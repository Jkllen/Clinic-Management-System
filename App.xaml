<Application
    x:Class="CruzNeryClinic.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:local="clr-namespace:CruzNeryClinic"
    StartupUri="MainWindow.xaml">

    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!--  Main application font  -->
        <FontFamily x:Key="AppFont">pack://application:,,,/Assets/Fonts/OpenSans/#Open Sans</FontFamily>

        <!--  Default TextBlock font  -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <!--  Default TextBox font  -->
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <!--#region TextBox and TextArea Styles-->
        <SolidColorBrush x:Key="FieldSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="FieldSurfaceReadonlyBrush" Color="#F7F9FC" />
        <SolidColorBrush x:Key="FieldBorderBrush" Color="#CBD5E1" />
        <SolidColorBrush x:Key="FieldBorderHoverBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="FieldAccentBrush" Color="#2F98D0" />
        <SolidColorBrush x:Key="FieldTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="FieldPlaceholderBrush" Color="#8B95A5" />

        <!--  Central single-line TextBox field style used across the system.  -->
        <Style x:Key="ModernTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
            <Setter Property="Padding" Value="10,2,14,2" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden" />

                                    <TextBlock
                                        x:Name="PlaceholderText"
                                        Margin="12,2,14,2"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontStretch="{TemplateBinding FontStretch}"
                                        FontStyle="{TemplateBinding FontStyle}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{StaticResource FieldPlaceholderBrush}"
                                        IsHitTestVisible="False"
                                        Text="{TemplateBinding Tag}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="FocusBar"
                                Height="2"
                                Margin="1,0,1,1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FieldAccentBrush}"
                                CornerRadius="0,0,7,7"
                                Opacity="0" />

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldAccentBrush}" />
                                <Setter TargetName="FocusBar" Property="Opacity" Value="1" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{StaticResource FieldSurfaceReadonlyBrush}" />
                                <Setter Property="Foreground" Value="#4B5563" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter TargetName="FieldBorder" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Central multiline TextBox style for notes, descriptions, and text areas.  -->
        <Style
            x:Key="ModernTextAreaStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="96" />
            <Setter Property="MinHeight" Value="82" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="12,10,14,10" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Disabled"
                                        VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}" />

                                    <TextBlock
                                        x:Name="PlaceholderText"
                                        Margin="12,2,14,2"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="Top"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontStretch="{TemplateBinding FontStretch}"
                                        FontStyle="{TemplateBinding FontStyle}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{StaticResource FieldPlaceholderBrush}"
                                        IsHitTestVisible="False"
                                        Text="{TemplateBinding Tag}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="FocusBar"
                                Height="2"
                                Margin="1,0,1,1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FieldAccentBrush}"
                                CornerRadius="0,0,7,7"
                                Opacity="0" />

                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldAccentBrush}" />
                                <Setter TargetName="FocusBar" Property="Opacity" Value="1" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsReadOnly" Value="True">
                                <Setter Property="Background" Value="{StaticResource FieldSurfaceReadonlyBrush}" />
                                <Setter Property="Foreground" Value="#4B5563" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter TargetName="FieldBorder" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Centralized user overlay editable TextBox style  -->
        <Style
            x:Key="UserOverlayTextBoxStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="46" />
        </Style>

        <!--  Central single-line TextBox variant for fields with a leading icon.  -->
        <Style
            x:Key="ModernIconTextBoxStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Padding" Value="48,2,18,2" />
        </Style>

        <!--  Central single-line TextBox variant for fields with leading and trailing icons.  -->
        <Style
            x:Key="ModernIconActionTextBoxStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Padding" Value="48,2,46,2" />
        </Style>

        <!--  Auth TextBox style for login/reset fields with a leading icon.  -->
        <Style x:Key="AuthIconTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
            <Setter Property="Padding" Value="25,2,14,2" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden" />

                                    <TextBlock
                                        x:Name="PlaceholderText"
                                        Margin="26,2,14,2"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontStretch="{TemplateBinding FontStretch}"
                                        FontStyle="{TemplateBinding FontStyle}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{StaticResource FieldPlaceholderBrush}"
                                        IsHitTestVisible="False"
                                        Text="{TemplateBinding Tag}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="FocusBar"
                                Height="2"
                                Margin="1,0,1,1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FieldAccentBrush}"
                                CornerRadius="0,0,7,7"
                                Opacity="0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldAccentBrush}" />
                                <Setter TargetName="FocusBar" Property="Opacity" Value="1" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter TargetName="FieldBorder" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Auth TextBox style for login/reset fields with leading and trailing icons.  -->
        <Style
            x:Key="AuthIconActionTextBoxStyle"
            BasedOn="{StaticResource AuthIconTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="48,2,46,2" />
        </Style>

        <!--  Auth visible-password TextBox style for password reveal states.  -->
        <Style
            x:Key="AuthVisiblePasswordTextBoxStyle"
            BasedOn="{StaticResource AuthIconActionTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="25,2,14,2" />
        </Style>

        <!--  Centralized user overlay read-only TextBox style  -->
        <Style
            x:Key="UserOverlayReadOnlyTextBoxStyle"
            BasedOn="{StaticResource UserOverlayTextBoxStyle}"
            TargetType="{x:Type TextBox}">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Foreground" Value="#8A8A8A" />
            <Setter Property="Background" Value="#FFF9FD" />
        </Style>

        <!--  Central visible-password TextBox style used by password reveal states.  -->
        <Style
            x:Key="ModernVisiblePasswordTextBoxStyle"
            BasedOn="{StaticResource ModernIconActionTextBoxStyle}"
            TargetType="TextBox">
        </Style>

        <Style
            x:Key="VisiblePasswordTextBoxStyle"
            BasedOn="{StaticResource ModernVisiblePasswordTextBoxStyle}"
            TargetType="TextBox">
        </Style>

        <!--  Centralized user overlay TextBox style for visible password mode  -->
        <Style
            x:Key="UserOverlayVisiblePasswordTextBoxStyle"
            BasedOn="{StaticResource UserOverlayTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="Padding" Value="10,2,46,2" />
        </Style>

        <!--  Shared search textbox style used in dashboard and module screens  -->
        <Style
            x:Key="SearchTextBoxStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="24,0,18,0" />
        </Style>
        <!--#endregion TextBox and TextArea Styles-->

        <!--#region Button and ScrollBar Styles-->
        <!--  Default Modern Filled Action Button Style  -->
        <Style x:Key="SmallActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Default Outlined Action Button Style  -->
        <Style x:Key="OutlineActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#223357" />
            <Setter Property="BorderBrush" Value="#223357" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EAF5FF" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D8EBFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Default Scrollbar style  -->
        <Style x:Key="BlueDataGridScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="#ffffff" />
            <Setter Property="Width" Value="5" />
            <Setter Property="Template">    
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border
                                                    x:Name="ThumbBorder"
                                                    Margin="7,0,2,0"
                                                    Background="#223357"
                                                    CornerRadius="4" />
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}" Value="Horizontal">
                                                    <Setter TargetName="ThumbBorder" Property="Margin" Value="0,2,0,2" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="3" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!--#endregion Button and ScrollBar Styles-->

        <!--#region Default Dropdown Combobox Style-->
        <SolidColorBrush x:Key="HeaderBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DropdownBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DropdownBorder" Color="#DADADA" />

        <SolidColorBrush x:Key="TextPlaceholder" Color="#8C8C8C" />
        <SolidColorBrush x:Key="TextRegular" Color="#111111" />
        <SolidColorBrush x:Key="TextSelected" Color="#FFFFFF" />

        <SolidColorBrush x:Key="AccentDarkBlue" Color="#223357" />
        <SolidColorBrush x:Key="AccentBlue" Color="#a7a8a9" />

        <DropShadowEffect
            x:Key="SoftShadow"
            BlurRadius="18"
            Direction="320"
            Opacity="0.15"
            ShadowDepth="5"
            Color="#3D2E56" />

        <Style x:Key="ImageStyleToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border
                            x:Name="templateRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#DADADA"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="1" Background="Transparent">
                                    <Path
                                        x:Name="arrow"
                                        Width="10"
                                        Height="6"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 5 5 L 10 0"
                                        RenderTransformOrigin="0.5,0.5"
                                        Stroke="{StaticResource AccentDarkBlue}"
                                        StrokeEndLineCap="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="2.2">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Grid>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#B8B8B8" />
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5" />
                                <Setter TargetName="templateRoot" Property="BorderBrush" Value="#223357" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="templateRoot" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExactStyleComboBoxItem" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextRegular}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border
                            x:Name="Bd"
                            Width="Auto"
                            Height="Auto"
                            Margin="6,0"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">

                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}" />
                                <Setter Property="Foreground" Value="{StaticResource TextSelected}" />
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDarkBlue}" />
                                <Setter Property="Foreground" Value="{StaticResource TextSelected}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExactStyleComboBox" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="{StaticResource HeaderBackground}" />
            <Setter Property="Foreground" Value="{StaticResource TextRegular}" />
            <Setter Property="Padding" Value="14,0,42,0" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="42" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ExactStyleComboBoxItem}" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="templateRoot">

                            <ToggleButton
                                x:Name="toggleButton"
                                Background="{TemplateBinding Background}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Style="{StaticResource ImageStyleToggleButton}" />

                            <TextBlock
                                x:Name="PlaceholderText"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Foreground="#8C8C8C"
                                IsHitTestVisible="False"
                                Text="{TemplateBinding Tag}"
                                Visibility="Collapsed" />

                            <ContentPresenter
                                x:Name="contentPresenter"
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                Placement="Bottom"
                                PopupAnimation="Slide">

                                <Border
                                    x:Name="dropDownBorder"
                                    MinWidth="{Binding ActualWidth, ElementName=templateRoot}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="15"
                                    Padding="0,8"
                                    Background="{StaticResource DropdownBackground}"
                                    BorderBrush="{StaticResource DropdownBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Effect="{StaticResource SoftShadow}">

                                    <ScrollViewer CanContentScroll="True" SnapsToDevicePixels="True">

                                        <ScrollViewer.Resources>
                                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                        </ScrollViewer.Resources>
                                        <ItemsPresenter
                                            x:Name="ItemsPresenter"
                                            KeyboardNavigation.DirectionalNavigation="Contained"
                                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SelectedIndex" Value="-1">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                                <Setter TargetName="contentPresenter" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--#endregion Default Dropdown Combobox Style-->

        <!--#region Modern Dropdown MenuItem Style-->
        <Style x:Key="ModernMoreDropdownMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextRegular}" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border
                            x:Name="menuItemBorder"
                            Margin="0,1"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentSource="Header"
                                RecognizesAccessKey="True" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="menuItemBorder" Property="Background" Value="#EEF2F7" />
                                <Setter Property="Foreground" Value="{StaticResource AccentDarkBlue}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#A0A7B2" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter TargetName="menuItemBorder" Property="Opacity" Value="0.58" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMoreMenuHeaderStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Width" Value="78" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#073C98" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#073C98" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernMoreDropdownMenuItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Grid>
                            <Border
                                x:Name="headerBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter
                                        Grid.Column="0"
                                        Margin="10,0,2,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        ContentSource="Header"
                                        RecognizesAccessKey="True" />

                                    <Path
                                        x:Name="headerArrow"
                                        Grid.Column="1"
                                        Width="8"
                                        Height="5"
                                        Margin="0,1,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 4 4 L 8 0"
                                        Stroke="{TemplateBinding Foreground}"
                                        StrokeEndLineCap="Round"
                                        StrokeStartLineCap="Round"
                                        StrokeThickness="1.8" />
                                </Grid>
                            </Border>

                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    MinWidth="170"
                                    Margin="0,6,0,0"
                                    Padding="6"
                                    Background="{StaticResource DropdownBackground}"
                                    BorderBrush="{StaticResource DropdownBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Effect="{StaticResource SoftShadow}"
                                    SnapsToDevicePixels="True">
                                    <StackPanel
                                        IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#0B4EBF" />
                                <Setter TargetName="headerBorder" Property="BorderBrush" Value="#0B4EBF" />
                            </Trigger>

                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="headerBorder" Property="Background" Value="#223357" />
                                <Setter TargetName="headerBorder" Property="BorderBrush" Value="#223357" />
                                <Setter TargetName="headerArrow" Property="Data" Value="M 0 4 L 4 0 L 8 4" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E5E7EB" />
                                <Setter Property="BorderBrush" Value="#D1D5DB" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--#endregion Modern Dropdown Menu Style-->

        <!--#region Button Defaults and Primary Styles-->
        <!--  Default Button font  -->
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <!--  Default ComboBox font  -->
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <!--  Shared rounded button style  -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#223357" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2E4575" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#182641" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Add New User Button and Show Archive Button  -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#223357" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Width" Value="180" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2E4575" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#182641" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--#endregion Button Defaults and Primary Styles-->


        <!--#region PasswordBox Styles-->
        <!--  Default PasswordBox font  -->
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <!--  Central PasswordBox style used across login, reset, and user management screens.  -->
        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,2,14,2" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="local:PasswordBoxAssist.MonitorPassword" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="PasswordBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        x:Name="PlaceholderText"
                                        Margin="12,2,14,2"
                                        VerticalAlignment="Center"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontStretch="{TemplateBinding FontStretch}"
                                        FontStyle="{TemplateBinding FontStyle}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{StaticResource FieldPlaceholderBrush}"
                                        IsHitTestVisible="False"
                                        Text="{TemplateBinding Tag}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="FocusBar"
                                Height="2"
                                Margin="1,0,1,1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FieldAccentBrush}"
                                CornerRadius="0,0,7,7"
                                Opacity="0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="local:PasswordBoxAssist.IsPasswordEmpty" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{StaticResource FieldAccentBrush}" />
                                <Setter TargetName="FocusBar" Property="Opacity" Value="1" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter TargetName="PasswordBoxBorder" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style
            x:Key="LoginPasswordBoxStyle"
            BasedOn="{StaticResource ModernPasswordBoxStyle}"
            TargetType="PasswordBox">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Padding" Value="48,2,46,2" />
        </Style>

        <Style
            x:Key="ModernIconPasswordBoxStyle"
            BasedOn="{StaticResource ModernPasswordBoxStyle}"
            TargetType="PasswordBox">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Padding" Value="48,2,46,2" />
        </Style>

        <!--  Auth PasswordBox style for login/reset fields with lock and eye icons.  -->
        <Style x:Key="AuthIconPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="52" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{StaticResource FieldTextBrush}" />
            <Setter Property="Background" Value="{StaticResource FieldSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource FieldBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="25,2,14,2" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="local:PasswordBoxAssist.MonitorPassword" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="PasswordBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        VerticalAlignment="Center" />

                                    <TextBlock
                                        x:Name="PlaceholderText"
                                        Margin="26,2,14,2"
                                        VerticalAlignment="Center"
                                        FontFamily="{TemplateBinding FontFamily}"
                                        FontSize="{TemplateBinding FontSize}"
                                        FontStretch="{TemplateBinding FontStretch}"
                                        FontStyle="{TemplateBinding FontStyle}"
                                        FontWeight="{TemplateBinding FontWeight}"
                                        Foreground="{StaticResource FieldPlaceholderBrush}"
                                        IsHitTestVisible="False"
                                        Text="{TemplateBinding Tag}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>

                            <Border
                                x:Name="FocusBar"
                                Height="2"
                                Margin="1,0,1,1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FieldAccentBrush}"
                                CornerRadius="0,0,7,7"
                                Opacity="0" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="local:PasswordBoxAssist.IsPasswordEmpty" Value="True">
                                <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{StaticResource FieldBorderHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBoxBorder" Property="BorderBrush" Value="{StaticResource FieldAccentBrush}" />
                                <Setter TargetName="FocusBar" Property="Opacity" Value="1" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                                <Setter TargetName="PasswordBoxBorder" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="UserOverlayPasswordBoxStyle"
            BasedOn="{StaticResource ModernPasswordBoxStyle}"
            TargetType="PasswordBox">
            <Setter Property="Height" Value="46" />
        </Style>
        <!--#endregion PasswordBox Styles-->

        <!--#region Icon Button Styles-->
        <!--
            Transparent icon button style.
            Used for the eye/eye-slash password toggle.
            Removes the default hover box but keeps hover feedback through opacity.
        -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <!--  Slight hover effect without showing default button box  -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.75" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--#endregion Icon Button Styles-->

        <!--#region Shared Brushes-->
        <SolidColorBrush x:Key="SidebarBrush" Color="#223357" />
        <SolidColorBrush x:Key="SelectedMenuBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2F98D0" />
        <SolidColorBrush x:Key="SuccessGreenBrush" Color="#50C878" />
        <SolidColorBrush x:Key="DangerRedBrush" Color="#E53935" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D8D8D8" />
        <SolidColorBrush x:Key="ScreenBackgroundBrush" Color="#F4F6F6" />
        <!--#endregion Shared Brushes-->

        <!--#region Layout, Sidebar, and Table Styles-->
        <!--  Shared White Dashboard/module Card Style  -->
        <Style x:Key="DashboardCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="15" />
            <Setter Property="Padding" Value="15" />
        </Style>

        <!--  Container style for table sections like Queue and Recent Transactions  -->
        <Style x:Key="DashboardTableContainerStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <!--  Shared large table/container box (Used in Today's Appointment in dashboard)  -->
        <Style x:Key="LargePanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!--  Shared sidebar menu button  -->
        <Style x:Key="SidebarMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="MenuBorder"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#19FFFFFF" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#0CFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Shared selected sidebar menu button  -->
        <Style
            x:Key="SelectedSidebarMenuButtonStyle"
            BasedOn="{StaticResource SidebarMenuButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SelectedMenuBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!--  Shared table style used by Dashboard, Patients, Appointments, Billing, and Users  -->
        <Style x:Key="DashboardDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CFCFCF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style x:Key="DashboardDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#F6F6F6" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="DashboardDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Shared scrollbar style for DataGrid tables  -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="True"
                                Orientation="{TemplateBinding Orientation}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border
                                                    Margin="2,0"
                                                    Background="#445577"
                                                    CornerRadius="4"
                                                    Opacity="0.6" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ViewAllButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Scrollbar style for main module screens only, not the sidebar  -->
        <Style x:Key="MainScreenScrollBarStyle" TargetType="{x:Type ScrollBar}">

            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track
                                x:Name="PART_Track"
                                IsDirectionReversed="True"
                                Orientation="{TemplateBinding Orientation}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border
                                                    x:Name="ThumbBorder"
                                                    Margin="2,0"
                                                    Background="#445577"
                                                    CornerRadius="4"
                                                    Opacity="0.6" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
