<UserControl
    x:Class="CruzNeryClinic.Views.BillingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:billingViews="clr-namespace:CruzNeryClinic.Views.Billing"
    xmlns:converters="clr-namespace:CruzNeryClinic.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Billing/BillingManagementStyles.xaml" />
                <ResourceDictionary Source="PatientManagement/PatientManagementStyles.xaml" />
                <ResourceDictionary Source="AppointmentManagement/AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:PesoCurrencyConverter x:Key="PesoCurrencyConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

            <!-- Soft drop shadow for billing panels (scoped to this view) -->
            <DropShadowEffect x:Key="CardDropShadow"
                              Color="#000000"
                              BlurRadius="14"
                              ShadowDepth="2"
                              Direction="270"
                              Opacity="0.16" />

            <Style x:Key="BillingPanelShadowStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource BillingPanelStyle}">
                <Setter Property="Effect" Value="{StaticResource CardDropShadow}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <Grid Margin="24,28,24,18">

            <Grid.RowDefinitions>
                <!--  Header  -->
                <RowDefinition Height="Auto" />

                <!--  Summary cards  -->
                <RowDefinition Height="Auto" />

                <!--  Toolbar: search, filter, module buttons  -->
                <RowDefinition Height="Auto" />

                <!--  Recent Billing + Payment History section  -->
                <RowDefinition Height="*" MinHeight="280" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Billing and Payment" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="Process invoice payments, balance payments, and manual transactions" />
            </StackPanel>

            <!--  Summary cards  -->
            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Unpaid  -->
                <Border
                    Grid.Column="0"
                    Padding="22,18"
                    Style="{StaticResource BillingPanelShadowStyle}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="14"
                            Opacity="0.18"
                            ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            VerticalAlignment="Center"
                            FontSize="26"
                            Foreground="#2D7BE5"
                            Icon="FileInvoiceDollar" />
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#333333"
                                Text="Unpaid" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#C62828"
                                Text="{Binding UnpaidCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Partial  -->
                <Border
                    Grid.Column="2"
                    Padding="22,18"
                    Style="{StaticResource BillingPanelShadowStyle}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="14"
                            Opacity="0.18"
                            ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            VerticalAlignment="Center"
                            FontSize="26"
                            Foreground="#2D7BE5"
                            Icon="FileInvoiceDollar" />
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#333333"
                                Text="Partial" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#D49A00"
                                Text="{Binding PartialCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Paid Today  -->
                <Border
                    Grid.Column="4"
                    Padding="22,18"
                    Style="{StaticResource BillingPanelShadowStyle}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="14"
                            Opacity="0.18"
                            ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            VerticalAlignment="Center"
                            FontSize="26"
                            Foreground="#2D7BE5"
                            Icon="FileInvoiceDollar" />
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#333333"
                                Text="Paid Today" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#00A423"
                                Text="{Binding PaidTodayCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Collected Today  -->
                <Border
                    Grid.Column="6"
                    Padding="22,18"
                    Style="{StaticResource BillingPanelShadowStyle}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="14"
                            Opacity="0.18"
                            ShadowDepth="3" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            VerticalAlignment="Center"
                            FontSize="26"
                            Foreground="#2D7BE5"
                            Icon="FileInvoiceDollar" />
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="#333333"
                                Text="Collected Today" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#2D7BE5"
                                Text="{Binding CollectedTodayDisplay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Toolbar: search + module action buttons  -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Search box  -->
                <Grid Grid.Column="0" Height="46">
                    <TextBox
                        Height="46"
                        Padding="44,0,12,0"
                        VerticalContentAlignment="Center"
                        Style="{StaticResource ModernTextBoxStyle}"
                        Tag="Search"
                        Text="{Binding RecentSearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <fa:IconBlock
                        Margin="16,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Foreground="#666666"
                        Icon="Search"
                        IsHitTestVisible="False" />
                </Grid>

                <!--  Module action buttons  -->
                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal">

                    <Button
                        Height="46"
                        Width="180"
                        Margin="0,0,12,0"
                        Background="#223357"
                        Command="{Binding OpenManualTransactionOverlayCommand}"
                        Content="Manual Transaction"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Height="46"
                        Width="170"
                        Margin="0,0,12,0"
                        Background="#223357"
                        Command="{Binding OpenBalancePaymentOverlayCommand}"
                        Content="Balance Payment"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Height="46"
                        Width="220"
                        Background="#223357"
                        Command="{Binding OpenInvoicePaymentOverlayCommand}"
                        Content="Process Invoice Payments"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>

            <!--  Recent billing transactions + patient payment history  -->
            <Border
                Grid.Row="3"
                Padding="20"
                Style="{StaticResource BillingPanelShadowStyle}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.7*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!--  Recent Billing Transactions  -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="#111111"
                                Text="Recent Billing Transactions" />

                            <ComboBox
                                Grid.Column="1"
                                Width="150"
                                Height="30"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                FontSize="13"
                                ItemsSource="{Binding BillingStatusFilterOptions}"
                                SelectedItem="{Binding SelectedBillingStatusFilter, Mode=TwoWay}"
                                MaxDropDownHeight="150"
                                Padding="10,2"
                                Style="{StaticResource ExactStyleComboBox}"
                                Tag="Filter">

                                <ComboBox.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="Set billing status filter" />
                                    </ToolTip>
                                </ComboBox.ToolTip>
                            </ComboBox>
                        </Grid>                 
                
                        <DataGrid
                            Grid.Row="1"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding BillingRecords}"
                            MinRowHeight="38"
                            RowHeight="40"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Binding="{Binding ReceiptNumber}"
                                    Header="Invoice No." />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="105"
                                    Binding="{Binding PatientCode}"
                                    Header="Patient ID" />
                                <DataGridTextColumn
                                    Width="1.3*"
                                    MinWidth="150"
                                    Binding="{Binding PatientName}"
                                    Header="Patient Name" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="105"
                                    Binding="{Binding TransactionDateDisplay}"
                                    Header="Date" />
                                <DataGridTextColumn
                                    Width="1.2*"
                                    MinWidth="135"
                                    Binding="{Binding ServiceName}"
                                    Header="Service" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding TotalAmountDisplay}"
                                    Header="Total" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding BalanceDisplay}"
                                    Header="Balance" />
                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="95"
                                    Binding="{Binding PaymentStatus}"
                                    Header="Status" />

                                <DataGridTemplateColumn
                                    Width="1.4*"
                                    MinWidth="170"
                                    Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <Button
                                                    Width="70"
                                                    Height="28"
                                                    Margin="0,0,6,0"
                                                    Background="#223357"
                                                    Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="White"
                                                    Style="{StaticResource SmallActionButtonStyle}">

                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconBlock
                                                            Margin="0,0,5,0"
                                                            FontSize="11"
                                                            Foreground="White"
                                                            Icon="Print" />

                                                        <TextBlock
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="Print" />
                                                    </StackPanel>
                                                </Button>

                                                <Button
                                                    Width="65"
                                                    Height="28"
                                                    Command="{Binding DataContext.ViewReceiptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="View"
                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!--  Payment History for Patient  -->
                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="White"
                        BorderBrush="#D8D8D8"
                        BorderThickness="1"
                        CornerRadius="12">

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="#111111"
                                    Text="Payment History for Patient" />

                                <TextBlock
                                    Margin="0,16,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Patient ID or Name" />

                                <!--  Patient lookup  -->
                                <Grid
                                    Width="230"
                                    Height="42"
                                    HorizontalAlignment="Left">

                                    <TextBox
                                        x:Name="PaymentHistoryPatientSearchBox"
                                        Height="42"
                                        Style="{StaticResource ModernTextBoxStyle}"
                                        Tag="Enter Patient ID or Name"
                                        Text="{Binding PaymentHistorySearchText, UpdateSourceTrigger=PropertyChanged}" />

                                    <Popup
                                        Width="{Binding ActualWidth, ElementName=PaymentHistoryPatientSearchBox}"
                                        AllowsTransparency="True"
                                        IsOpen="{Binding IsPaymentHistorySearchPopupOpen, Mode=TwoWay}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=PaymentHistoryPatientSearchBox}"
                                        StaysOpen="True">

                                        <Border
                                            MaxHeight="220"
                                            Background="White"
                                            BorderBrush="#D8D8D8"
                                            BorderThickness="1"
                                            CornerRadius="8">

                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="16"
                                                    Opacity="0.18"
                                                    ShadowDepth="3" />
                                            </Border.Effect>

                                            <ListBox
                                                BorderThickness="0"
                                                ItemsSource="{Binding PaymentHistoryPatientResults}"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                SelectedItem="{Binding SelectedPaymentHistoryPatient, Mode=TwoWay}">

                                                <ListBox.Resources>
                                                    <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                                </ListBox.Resources>

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,10" Background="Transparent">
                                                            <StackPanel>
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#111111">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0} - {1}">
                                                                            <Binding Path="PatientCode" />
                                                                            <Binding Path="PatientName" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>

                                                                <TextBlock
                                                                    Margin="0,3,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#777777"
                                                                    Text="{Binding Category}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <TextBlock
                                    Margin="0,12,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Patient Name" />

                                <TextBox
                                    Width="230"
                                    Height="42"
                                    HorizontalAlignment="Left"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding PaymentHistoryPatientName, Mode=OneWay}" />

                                <!--  Transaction History title only appears after patient selection  -->
                                <TextBlock
                                    Margin="0,18,0,8"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Transaction History"
                                    Visibility="{Binding HasSelectedPaymentHistoryPatient, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!--  Transaction History list only appears after patient selection  -->
                                <Border
                                    Padding="12"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding HasSelectedPaymentHistoryPatient, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding LatestPatientBillingRecords}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,0,10"
                                                        Padding="12"
                                                        Background="#EFEFF3"
                                                        CornerRadius="6">

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <!--  Receipt Details  -->
                                                                <ColumnDefinition Width="*" />
                                                                <!--  Status Column  -->
                                                                <ColumnDefinition Width="74" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                                <TextBlock
                                                                    MaxWidth="125"
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding ReceiptNumber}"
                                                                    TextWrapping="Wrap" />

                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#666666"
                                                                    Text="{Binding TransactionDateDisplay}" />

                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#333333"
                                                                    Text="{Binding ServiceName}" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                                <Border
                                                                    Width="54"
                                                                    Margin="0,0,0,20"
                                                                    Padding="8,3"
                                                                    CornerRadius="5">

                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#D9F8DF" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                                    <Setter Property="Background" Value="#FFEBC0" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                                    <Setter Property="Background" Value="#FFD6D6" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>

                                                                    <TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        Text="{Binding PaymentStatus}"
                                                                        TextAlignment="Center">

                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#00A423" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                                        <Setter Property="Foreground" Value="#D49A00" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>

                                                                <Button
                                                                    Width="48"
                                                                    Height="24"
                                                                    Command="{Binding DataContext.ExpandReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Expand"
                                                                    FontSize="10"
                                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Foreground="#777777"
                                            Text="No transactions found."
                                            Visibility="{Binding SelectedPatientBillingRecords.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                                        <Button
                                            Width="90"
                                            Height="34"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Right"
                                            Command="{Binding OpenTransactionHistoryOverlayCommand}"
                                            Content="View all"
                                            Style="{StaticResource OutlineActionButtonStyle}"
                                            Visibility="{Binding HasMoreThanThreePatientBillingRecords, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

        </Grid>

        <!--  ============================================================
              Invoice Payment Overlay
              ============================================================  -->
        <Grid Background="#66000000" Visibility="{Binding IsInvoicePaymentOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="1200"
                MaxHeight="780"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Close button  -->
                    <Button
                        Grid.Row="0"
                        Width="38"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#F1F1F4"
                        BorderThickness="0"
                        Command="{Binding CloseBillingModuleOverlayCommand}"
                        Style="{StaticResource SecondaryButtonStyle}">
                        <fa:IconBlock
                            FontSize="16"
                            Foreground="#444444"
                            Icon="Times" />
                    </Button>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <!--  Appointment / Invoice Payment Section  -->
                        <Grid Margin="0,0,14,0">
                            <Grid.RowDefinitions>
                                <!-- Header + search -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="22" />

                                <!-- Patient/category/amount/payment row -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />

                                <!-- Patient name/discount/billable row -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />

                                <!-- Service/date/invoice number row -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />

                                <!-- Invoice Builder row -->
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />

                                <!-- Appointment type row -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="1.6*" />
                            </Grid.ColumnDefinitions>

                            <!--  Title and completed appointment lookup  -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="0"
                                Grid.ColumnSpan="9">
                                <TextBlock
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Foreground="#111111"
                                    Text="Invoice Payment" />

                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontSize="15"
                                    Foreground="#777777"
                                    Text="Create or update invoices from completed appointments, then record payments." />

                                <!--  Completed appointment lookup  -->
                                <Grid
                                    Width="390"
                                    Height="52"
                                    Margin="0,22,0,0"
                                    HorizontalAlignment="Left">

                                    <TextBox
                                        x:Name="AppointmentPaymentSearchBox"
                                        Height="52"
                                        Style="{StaticResource SearchTextBoxStyle}"
                                        Text="{Binding AppointmentPaymentSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                    <fa:IconBlock
                                        Margin="18,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="20"
                                        Foreground="#666666"
                                        Icon="Search" />

                                    <TextBlock
                                        Margin="52,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="17"
                                        Foreground="#8A8A8A"
                                        IsHitTestVisible="False"
                                        Text="Search completed treatment">

                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppointmentPaymentSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>

                                                    <DataTrigger Binding="{Binding AppointmentPaymentSearchText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Popup
                                        Width="{Binding ActualWidth, ElementName=AppointmentPaymentSearchBox}"
                                        AllowsTransparency="True"
                                        IsOpen="{Binding IsAppointmentPaymentSearchPopupOpen, Mode=TwoWay}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=AppointmentPaymentSearchBox}"
                                        StaysOpen="True">

                                        <Border
                                            MaxHeight="250"
                                            Background="White"
                                            BorderBrush="#D8D8D8"
                                            BorderThickness="1"
                                            CornerRadius="8">

                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="16"
                                                    Opacity="0.18"
                                                    ShadowDepth="3" />
                                            </Border.Effect>

                                            <ListBox
                                                BorderThickness="0"
                                                ItemsSource="{Binding FilteredAppointmentPaymentItems}"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                SelectedItem="{Binding SelectedAppointmentPaymentItem, Mode=TwoWay}">

                                                <ListBox.Resources>
                                                    <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />

                                                    <Style TargetType="{x:Type ListBoxItem}">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Padding" Value="0" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                                    <Border x:Name="ItemBorder" Background="Transparent">
                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" />
                                                                    </Border>

                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5FF" />
                                                                        </Trigger>

                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#DDF0FF" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.Resources>

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,10">
                                                            <StackPanel>
                                                                <TextBlock
                                                                    FontSize="14"
                                                                    FontWeight="Bold"
                                                                    Foreground="#111111">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0} - {1}">
                                                                            <Binding Path="PatientCode" />
                                                                            <Binding Path="PatientName" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>

                                                                <TextBlock
                                                                    Margin="0,3,0,0"
                                                                    FontSize="12"
                                                                    Foreground="#777777">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0} • {1}">
                                                                            <Binding Path="ServiceName" />
                                                                            <Binding Path="TreatmentDateDisplay" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <!--  Row 2  -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Patient ID" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentPatientCode, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Category" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentCategory, Mode=OneWay}" />
                            </StackPanel>
 
                            <StackPanel Grid.Row="2" Grid.Column="4">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Total Amount *" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Text="{Binding AppointmentTotalAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="6">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Payment Amount *" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Text="{Binding AppointmentPaymentAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <!--  Summary box  -->
                            <Border
                                Grid.Row="2"
                                Grid.RowSpan="3"
                                Grid.Column="8"
                                Padding="22"
                                Background="#EAF5FF"
                                BorderBrush="#B9DAFF"
                                BorderThickness="1"
                                CornerRadius="12">

                                <StackPanel>
                                    <Grid>
                                        <TextBlock Foreground="#223357" Text="Total Amount:" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Foreground="#223357"
                                            Text="{Binding AppointmentTotalAmount, StringFormat=₱ {0:N2}}" />
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppointmentDiscountType}" Value="PWD">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AppointmentDiscountType}" Value="Senior Citizen">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AppointmentDiscountType}" Value="PWD/Senior">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <TextBlock Foreground="#223357" Text="VAT Exempt Sales:" />

                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Foreground="#223357"
                                            Text="{Binding AppointmentVatExemptSalesDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <TextBlock Foreground="#223357" Text="{Binding AppointmentDiscountLabel}" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Foreground="#00A423"
                                            Text="{Binding AppointmentDiscountAmount, StringFormat=-₱ {0:N2}}" />
                                    </Grid>

                                    <Grid Margin="0,14,0,0">
                                        <TextBlock Foreground="#223357" Text="Payment:" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Foreground="#223357"
                                            Text="{Binding AppointmentPaymentAmount, StringFormat=-₱ {0:N2}}" />
                                    </Grid>

                                    <Border
                                        Height="1"
                                        Margin="0,18,0,14"
                                        Background="#223357" />

                                    <Grid>
                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="#223357"
                                            Text="Balance:" />

                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Foreground="#00A423"
                                            Text="{Binding AppointmentBalanceDisplay}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!--  Row 4  -->
                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Patient Name" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentPatientName, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Discount Amount" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentDiscountAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                            </StackPanel>

                            <Border
                                Grid.Row="4"
                                Grid.Column="4"
                                Grid.ColumnSpan="3"
                                Height="52"
                                Margin="0,31,0,0"
                                Padding="20,0"
                                Background="#EEEEEE"
                                CornerRadius="8">

                                <Grid>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Foreground="#888888"
                                        Text="Billable Amount:" />

                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        Foreground="#888888"
                                        Text="{Binding AppointmentSubtotalDisplay}" />
                                </Grid>
                            </Border>

                            <!--  Row 6  -->
                            <StackPanel Grid.Row="6" Grid.Column="0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Service / Treatment" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentServiceName, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6" Grid.Column="2">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Date" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding AppointmentDate, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel
                                Grid.Row="6"
                                Grid.Column="4"
                                Grid.ColumnSpan="3">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Invoice Item Name *" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Example: Dentures"
                                    Text="{Binding AppointmentInvoiceItemName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Notes and action buttons  -->
                            <StackPanel
                                Grid.Row="6"
                                Grid.RowSpan="3"
                                Grid.Column="8">

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Notes" />

                                <TextBox
                                    Height="120"
                                    Margin="0,8,0,0"
                                    AcceptsReturn="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Text="{Binding AppointmentNotes, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap" />

                                <StackPanel
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">

                                    <Button
                                        Width="190"
                                        Height="46"
                                        Margin="0,0,14,0"
                                        Background="#223357"
                                        Command="{Binding ProcessAppointmentPaymentCommand}"
                                        Foreground="White"
                                        Style="{StaticResource SecondaryButtonStyle}">

                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Text="₱ Save / Pay Invoice" />
                                    </Button>

                                    <Button
                                        Width="84"
                                        Height="46"
                                        Background="White"
                                        BorderBrush="#111111"
                                        BorderThickness="1"
                                        Command="{Binding ClearAppointmentPaymentFormCommand}"
                                        Content="Clear"
                                        FontSize="14"
                                        Foreground="Black"
                                        Style="{StaticResource OutlineActionButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- =====================================================
                                Invoice Builder Section
                                ===================================================== -->
                            <Border
                                Grid.Row="8"
                                Grid.Column="0"
                                Grid.ColumnSpan="7"
                                Margin="0,16,0,0"
                                Padding="16"
                                Background="#F7F8FB"
                                BorderBrush="#D8D8D8"
                                BorderThickness="1"
                                CornerRadius="8">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <!-- Header -->
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />

                                        <!-- Open invoice selector -->
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />

                                        <!-- Create new invoice -->
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />

                                        <!-- Selected invoice summary -->
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />

                                        <!-- Selected invoice items -->
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="#111111"
                                                Text="Invoice Builder" />

                                            <TextBlock
                                                Margin="0,3,0,0"
                                                FontSize="12"
                                                Foreground="#777777"
                                                Text="Select an existing open invoice or create a new invoice for this treatment." />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Open invoice selector -->
                                    <StackPanel Grid.Row="2">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="Open Invoices" />

                                        <ComboBox
                                            Height="42"
                                            Margin="0,7,0,0"
                                            ItemsSource="{Binding PatientOpenInvoices}"
                                            SelectedItem="{Binding SelectedOpenInvoice, Mode=TwoWay}"
                                            Style="{StaticResource ExactStyleComboBox}"
                                            Tag="Select existing invoice">

                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock>
                                                        <Run Text="{Binding ReceiptNumber}" />
                                                        <Run Text=" - " />
                                                        <Run Text="{Binding ServiceName}" />
                                                        <Run Text=" | Balance: " />
                                                        <Run Text="{Binding RemainingBalanceDisplay}" />
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Create new invoice -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="#333333"
                                                Text="New Invoice Title" />

                                            <TextBox
                                                Height="42"
                                                Margin="0,7,0,0"
                                                Style="{StaticResource ModernTextBoxStyle}"
                                                Tag="Example: Denture Case"
                                                Text="{Binding NewInvoiceTitle, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <Button
                                            Grid.Column="2"
                                            Width="Auto"
                                            Height="42"
                                            Margin="0,25,0,0"
                                            Background="#223357"
                                            Command="{Binding CreateNewInvoiceForSelectedTreatmentCommand}"
                                            Foreground="White"
                                            Style="{StaticResource SecondaryButtonStyle}">

                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Text="Create Invoice" />
                                        </Button>
                                    </Grid>

                                    <!-- Selected invoice summary -->
                                    <Border
                                        Grid.Row="6"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="#E1E1E1"
                                        BorderThickness="1"
                                        CornerRadius="6">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="10" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#111111"
                                                Text="Selected Invoice Summary" />

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#777777"
                                                        Text="Invoice No." />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="#111111"
                                                        Text="{Binding SelectedInvoiceNumberDisplay}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#777777"
                                                        Text="Total" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="#111111"
                                                        Text="{Binding SelectedInvoiceTotalDisplay}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#777777"
                                                        Text="Remaining Balance" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="#C62828"
                                                        Text="{Binding SelectedInvoiceBalanceDisplay}" />
                                                </StackPanel>
                                            </Grid>

                                            <Button
                                                Grid.Row="4"
                                                HorizontalAlignment="Right"
                                                Width="250"
                                                Height="40"
                                                Background="#223357"
                                                Command="{Binding AddSelectedTreatmentToInvoiceCommand}"
                                                Foreground="White"
                                                Style="{StaticResource SecondaryButtonStyle}">

                                                <TextBlock
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Text="Add Item to Selected Invoice" />
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Selected invoice items -->
                                    <Border
                                        Grid.Row="8"
                                        Padding="12"
                                        Background="White"
                                        BorderBrush="#E1E1E1"
                                        BorderThickness="1"
                                        CornerRadius="6">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="8" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Grid.Row="0"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Foreground="#111111"
                                                Text="Items in Selected Invoice" />

                                            <ItemsControl Grid.Row="2" ItemsSource="{Binding SelectedInvoiceItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Margin="0,0,0,8"
                                                            Padding="10"
                                                            Background="#F5F6FA"
                                                            CornerRadius="5">

                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="110" />
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel Grid.Column="0">
                                                                    <TextBlock
                                                                        FontSize="13"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#111111"
                                                                        Text="{Binding ServiceName}" />

                                                                    <TextBlock
                                                                        Margin="0,3,0,0"
                                                                        FontSize="11"
                                                                        Foreground="#777777"
                                                                        Text="{Binding TreatmentDateDisplay}" />
                                                                </StackPanel>

                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#223357"
                                                                    Text="{Binding AmountDisplay}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock
                                                Grid.Row="2"
                                                HorizontalAlignment="Left"
                                                FontSize="12"
                                                Foreground="#777777"
                                                Text="No items added yet."
                                                Visibility="{Binding SelectedInvoiceItems.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!--  Row 10  -->
                            <StackPanel Grid.Row="10" Grid.Column="0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Appointment Type" />
                                <TextBox
                                    Height="52"
                                    Margin="0,8,0,0"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="Completed Appointment" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  ============================================================
              Balance Payment Overlay
              ============================================================  -->
        <Grid Background="#66000000" Visibility="{Binding IsBalancePaymentOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="1180"
                MaxHeight="780"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button
                        Grid.Row="0"
                        Width="38"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#F1F1F4"
                        BorderThickness="0"
                        Command="{Binding CloseBillingModuleOverlayCommand}"
                        Style="{StaticResource SecondaryButtonStyle}">
                        <fa:IconBlock
                            FontSize="16"
                            Foreground="#444444"
                            Icon="Times" />
                    </Button>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <billingViews:BalancePaymentView Margin="0,0,14,0" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  ============================================================
              Manual Transaction Overlay
              ============================================================  -->
        <Grid Background="#66000000" Visibility="{Binding IsManualTransactionOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="1180"
                MaxHeight="780"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button
                        Grid.Row="0"
                        Width="38"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#F1F1F4"
                        BorderThickness="0"
                        Command="{Binding CloseBillingModuleOverlayCommand}"
                        Style="{StaticResource SecondaryButtonStyle}">
                        <fa:IconBlock
                            FontSize="16"
                            Foreground="#444444"
                            Icon="Times" />
                    </Button>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <billingViews:ManualTransactionView Margin="0,0,14,0" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--  Full Transaction History Overlay  -->
        <Grid Background="#66000000" Visibility="{Binding IsTransactionHistoryOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="720"
                MaxHeight="620"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Transaction History" />

                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="14"
                            Foreground="#777777"
                            Text="{Binding PaymentHistoryPatientName}" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Row="2"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding SelectedPatientBillingRecords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="16"
                                        Background="#EFEFF3"
                                        CornerRadius="8">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Text="{Binding ReceiptNumber}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#666666"
                                                    Text="{Binding TransactionDateDisplay}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#333333"
                                                    Text="{Binding ServiceName}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#333333"
                                                    Text="{Binding TotalAmountDisplay}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Border
                                                    Width="54"
                                                    Margin="0,0,0,12"
                                                    Padding="10,4"
                                                    CornerRadius="5">

                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#D9F8DF" />

                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                    <Setter Property="Background" Value="#FFEBC0" />
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                    <Setter Property="Background" Value="#FFD6D6" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        FontSize="11"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding PaymentStatus}"
                                                        TextAlignment="Center">

                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#00A423" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                        <Setter Property="Foreground" Value="#D49A00" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Button
                                                    Width="78"
                                                    Height="30"
                                                    Command="{Binding DataContext.ExpandReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Expand"
                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button
                        Grid.Row="4"
                        Width="110"
                        Height="40"
                        HorizontalAlignment="Right"
                        Background="#223357"
                        Command="{Binding CloseTransactionHistoryOverlayCommand}"
                        Content="Close"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SmallActionButtonStyle}" />
                </Grid>
            </Border>
        </Grid>

        <!--  Receipt Detail Overlay  -->
        <Grid Background="#66000000" Visibility="{Binding IsReceiptOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="820"
                MaxHeight="700"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Border
                        Grid.Row="0"
                        Background="#223357"
                        CornerRadius="18,18,0,0">

                        <Grid Margin="30,0">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Dental Invoice" />

                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Invoice Number" />

                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding SelectedReceiptDetail.ReceiptNumber}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  Body  -->
                    <ScrollViewer
                        Grid.Row="1"
                        Padding="30"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <StackPanel>

                            <!--  Info blocks  -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Patient Information  -->
                                <StackPanel Grid.Column="0">
                                    <Border Padding="12" Background="#F3F7FA">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Text="Patient Information" />
                                    </Border>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock FontSize="14" Text="{Binding SelectedReceiptDetail.PatientName}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PatientCode}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PatientCategory, StringFormat=Category: {0}}" />
                                    </StackPanel>
                                </StackPanel>

                                <!--  Transaction Information  -->
                                <StackPanel Grid.Column="2">
                                    <Border Padding="12" Background="#F3F7FA">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Text="Invoice Information" />
                                    </Border>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock FontSize="14" Text="{Binding SelectedReceiptDetail.TransactionDateDisplay}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PaymentMethod, StringFormat=Payment Method: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PaymentStatus, StringFormat=Payment Status: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.BillingSource, StringFormat=Billing Source: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.LatestPaymentDateDisplay, StringFormat=Latest Payment: {0}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border
                                Height="1"
                                Margin="0,28,0,20"
                                Background="#DDDDDD" />

                            <!--  Invoice Items  -->
                            <TextBlock
                                FontSize="19"
                                FontWeight="Bold"
                                Text="Invoice Items" />

                            <DataGrid
                                Margin="0,12,0,0"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserResizeRows="False"
                                HeadersVisibility="Column"
                                GridLinesVisibility="Horizontal"
                                ItemsSource="{Binding SelectedReceiptDetail.InvoiceItems}"
                                RowHeight="46"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                IsReadOnly="True"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                MaxHeight="190">

                                <DataGrid.Resources>
                                    <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />

                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Foreground" Value="#111111" />
                                        <Setter Property="Background" Value="#F3F7FA" />
                                        <Setter Property="BorderBrush" Value="#DDDDDD" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Padding" Value="10,8" />
                                    </Style>

                                    <Style TargetType="{x:Type DataGridCell}">
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="Foreground" Value="#333333" />
                                        <Setter Property="BorderBrush" Value="#EEEEEE" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Padding" Value="10,6" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="1.5*"
                                        Binding="{Binding ServiceName}"
                                        Header="Description / Nature of Service" />

                                    <DataGridTextColumn
                                        Width="0.7*"
                                        Binding="{Binding TreatmentDateDisplay}"
                                        Header="Date" />

                                    <DataGridTextColumn
                                        Width="0.45*"
                                        Header="Qty">
                                        <DataGridTextColumn.Binding>
                                            <Binding Source="1" />
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>

                                    <DataGridTextColumn
                                        Width="0.7*"
                                        Binding="{Binding AmountDisplay}"
                                        Header="Amount" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="#777777"
                                Text="No invoice items found."
                                Visibility="{Binding SelectedReceiptDetail.InvoiceItems.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                            <!--  Payment History  -->
                            <TextBlock
                                Margin="0,26,0,0"
                                FontSize="19"
                                FontWeight="Bold"
                                Text="Payment History" />

                            <DataGrid
                                Margin="0,12,0,0"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                CanUserResizeRows="False"
                                HeadersVisibility="Column"
                                GridLinesVisibility="Horizontal"
                                ItemsSource="{Binding SelectedReceiptDetail.PaymentHistory}"
                                RowHeight="44"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                IsReadOnly="True"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                MaxHeight="170">

                                <DataGrid.Resources>
                                    <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />

                                    <Style TargetType="{x:Type DataGridColumnHeader}">
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Foreground" Value="#111111" />
                                        <Setter Property="Background" Value="#F3F7FA" />
                                        <Setter Property="BorderBrush" Value="#DDDDDD" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Padding" Value="10,8" />
                                    </Style>

                                    <Style TargetType="{x:Type DataGridCell}">
                                        <Setter Property="FontSize" Value="13" />
                                        <Setter Property="Foreground" Value="#333333" />
                                        <Setter Property="BorderBrush" Value="#EEEEEE" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Padding" Value="10,6" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="0.8*"
                                        Binding="{Binding PaymentDate, StringFormat=MM/dd/yyyy}"
                                        Header="Payment Date" />

                                    <DataGridTextColumn
                                        Width="0.8*"
                                        Binding="{Binding PaymentMethod}"
                                        Header="Method" />

                                    <DataGridTextColumn
                                        Width="1.3*"
                                        Binding="{Binding Notes}"
                                        Header="Notes" />

                                    <DataGridTextColumn
                                        Width="0.8*"
                                        Binding="{Binding AmountPaid, StringFormat=₱ {0:N2}}"
                                        Header="Amount" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock
                                Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="#777777"
                                Text="No payment records found."
                                Visibility="{Binding SelectedReceiptDetail.PaymentHistory.Count, Converter={StaticResource CountToVisibilityConverter}}" />
                                                                
                            <!--  Billing Summary  -->
                            <Grid Margin="0,30,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="300" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="Billing Summary" />

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Gross Amount" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedReceiptDetail.TotalAmountDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10" Visibility="{Binding SelectedReceiptDetail.HasVatExemption, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock FontWeight="SemiBold" Text="VAT Exempt Sales" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedReceiptDetail.VatExemptSalesDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Discount Type" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedReceiptDetail.DiscountType}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Discount Amount" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedReceiptDetail.DiscountAmountDisplay}" />
                                    </Grid>

                                    <Border
                                        Height="1"
                                        Margin="0,4,0,12"
                                        Background="#DDDDDD" />

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="Bold" Text="Billable Amount" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.SubtotalAfterDiscountDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Amount Paid" />
                                        <TextBlock HorizontalAlignment="Right" Text="{Binding SelectedReceiptDetail.AmountPaidDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="Bold" Text="Remaining Balance" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.RemainingBalanceDisplay}" />
                                    </Grid>

                                    <Grid>
                                        <TextBlock FontWeight="Bold" Text="Payment Status" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.PaymentStatus}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!--  Notes  -->
                            <StackPanel Margin="0,26,0,0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Notes" />

                                <Border
                                    Margin="0,8,0,0"
                                    Padding="12"
                                    Background="#F8F8F8"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1">

                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#555555"
                                        Text="{Binding SelectedReceiptDetail.Notes}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!--  Footer  -->
                    <StackPanel
                        Grid.Row="2"
                        Margin="30,0,30,24"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Command="{Binding SaveReceiptPdfCommand}"
                            CommandParameter="{Binding SelectedReceiptDetail}"
                            Content="Save PDF"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Command="{Binding PrintReceiptPdfCommand}"
                            CommandParameter="{Binding SelectedReceiptDetail}"
                            Content="Print"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="110"
                            Height="42"
                            Background="White"
                            BorderBrush="#111111"
                            BorderThickness="1"
                            Command="{Binding CloseReceiptOverlayCommand}"
                            Content="Close"
                            FontWeight="Bold"
                            Foreground="Black"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <!--  Receipt PDF Print Preview Overlay  -->
        <Grid Background="#66000000" Visibility="{Binding IsReceiptPrintPreviewOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="980"
                Height="720"
                Padding="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#223357"
                        Text="Invoice Print Preview" />

                    <wv2:WebView2 x:Name="ReceiptPrintWebView" Grid.Row="2" />

                    <StackPanel
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="120"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Click="OpenReceiptPrintDialog_Click"
                            Content="Print"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="120"
                            Height="42"
                            Background="White"
                            BorderBrush="#111111"
                            BorderThickness="1"
                            Command="{Binding CloseReceiptPrintPreviewCommand}"
                            Content="Close"
                            FontWeight="Bold"
                            Foreground="Black"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!--  Center Prompt Overlay  -->
        <Grid Background="#66000000" Visibility="{Binding IsPromptOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="420"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#223357"
                        Text="{Binding PromptTitle}" />

                    <TextBlock
                        Margin="0,14,0,24"
                        FontSize="15"
                        Foreground="#333333"
                        Text="{Binding PromptMessage}"
                        TextWrapping="Wrap" />

                    <Button
                        Width="120"
                        Height="42"
                        HorizontalAlignment="Right"
                        Background="#223357"
                        Command="{Binding ClosePromptCommand}"
                        Content="OK"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
