<UserControl
    x:Class="CruzNeryClinic.Views.BillingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="clr-namespace:CruzNeryClinic.Converters"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Billing/BillingManagementStyles.xaml" />
                <ResourceDictionary Source="PatientManagement/PatientManagementStyles.xaml" />
                <ResourceDictionary Source="AppointmentManagement/AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:PesoCurrencyConverter x:Key="PesoCurrencyConverter" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <Grid Margin="24,28,24,18">

            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="104" />

                <!-- Recent Billing + Payment History section -->
                <RowDefinition Height="360" MinHeight="220" />

                <!-- Draggable splitter row -->
                <RowDefinition Height="8" />

                <!-- Appointment Payment section -->
                <RowDefinition Height="*" MinHeight="280" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Billing Management" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="Process appointment payments, balance payments, and manual transactions" />
            </StackPanel>

            <!--  Submodule tabs  -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Command="{Binding SelectBillingModuleCommand}"
                    CommandParameter="Appointment Payment">
                    <Button.Style>
                        <Style BasedOn="{StaticResource BillingTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAppointmentPaymentSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="CalendarCheck" />

                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="Appointment Payment" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="2"
                    Command="{Binding SelectBillingModuleCommand}"
                    CommandParameter="Balance Payment">

                    <Button.Style>
                        <Style BasedOn="{StaticResource BillingTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBalancePaymentSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="PesoSign" />

                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="Balance Payment" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="4"
                    Command="{Binding SelectBillingModuleCommand}"
                    CommandParameter="Manual Transaction">

                    <Button.Style>
                        <Style BasedOn="{StaticResource BillingTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsManualTransactionSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="24"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="CashRegister" />

                        <TextBlock
                            Margin="0,6,0,0"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="Bold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Text="Manual Transaction" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Recent billing transactions + patient payment history -->
            <Border
                Grid.Row="2"
                Padding="20"
                Style="{StaticResource BillingPanelStyle}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.7*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- Recent Billing Transactions -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="Recent Billing Transactions" />

                        <DataGrid
                            Grid.Row="1"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding BillingRecords}"
                            MinRowHeight="38"
                            RowHeight="40"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Width="1*" MinWidth="120" Binding="{Binding ReceiptNumber}" Header="Receipt No." />
                                <DataGridTextColumn Width="1*" MinWidth="105" Binding="{Binding PatientCode}" Header="Patient ID" />
                                <DataGridTextColumn Width="1.3*" MinWidth="150" Binding="{Binding PatientName}" Header="Patient Name" />
                                <DataGridTextColumn Width="1*" MinWidth="105" Binding="{Binding TransactionDateDisplay}" Header="Date" />
                                <DataGridTextColumn Width="1.2*" MinWidth="135" Binding="{Binding ServiceName}" Header="Service" />
                                <DataGridTextColumn Width="1*" MinWidth="115" Binding="{Binding TotalAmountDisplay}" Header="Total" />
                                <DataGridTextColumn Width="1*" MinWidth="115" Binding="{Binding BalanceDisplay}" Header="Balance" />
                                <DataGridTextColumn Width="0.9*" MinWidth="95" Binding="{Binding PaymentStatus}" Header="Status" />

                                <DataGridTemplateColumn Width="1.4*" MinWidth="170" Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <Button
                                                    Width="70"
                                                    Height="28"
                                                    Margin="0,0,6,0"
                                                    Background="#223357"
                                                    Command="{Binding DataContext.PrintReceiptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="White"
                                                    Style="{StaticResource SmallActionButtonStyle}">

                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconBlock
                                                            Margin="0,0,5,0"
                                                            FontSize="11"
                                                            Foreground="White"
                                                            Icon="Print" />

                                                        <TextBlock
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="Print" />
                                                    </StackPanel>
                                                </Button>

                                                <Button
                                                    Width="65"
                                                    Height="28"
                                                    Command="{Binding DataContext.ViewReceiptCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Content="View"
                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Payment History for Patient -->
                    <Border
                        Grid.Column="2"
                        Padding="16"
                        BorderBrush="#D8D8D8"
                        BorderThickness="1"
                        CornerRadius="12"
                        Background="White">

                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">

                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="#111111"
                                    Text="Payment History for Patient" />

                                <TextBlock
                                    Margin="0,16,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Patient ID or Name" />

                                <!-- Patient lookup -->
                                <Grid
                                    Width="230"
                                    Height="42"
                                    HorizontalAlignment="Left">

                                    <TextBox
                                        x:Name="PaymentHistoryPatientSearchBox"
                                        Height="42"
                                        Style="{StaticResource ModernTextBoxStyle}"
                                        Tag="Enter Patient ID or Name"
                                        Text="{Binding PaymentHistorySearchText, UpdateSourceTrigger=PropertyChanged}" />

                                    <Popup
                                        AllowsTransparency="True"
                                        IsOpen="{Binding IsPaymentHistorySearchPopupOpen, Mode=TwoWay}"
                                        Placement="Bottom"
                                        PlacementTarget="{Binding ElementName=PaymentHistoryPatientSearchBox}"
                                        StaysOpen="True"
                                        Width="{Binding ActualWidth, ElementName=PaymentHistoryPatientSearchBox}">

                                        <Border
                                            MaxHeight="220"
                                            Background="White"
                                            BorderBrush="#D8D8D8"
                                            BorderThickness="1"
                                            CornerRadius="8">

                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="16"
                                                    ShadowDepth="3"
                                                    Opacity="0.18" />
                                            </Border.Effect>

                                            <ListBox
                                                BorderThickness="0"
                                                ItemsSource="{Binding PaymentHistoryPatientResults}"
                                                SelectedItem="{Binding SelectedPaymentHistoryPatient, Mode=TwoWay}"
                                                ScrollViewer.VerticalScrollBarVisibility="Auto">

                                                <ListBox.Resources>
                                                    <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                                </ListBox.Resources>

                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12,10" Background="Transparent">
                                                            <StackPanel>
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    FontWeight="Bold"
                                                                    Foreground="#111111">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="{}{0} - {1}">
                                                                            <Binding Path="PatientCode" />
                                                                            <Binding Path="PatientName" />
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>

                                                                <TextBlock
                                                                    Margin="0,3,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#777777"
                                                                    Text="{Binding Category}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <TextBlock
                                    Margin="0,12,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Patient Name" />

                                <TextBox
                                    Width="230"
                                    Height="42"
                                    HorizontalAlignment="Left"
                                    IsReadOnly="True"
                                    Style="{StaticResource ModernTextBoxStyle}"
                                    Tag="Auto-Filled"
                                    Text="{Binding PaymentHistoryPatientName, Mode=OneWay}" />

                                <!-- Transaction History title only appears after patient selection -->
                                <TextBlock
                                    Margin="0,18,0,8"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Transaction History"
                                    Visibility="{Binding HasSelectedPaymentHistoryPatient, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!-- Transaction History list only appears after patient selection -->
                                <Border
                                    Padding="12"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding HasSelectedPaymentHistoryPatient, Converter={StaticResource BoolToVisibilityConverter}}">

                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding LatestPatientBillingRecords}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Margin="0,0,0,10"
                                                        Padding="12"
                                                        Background="#EFEFF3"
                                                        CornerRadius="6">

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <!-- Receipt Details -->
                                                                <ColumnDefinition Width="*" />
                                                                <!-- Status Column-->
                                                                <ColumnDefinition Width="74" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel 
                                                                Grid.Column="0"
                                                                Margin="0,0,8,0">
                                                                <TextBlock
                                                                    FontSize="13"
                                                                    FontWeight="SemiBold"
                                                                    Text="{Binding ReceiptNumber}"
                                                                    TextWrapping="Wrap"
                                                                    MaxWidth="125" />

                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#666666"
                                                                    Text="{Binding TransactionDateDisplay}" />

                                                                <TextBlock
                                                                    Margin="0,4,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#333333"
                                                                    Text="{Binding ServiceName}" />
                                                            </StackPanel>

                                                            <StackPanel 
                                                                Grid.Column="1"
                                                                HorizontalAlignment="Right">
                                                                <Border
                                                                    Width="54"
                                                                    Margin="0,0,0,20"
                                                                    Padding="8,3"
                                                                    CornerRadius="5">

                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="#D9F8DF" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                                    <Setter Property="Background" Value="#FFEBC0" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                                    <Setter Property="Background" Value="#FFD6D6" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>

                                                                    <TextBlock
                                                                        FontSize="10"
                                                                        HorizontalAlignment="Center"
                                                                        TextAlignment="Center"
                                                                        FontWeight="SemiBold"
                                                                        Text="{Binding PaymentStatus}">

                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#00A423" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                                        <Setter Property="Foreground" Value="#D49A00" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Border>

                                                                <Button
                                                                    Width="48"
                                                                    Height="24"
                                                                    Command="{Binding DataContext.ExpandReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Expand"
                                                                    FontSize="10"
                                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="12"
                                            Foreground="#777777"
                                            Text="No transactions found."
                                            Visibility="{Binding SelectedPatientBillingRecords.Count, Converter={StaticResource CountToVisibilityConverter}}" />

                                        <Button
                                            Width="90"
                                            Height="34"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Right"
                                            Command="{Binding OpenTransactionHistoryOverlayCommand}"
                                            Content="View all"
                                            Style="{StaticResource OutlineActionButtonStyle}"
                                            Visibility="{Binding HasMoreThanThreePatientBillingRecords, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>                
                </Grid>
            </Border>

            <!-- Draggable vertical resize splitter -->
            <GridSplitter
                Grid.Row="3"
                Height="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Background="Transparent"
                ResizeDirection="Rows"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True"
                Cursor="SizeNS">

                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border
                                Width="80"
                                Height="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#223357"
                                CornerRadius="4" />
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>


            <!-- Bottom transaction content -->
            <Border
                Grid.Row="4"
                Margin="0,16,0,0"
                Padding="28"
                Style="{StaticResource BillingPanelStyle}">

                <ScrollViewer
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">

                    <ScrollViewer.Resources>
                        <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                    </ScrollViewer.Resources>

                    <Grid Margin="0,0,14,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAppointmentPaymentSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="22" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>

                        <!-- Title and completed appointment lookup -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="9">
                            <TextBlock
                                FontSize="24"
                                FontWeight="Bold"
                                Foreground="#111111"
                                Text="Appointment Payment" />

                            <TextBlock
                                Margin="0,6,0,0"
                                FontSize="15"
                                Foreground="#777777"
                                Text="Process payments connected to completed appointments." />

                            <!-- Completed appointment lookup -->
                            <Grid
                                Width="390"
                                Height="52"
                                Margin="0,22,0,0"
                                HorizontalAlignment="Left">

                                <TextBox
                                    x:Name="AppointmentPaymentSearchBox"
                                    Height="52"
                                    Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{Binding AppointmentPaymentSearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <fa:IconBlock
                                    Margin="18,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    Foreground="#666666"
                                    Icon="Search" />

                                <TextBlock
                                    Margin="52,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="17"
                                    Foreground="#8A8A8A"
                                    IsHitTestVisible="False"
                                    Text="Search completed appointment">

                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AppointmentPaymentSearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>

                                                <DataTrigger Binding="{Binding AppointmentPaymentSearchText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Popup
                                    AllowsTransparency="True"
                                    IsOpen="{Binding IsAppointmentPaymentSearchPopupOpen, Mode=TwoWay}"
                                    Placement="Bottom"
                                    PlacementTarget="{Binding ElementName=AppointmentPaymentSearchBox}"
                                    StaysOpen="True"
                                    Width="{Binding ActualWidth, ElementName=AppointmentPaymentSearchBox}">

                                    <Border
                                        MaxHeight="250"
                                        Background="White"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="8">

                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="16"
                                                ShadowDepth="3"
                                                Opacity="0.18" />
                                        </Border.Effect>

                                        <ListBox
                                            BorderThickness="0"
                                            ItemsSource="{Binding FilteredAppointmentPaymentItems}"
                                            SelectedItem="{Binding SelectedAppointmentPaymentItem, Mode=TwoWay}"
                                            ScrollViewer.VerticalScrollBarVisibility="Auto">

                                            <ListBox.Resources>
                                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />

                                                <Style TargetType="{x:Type ListBoxItem}">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                                <Border
                                                                    x:Name="ItemBorder"
                                                                    Background="Transparent">
                                                                    <ContentPresenter
                                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                        VerticalAlignment="Center" />
                                                                </Border>

                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5FF" />
                                                                    </Trigger>

                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#DDF0FF" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.Resources>

                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,10">
                                                        <StackPanel>
                                                            <TextBlock
                                                                FontSize="14"
                                                                FontWeight="Bold"
                                                                Foreground="#111111">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0} - {1}">
                                                                        <Binding Path="PatientCode" />
                                                                        <Binding Path="PatientName" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>

                                                            <TextBlock
                                                                Margin="0,3,0,0"
                                                                FontSize="12"
                                                                Foreground="#777777">
                                                                <TextBlock.Text>
                                                                    <MultiBinding StringFormat="{}{0} • {1}">
                                                                        <Binding Path="ServiceName" />
                                                                        <Binding Path="TreatmentDateDisplay" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>
                        </StackPanel>

                        <!-- Row 2 -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Patient ID" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentPatientCode, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Category" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentCategory, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="4">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Total Amount *" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Text="{Binding AppointmentTotalAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="6">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Payment Amount *" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Text="{Binding AppointmentPaymentAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>

                        <!-- Summary box -->
                        <Border
                            Grid.Row="2"
                            Grid.RowSpan="3"
                            Grid.Column="8"
                            Padding="22"
                            Background="#EAF5FF"
                            BorderBrush="#B9DAFF"
                            BorderThickness="1"
                            CornerRadius="12">

                            <StackPanel>
                                <Grid>
                                    <TextBlock Foreground="#223357" Text="Total Amount:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="#223357"
                                        Text="{Binding AppointmentTotalAmount, StringFormat=₱ {0:N2}}" />
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <TextBlock Foreground="#223357" Text="{Binding AppointmentDiscountLabel}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="#00A423"
                                        Text="{Binding AppointmentDiscountAmount, StringFormat=₱ {0:N2}}" />
                                </Grid>

                                <Grid Margin="0,14,0,0">
                                    <TextBlock Foreground="#223357" Text="Payment:" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="#223357"
                                        Text="{Binding AppointmentPaymentAmount, StringFormat=₱ {0:N2}}" />
                                </Grid>

                                <Border
                                    Height="1"
                                    Margin="0,18,0,14"
                                    Background="#223357" />

                                <Grid>
                                    <TextBlock
                                        FontWeight="Bold"
                                        Foreground="#223357"
                                        Text="Balance:" />

                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontWeight="Bold"
                                        Foreground="#00A423"
                                        Text="{Binding AppointmentBalanceDisplay}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Row 4 -->
                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Patient Name" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentPatientName, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Discount Amount" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentDiscountAmount, Converter={StaticResource PesoCurrencyConverter}, UpdateSourceTrigger=LostFocus}" />
                        </StackPanel>

                        <Border
                            Grid.Row="4"
                            Grid.Column="4"
                            Grid.ColumnSpan="3"
                            Height="52"
                            Margin="0,31,0,0"
                            Padding="20,0"
                            Background="#EEEEEE"
                            CornerRadius="8">

                            <Grid>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Foreground="#888888"
                                    Text="Billable Amount:" />

                                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontSize="15"
                                    Foreground="#888888"
                                    Text="{Binding AppointmentSubtotalDisplay}" />
                            </Grid>
                        </Border>

                        <!-- Row 6 -->
                        <StackPanel Grid.Row="6" Grid.Column="0">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Service / Treatment" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentServiceName, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="2">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Date" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="{Binding AppointmentDate, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="4" Grid.ColumnSpan="3">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Receipt Number" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Text="{Binding AppointmentReceiptNumber, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Notes and action buttons -->
                        <StackPanel
                            Grid.Row="6"
                            Grid.RowSpan="3"
                            Grid.Column="8">

                            <TextBlock
                                FontSize="16"
                                FontWeight="Bold"
                                Text="Notes" />

                            <TextBox
                                Height="120"
                                Margin="0,8,0,0"
                                AcceptsReturn="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Text="{Binding AppointmentNotes, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />

                            <StackPanel
                                Margin="0,14,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">

                                <Button
                                    Width="190"
                                    Height="46"
                                    Margin="0,0,14,0"
                                    Background="#223357"
                                    Command="{Binding ProcessAppointmentPaymentCommand}"
                                    Foreground="White"
                                    Style="{StaticResource SecondaryButtonStyle}">

                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="Bold"
                                        Text="₱ Process Transaction" />
                                </Button>

                                <Button
                                    Width="84"
                                    Height="46"
                                    Background="White"
                                    BorderBrush="#111111"
                                    BorderThickness="1"
                                    Command="{Binding ClearAppointmentPaymentFormCommand}"
                                    Content="Clear"
                                    FontSize="14"
                                    Foreground="Black"
                                    Style="{StaticResource OutlineActionButtonStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Row 8 -->
                        <StackPanel Grid.Row="8" Grid.Column="0">
                            <TextBlock FontSize="16" FontWeight="Bold" Text="Appointment Type" />
                            <TextBox
                                Height="52"
                                Margin="0,8,0,0"
                                IsReadOnly="True"
                                Style="{StaticResource ModernTextBoxStyle}"
                                Tag="Auto-Filled"
                                Text="Completed Appointment" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- Full Transaction History Overlay -->
        <Grid
            Background="#66000000"
            Visibility="{Binding IsTransactionHistoryOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="720"
                MaxHeight="620"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        ShadowDepth="4"
                        Opacity="0.25" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Transaction History" />

                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="14"
                            Foreground="#777777"
                            Text="{Binding PaymentHistoryPatientName}" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <ItemsControl ItemsSource="{Binding SelectedPatientBillingRecords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="16"
                                        Background="#EFEFF3"
                                        CornerRadius="8">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock
                                                    FontSize="15"
                                                    FontWeight="Bold"
                                                    Text="{Binding ReceiptNumber}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#666666"
                                                    Text="{Binding TransactionDateDisplay}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#333333"
                                                    Text="{Binding ServiceName}" />

                                                <TextBlock
                                                    Margin="0,5,0,0"
                                                    FontSize="12"
                                                    Foreground="#333333"
                                                    Text="{Binding TotalAmountDisplay}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Border
                                                    Width="54"
                                                    Margin="0,0,0,12"
                                                    Padding="10,4"
                                                    CornerRadius="5">

                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#D9F8DF" />

                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                    <Setter Property="Background" Value="#FFEBC0" />
                                                                </DataTrigger>

                                                                <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                    <Setter Property="Background" Value="#FFD6D6" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>

                                                    <TextBlock
                                                        FontSize="11"
                                                        HorizontalAlignment="Center"
                                                        TextAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding PaymentStatus}">

                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#00A423" />

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                                        <Setter Property="Foreground" Value="#D49A00" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding PaymentStatus}" Value="Unpaid">
                                                                        <Setter Property="Foreground" Value="#C62828" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Button
                                                    Width="78"
                                                    Height="30"
                                                    Command="{Binding DataContext.ExpandReceiptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Content="Expand"
                                                    Style="{StaticResource OutlineActionButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button
                        Grid.Row="4"
                        Width="110"
                        Height="40"
                        HorizontalAlignment="Right"
                        Background="#223357"
                        Command="{Binding CloseTransactionHistoryOverlayCommand}"
                        Content="Close"
                        Foreground="White"
                        FontWeight="Bold"
                        Style="{StaticResource SmallActionButtonStyle}" />
                </Grid>
            </Border>
        </Grid>

        <!-- Receipt Detail Overlay -->
        <Grid
            Background="#66000000"
            Visibility="{Binding IsReceiptOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="820"
                MaxHeight="700"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        ShadowDepth="4"
                        Opacity="0.25" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="84" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border
                        Grid.Row="0"
                        Background="#223357"
                        CornerRadius="18,18,0,0">

                        <Grid Margin="30,0">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Dental Receipt" />

                            <StackPanel
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    Text="Receipt Number" />

                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="{Binding SelectedReceiptDetail.ReceiptNumber}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <ScrollViewer
                        Grid.Row="1"
                        Padding="30"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">

                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <StackPanel>

                            <!-- Info blocks -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Patient Information -->
                                <StackPanel Grid.Column="0">
                                    <Border
                                        Padding="12"
                                        Background="#F3F7FA">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Text="Patient Information" />
                                    </Border>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock
                                            FontSize="14"
                                            Text="{Binding SelectedReceiptDetail.PatientName}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PatientCode}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PatientCategory, StringFormat=Category: {0}}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Transaction Information -->
                                <StackPanel Grid.Column="2">
                                    <Border
                                        Padding="12"
                                        Background="#F3F7FA">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="Bold"
                                            Text="Transaction Information" />
                                    </Border>

                                    <StackPanel Margin="0,14,0,0">
                                        <TextBlock
                                            FontSize="14"
                                            Text="{Binding SelectedReceiptDetail.TransactionDateDisplay}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PaymentMethod, StringFormat=Payment Method: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.PaymentStatus, StringFormat=Payment Status: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.BillingSource, StringFormat=Billing Source: {0}}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="13"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.LatestPaymentDateDisplay, StringFormat=Latest Payment: {0}}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border
                                Height="1"
                                Margin="0,28,0,20"
                                Background="#DDDDDD" />

                            <!-- Service / Treatment -->
                            <TextBlock
                                FontSize="19"
                                FontWeight="Bold"
                                Text="Service / Treatment" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Padding="14"
                                    Background="#F8F8F8"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1">

                                    <StackPanel>
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="{Binding SelectedReceiptDetail.ServiceName}" />

                                        <TextBlock
                                            Margin="0,6,0,0"
                                            FontSize="12"
                                            Foreground="#555555"
                                            Text="{Binding SelectedReceiptDetail.Description}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="14"
                                    Background="#F8F8F8"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1">

                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="{Binding SelectedReceiptDetail.TotalAmountDisplay}" />
                                </Border>
                            </Grid>

                            <!-- Billing Summary -->
                            <Grid Margin="0,30,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="300" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="1">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="Billing Summary" />

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Gross Amount" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            Text="{Binding SelectedReceiptDetail.TotalAmountDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Discount Type" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            Text="{Binding SelectedReceiptDetail.DiscountType}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Discount Amount" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            Text="{Binding SelectedReceiptDetail.DiscountAmountDisplay}" />
                                    </Grid>

                                    <Border
                                        Height="1"
                                        Margin="0,4,0,12"
                                        Background="#DDDDDD" />

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="Bold" Text="Billable Amount" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.SubtotalAfterDiscountDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="SemiBold" Text="Amount Paid" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            Text="{Binding SelectedReceiptDetail.AmountPaidDisplay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock FontWeight="Bold" Text="Remaining Balance" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.RemainingBalanceDisplay}" />
                                    </Grid>

                                    <Grid>
                                        <TextBlock FontWeight="Bold" Text="Payment Status" />
                                        <TextBlock
                                            HorizontalAlignment="Right"
                                            FontWeight="Bold"
                                            Text="{Binding SelectedReceiptDetail.PaymentStatus}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!-- Notes -->
                            <StackPanel Margin="0,26,0,0">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="Notes" />

                                <Border
                                    Margin="0,8,0,0"
                                    Padding="12"
                                    Background="#F8F8F8"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1">

                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#555555"
                                        Text="{Binding SelectedReceiptDetail.Notes}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <StackPanel
                        Grid.Row="2"
                        Margin="30,0,30,24"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Command="{Binding SaveReceiptPdfCommand}"
                            CommandParameter="{Binding SelectedReceiptDetail}"
                            Content="Save PDF"
                            Foreground="White"
                            FontWeight="Bold"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Command="{Binding PrintReceiptPdfCommand}"
                            CommandParameter="{Binding SelectedReceiptDetail}"
                            Content="Print"
                            Foreground="White"
                            FontWeight="Bold"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="110"
                            Height="42"
                            Background="White"
                            BorderBrush="#111111"
                            BorderThickness="1"
                            Command="{Binding CloseReceiptOverlayCommand}"
                            Content="Close"
                            Foreground="Black"
                            FontWeight="Bold"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <!-- Receipt PDF Print Preview Overlay -->
        <Grid
            Background="#66000000"
            Visibility="{Binding IsReceiptPrintPreviewOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="980"
                Height="720"
                Padding="18"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        ShadowDepth="4"
                        Opacity="0.25" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#223357"
                        Text="Receipt Print Preview" />

                    <wv2:WebView2
                        x:Name="ReceiptPrintWebView"
                        Grid.Row="2"/>

                    <StackPanel
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="120"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Click="OpenReceiptPrintDialog_Click"
                            Content="Print"
                            Foreground="White"
                            FontWeight="Bold"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="120"
                            Height="42"
                            Background="White"
                            BorderBrush="#111111"
                            BorderThickness="1"
                            Command="{Binding CloseReceiptPrintPreviewCommand}"
                            Content="Close"
                            Foreground="Black"
                            FontWeight="Bold"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Center Prompt Overlay -->
        <Grid
            Background="#66000000"
            Visibility="{Binding IsPromptOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="420"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="18">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        ShadowDepth="4"
                        Opacity="0.25" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#223357"
                        Text="{Binding PromptTitle}" />

                    <TextBlock
                        Margin="0,14,0,24"
                        FontSize="15"
                        Foreground="#333333"
                        Text="{Binding PromptMessage}"
                        TextWrapping="Wrap" />

                    <Button
                        Width="120"
                        Height="42"
                        HorizontalAlignment="Right"
                        Background="#223357"
                        Command="{Binding ClosePromptCommand}"
                        Content="OK"
                        Foreground="White"
                        FontWeight="Bold"
