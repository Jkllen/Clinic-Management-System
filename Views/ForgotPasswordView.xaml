<UserControl x:Class="CruzNeryClinic.Views.ForgotPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Shared input design for the forgot password field. -->
        <Style x:Key="ForgotInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#9A9A9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,0,20,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                            Margin="{TemplateBinding Padding}"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#223357"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#223357"/>
                                <Setter TargetName="TextBoxBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- 
        Forgot Password screen.
        Uses a responsive Viewbox so the card scales down when the window becomes smaller.
    -->
    <Grid>

        <!-- Top-left white to bottom-right cyan gradient. -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#91EFEF" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Viewbox Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="30">

            <Grid Width="560" Height="780">

                <!-- Main card -->
                <Border CornerRadius="36"
                        Background="#EAFDFD"
                        BorderBrush="White"
                        BorderThickness="1"
                        Padding="44">

                    <Border.Effect>
                        <DropShadowEffect Color="#707070"
                                          BlurRadius="10"
                                          ShadowDepth="4"
                                          Opacity="0.28"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 0: Logo area -->
                            <RowDefinition Height="285"/>

                            <!-- 1: ForgotPass title -->
                            <RowDefinition Height="Auto"/>

                            <!-- 2: User ID title -->
                            <RowDefinition Height="Auto"/>

                            <!-- 3: User ID textbox -->
                            <RowDefinition Height="Auto"/>

                            <!-- 4: Error message -->
                            <RowDefinition Height="40"/>

                            <!-- 5: Button -->
                            <RowDefinition Height="85"/>
                            
                            <!-- Space -->
                            <RowDefinition Height="30"/>

                        </Grid.RowDefinitions>

                        <!-- Clinic logo -->
                        <Image Grid.Row="0"
                               Source="/Assets/Images/logo.png"
                               Width="280"
                               Height="280"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- Title -->
                        <TextBlock Grid.Row="1"
                                   Text="Forgot Password"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#111111"
                                   Margin="0,0,0,12"/>

                        <!-- User ID title -->
                        <TextBlock Grid.Row="2"
                                   Text="User ID"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111111"
                                   Margin="0,0,0,12"/>

                        <!-- User ID input -->
                        <Grid Grid.Row="3"
                              Height="58"
                              Margin="0,0,0,14">

                            <TextBox Style="{StaticResource ForgotInputStyle}"
                                     Text="{Binding UserCode, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter your user ID"/>

                            <!-- Placeholder -->
                            <TextBlock Text="Enter your user id"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="22"
                                       Foreground="#8A8A8A"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="62,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserCode}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UserCode}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- FontAwesome user icon -->
                            <fa:IconBlock Icon="User"
                                          Foreground="#08CFA5"
                                          FontSize="26"
                                          Width="32"
                                          Height="32"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="18,0,0,0"/>
                        </Grid>

                        <!-- Error message -->
                        <TextBlock Grid.Row="4"
                                   Text="{Binding ErrorMessage}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="#C62828"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Bottom buttons -->
                        <Grid Grid.Row="5"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,20">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Optional back button for easier navigation -->
                            <Button Grid.Column="0"
                                    Content="Back"
                                    Command="{Binding BackToLoginCommand}"
                                    Width="130"
                                    Height="52"
                                    HorizontalAlignment="Left"
                                    Background="#B6B6B6"
                                    Foreground="White"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,0,15,0"/>


                            <!-- Continue button -->
                            <Button Grid.Column="1"
                                    Content="Enter"
                                    Command="{Binding ContinueCommand}"
                                    Width="150"
                                    Height="52"
                                    Background="#223357"
                                    Foreground="White"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="26"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>