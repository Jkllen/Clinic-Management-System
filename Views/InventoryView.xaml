                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EBF5FF" BorderBrush="#B3D7FF" BorderThickness="1" CornerRadius="10" Padding="14,10">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1A5FA8" Text="{Binding UsageCurrentStockDisplay}" TextWrapping="Wrap" />
                                </Border>
                                <Border Grid.Column="2" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="10" Padding="14,10">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#92400E" Text="{Binding UsageRemainingStockDisplay}" TextWrapping="Wrap" />
                                </Border>
                            </Grid>

                            <!--  Notes (optional)  -->
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Notes (optional) :" />
                                <TextBox
                                    Height="100"
                                    FontSize="13"
                                    Style="{StaticResource ModernTextAreaStyle}"
                                    Tag="Add additional notes..."
                                    Text="{Binding UsageNotes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!--  Error + buttons  -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding UsageErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasUsageError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button Width="130" Height="44" Margin="0,0,16,0" Command="{Binding CloseUsageOverlayCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CancelBorder" Background="#E31D1D" CornerRadius="22">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="Cancel" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CancelBorder" Property="Opacity" Value="0.85" /></Trigger>
                                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="CancelBorder" Property="Opacity" Value="0.7" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Width="190" Height="44" Command="{Binding ConfirmUsageCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ConfirmBorder" Background="#22C84A" CornerRadius="22">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="Record Item Usage" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.85" /></Trigger>
                                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.7" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Confirmation Dialog Overlay                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="70" Visibility="{Binding IsConfirmDialogVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#88000000" />
            <Border
                Width="420"
                Height="Auto"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">
                <StackPanel Margin="28,24,28,24">

                    <!--  Title  -->
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="{Binding ConfirmTitle}" />

                    <!--  Subtitle  -->
                    <TextBlock
                        Margin="0,6,0,18"
                        FontSize="13"
                        Foreground="#555555"
                        Text="{Binding ConfirmSubtitle}"
                        TextWrapping="Wrap" />

                    <!--  Field rows  -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="{Binding ConfirmField1Label}" />
                        <TextBlock Grid.Column="1" FontSize="13" Foreground="#333333" Text="{Binding ConfirmField1Value}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="{Binding ConfirmField2Label}" />
                        <TextBlock Grid.Column="1" FontSize="13" Foreground="#333333" Text="{Binding ConfirmField2Value}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="{Binding ConfirmField3Label}" />
                        <TextBlock Grid.Column="1" FontSize="13" Foreground="#333333" Text="{Binding ConfirmField3Value}" />
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold" Text="{Binding ConfirmField4Label}" />
                        <TextBlock Grid.Column="1" FontSize="13" Foreground="#333333" Text="{Binding ConfirmField4Value}" />
                    </Grid>

                    <!--  Buttons  -->
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                        <!--  Go Back – outlined  -->
                        <Button
                            Width="120"
                            Height="40"
                            Margin="0,0,12,0"
                            Command="{Binding GoBackConfirmCommand}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="GoBackBorder"
                                        Background="White"
                                        BorderBrush="#BBBBBB"
                                        BorderThickness="1.5"
                                        CornerRadius="20">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="Go Back" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="GoBackBorder" Property="Background" Value="#F5F5F5" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="GoBackBorder" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!--  Confirm – dark blue  -->
                        <Button
                            Width="120"
                            Height="40"
                            Command="{Binding FinalConfirmCommand}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="ConfirmBtnBorder"
                                        Background="#073C98"
                                        CornerRadius="20">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="Confirm" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ConfirmBtnBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ConfirmBtnBorder" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Completion Dialog Overlay                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="80" Visibility="{Binding IsSuccessPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#AAFFFFFF" />
            <Border
                Width="330"
                Height="Auto"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="14">
                <StackPanel Margin="28,30,28,28" HorizontalAlignment="Center">

                    <!--  Green circle checkmark  -->
                    <Border
                        Width="70"
                        Height="70"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="#22C84A"
                        BorderThickness="3"
                        CornerRadius="35">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="34"
                            Foreground="#22C84A"
                            Icon="Check" />
                    </Border>

                    <!--  Completed!  -->
                    <TextBlock
                        Margin="0,18,0,6"
                        HorizontalAlignment="Center"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="Completed!" />

                    <!--  Sub-message  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="#555555"
                        Text="{Binding SuccessSubMessage}"
                        TextWrapping="Wrap" />

                    <!--  Buttons  -->
                    <StackPanel
                        Margin="0,24,0,0"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">

                        <!--  Exit – outlined  -->
                        <Button
                            Width="90"
                            Height="40"
                            Margin="0,0,12,0"
                            Command="{Binding CloseSuccessPromptCommand}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="ExitBorder"
                                        Background="White"
                                        BorderBrush="#BBBBBB"
                                        BorderThickness="1.5"
                                        CornerRadius="20">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="Exit" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ExitBorder" Property="Background" Value="#F5F5F5" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ExitBorder" Property="Opacity" Value="0.75" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!--  Action – dark blue  -->
                        <Button
                            Width="150"
                            Height="40"
                            Command="{Binding SuccessActionCommand}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="ActionBorder"
                                        Background="#073C98"
                                        CornerRadius="20">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding SuccessActionLabel}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ActionBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ActionBorder" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
