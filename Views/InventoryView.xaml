<UserControl
    x:Class="CruzNeryClinic.Views.InventoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!--  Soft drop shadow shared by the top info cards and the table panel  -->
        <DropShadowEffect
            x:Key="CardDropShadow"
            BlurRadius="16"
            Direction="270"
            Opacity="0.16"
            ShadowDepth="3"
            Color="#444444" />

        <!--  Summary card number styles  -->
        <Style x:Key="SummaryNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#50C878" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="LowStockNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#F0A500" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="OutOfStockNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="#E31D1D" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!--  Small rounded action button (text+icon)  -->
        <Style x:Key="SmallActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Small up/down spinner button used inside numeric form fields  -->
        <Style x:Key="SpinnerButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#EEF3FA" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="SpinnerBorder"
                            Margin="0,0.5"
                            Background="{TemplateBinding Background}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SpinnerBorder" Property="Background" Value="#D7E4F5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SpinnerBorder" Property="Background" Value="#C0D4EE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Icon-only square action button for DataGrid rows  -->
        <Style x:Key="IconSquareButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Overlay TextBox style (Add/Edit Item modal)  -->
        <Style
            x:Key="InventoryOverlayTextBoxStyle"
            BasedOn="{StaticResource ModernTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="7.5,0,16,0" />
        </Style>

        <!--  Overlay TextBox style with ₱ prefix (Unit Price field)  -->
        <Style x:Key="InventoryOverlayPriceTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#FFFDFD" />
            <Setter Property="BorderBrush" Value="#C8DCF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="34,0,16,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="TextBoxBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <Grid>
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                                <TextBlock
                                    Margin="14,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="#111111"
                                    IsHitTestVisible="False"
                                    Text="₱" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#223357" />
                                <Setter TargetName="TextBoxBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Overlay ComboBox style (Add/Edit Item modal)  -->
        <Style x:Key="InventoryOverlayComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#FFFDFD" />
            <Setter Property="BorderBrush" Value="#C8DCF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,0,46,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                x:Name="ToggleButton"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                HorizontalAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                ClickMode="Press"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border
                                    x:Name="ComboBorder"
                                    HorizontalAlignment="Stretch"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                    <Grid>
                                        <ContentPresenter
                                            x:Name="ContentSite"
                                            Margin="16,0,46,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                        <TextBlock
                                            x:Name="PlaceholderText"
                                            Margin="16,0,46,0"
                                            VerticalAlignment="Center"
                                            Foreground="#A0A0A0"
                                            IsHitTestVisible="False"
                                            Text="{TemplateBinding Tag}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <fa:IconBlock
                                            Margin="0,0,16,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="16"
                                            Foreground="Black"
                                            Icon="AngleDown" />
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup
                                x:Name="PART_Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="220"
                                    Background="White"
                                    BorderBrush="#DADADA"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <ScrollViewer Margin="2">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#223357" />
                                <Setter TargetName="ComboBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  DatePickerTextBox sub-style – clears default watermark chrome  -->
        <Style x:Key="InventoryDatePickerTextBoxStyle" TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ContentControl
                                x:Name="PART_Watermark"
                                Focusable="False"
                                Foreground="#A0A0A0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="Hidden" />
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Background="Transparent"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden"
                                VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  DatePicker style matching InventoryOverlayTextBoxStyle  -->
        <Style x:Key="InventoryOverlayDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="46" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#FFFDFD" />
            <Setter Property="BorderBrush" Value="#C8DCF0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border
                            x:Name="DatePickerBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox
                                    x:Name="PART_TextBox"
                                    Grid.Column="0"
                                    Margin="12,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Focusable="True"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Style="{StaticResource InventoryDatePickerTextBoxStyle}"
                                    VerticalAlignment="Center" />
                                <Button
                                    x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="38"
                                    Margin="0,0,6,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False"
                                    VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="8" Padding="4">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#F0F0F0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <fa:IconBlock FontSize="16" Foreground="#777777" Icon="CalendarAlt" />
                                </Button>
                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Placement="Bottom"
                                    StaysOpen="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="#223357" />
                                <Setter TargetName="DatePickerBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <!--  Main content  -->
        <Grid Margin="24,28,24,18">

            <Grid.RowDefinitions>
                <!--  Row 0: Page header  -->
                <RowDefinition Height="80" />
                <!--  Row 1: Overview card + Recent Usage card + Recent Restock card  -->
                <RowDefinition Height="300" />
                <!--  Row 2: Search / Filter / Sort / Add New Item toolbar  -->
                <RowDefinition Height="88" />
                <!--  Row 3: DataGrid table + Help button  -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Row 0 – Page Header -->
            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Inventory" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="Management and Monitoring of Dental Supplies" />
            </StackPanel>

            <!--  Row 1 – Three top info cards -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ─── Inventory Overview card ─────────── -->
                <Border
                    Grid.Column="0"
                    Padding="20,16"
                    Effect="{StaticResource CardDropShadow}"
                    Style="{StaticResource DashboardCardStyle}">
                    <StackPanel>
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Inventory Overview" />

                        <!--  Total Items  -->
                        <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                            <Border
                                Width="55"
                                Height="55"
                                Background="#F5DEF5"
                                BorderBrush="#C462C4"
                                BorderThickness="2"
                                CornerRadius="10">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="#525151"
                                    Icon = "BoxOpen" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="18" Text="Total Items" />
                                <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding TotalItems}" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Low Stock  -->
                        <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                            <Border
                                Width="55"
                                Height="55"
                                Background="#FEF3C7"
                                BorderBrush="#EAB308"
                                BorderThickness="2"
                                CornerRadius="10">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="#525151"
                                    Icon="ExclamationTriangle" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="18" Text="Low Stock" />
                                <TextBlock Style="{StaticResource LowStockNumberStyle}" Text="{Binding LowStockCount}" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Out of Stock  -->
                        <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
                            <Border
                                Width="55"
                                Height="55"
                                Background="#FF0000"
                                BorderBrush="#CC0000"
                                BorderThickness="2"
                                CornerRadius="10">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="White"
                                    Icon="Ban" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="18" Text="Out of Stock" />
                                <TextBlock Style="{StaticResource OutOfStockNumberStyle}" Text="{Binding OutOfStockCount}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Recent Item Usage card ──────────── -->
                <Border
                    Grid.Column="2"
                    Padding="16,16"
                    Effect="{StaticResource CardDropShadow}"
                    Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Card header  -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="55" Height="55" Background="#3B8CBB" CornerRadius="10">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="White"
                                    Icon="ClipboardList" />
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" MaxWidth="300">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recent Item Usage" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#7A7A7A"
                                    Text="Number of dental supply items that have been recently used during patient treatments."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Column headers  -->
                        <Grid Grid.Row="1" Margin="0,14,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="Bold" Text="Item Id"        HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Text="Item Name"      HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" FontSize="12" FontWeight="Bold" Text="Quantity Used"  HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" FontWeight="Bold" Text="Date"           HorizontalAlignment="Center" />
                        </Grid>

                        <!--  Recent usage list  -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentItemUsages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="12" Text="{Binding ItemId}"       HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" FontSize="12" Text="{Binding ItemName}"     HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" FontSize="12" Text="{Binding QuantityUsed}" HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" FontSize="12" Text="{Binding Date, StringFormat=MM/dd/yyyy}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  View all / Log Item Usage  -->
                        <StackPanel
                            Grid.Row="3"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

                            <Button
                                Height="36"
                                Padding="16,0"
                                Background="Transparent"
                                BorderBrush="#223357"
                                BorderThickness="1.5"
                                Command="{Binding ViewAllUsagesCommand}"
                                Cursor="Hand"
                                Style="{StaticResource SmallActionButtonStyle}">
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#223357"
                                    Text="View all" />
                            </Button>

                            <Button
                                Height="36"
                                Margin="10,0,0,0"
                                Padding="14,0"
                                Background="#073C98"
                                Command="{Binding LogItemUsageCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Foreground="White"
                                        Icon="ClipboardList" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="Log Item Usage" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ─── Recent Restock Item card ────────── -->
                <Border
                    Grid.Column="4"
                    Padding="20,16"
                    Effect="{StaticResource CardDropShadow}"
                    Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Card header  -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <Border Width="55" Height="55" Background="#3B8CBB" CornerRadius="10">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="30"
                                    Foreground="White"
                                    Icon="PlusSquare" />
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center" MaxWidth="300">
                                <TextBlock FontSize="20" FontWeight="SemiBold" Text="Recent Restock Item" />
                                <TextBlock
                                    FontSize="11"
                                    Foreground="#7A7A7A"
                                    Text="Dental supply items that have been recently restocked and added back into the inventory."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <!--  Column headers  -->
                        <Grid Grid.Row="1" Margin="0,14,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontSize="12" FontWeight="Bold" Text="Item Id"     HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="1" FontSize="12" FontWeight="Bold" Text="Item Name"   HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" FontSize="12" FontWeight="Bold" Text="Unit Price"  HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" FontSize="12" FontWeight="Bold" Text="Stock Added" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" FontSize="12" FontWeight="Bold" Text="Date"        HorizontalAlignment="Center" />
                        </Grid>

                        <!--  Recent restock list  -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentRestockItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="12" Text="{Binding ItemId}"                                    HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="1" FontSize="12" Text="{Binding ItemName}"                                  HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="2" FontSize="12" Text="{Binding UnitPrice, StringFormat=&#x20B1;{0:N2}}"   HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="3" FontSize="12" Text="{Binding StockAdded}"                               HorizontalAlignment="Center" />
                                        <TextBlock Grid.Column="4" FontSize="12" Text="{Binding Date, StringFormat=MM/dd/yyyy}"            HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  View all / Restock Item  -->
                        <StackPanel
                            Grid.Row="3"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

                            <Button
                                Height="36"
                                Padding="16,0"
                                Background="Transparent"
                                BorderBrush="#223357"
                                BorderThickness="1.5"
                                Command="{Binding ViewAllRestocksCommand}"
                                Cursor="Hand"
                                Style="{StaticResource SmallActionButtonStyle}">
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="#223357"
                                    Text="View all" />
                            </Button>

                            <Button
                                Height="36"
                                Margin="10,0,0,0"
                                Padding="14,0"
                                Background="#073C98"
                                Command="{Binding RestockItemCommand}"
                                Style="{StaticResource SmallActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconBlock
                                        Margin="0,0,7,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Foreground="White"
                                        Icon="PlusSquare" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Text="Restock Item" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!--  Row 2 – Toolbar: Search / Filter / Sort / Add New Item  -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!--  Search Item  -->
                <Grid x:Name="SearchBox" Grid.Column="0" Height="52" VerticalAlignment="Center">
                    <TextBox
                        x:Name="SearchTextBox"
                        Style="{StaticResource SearchTextBoxStyle}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock
                        Margin="51,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="#8A8A8A"
                        IsHitTestVisible="False"
                        Text="Search Item">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <fa:IconBlock
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="Black"
                        Icon="Search" />
                </Grid>

                <!--  Filter dropdown  -->
                <ComboBox
                    Grid.Column="2"
                    Height="42"
                    Width="Auto"
                    FontSize="16"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                    Style="{StaticResource ExactStyleComboBox}"
                    Tag="Filter" />

                <!--  Sort By dropdown  -->
                <ComboBox
                    Grid.Column="4"
                    Height="42"
                    FontSize="16"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                    Style="{StaticResource ExactStyleComboBox}"
                    Tag="Sort By" />

                <!--  Add New Item button  -->
                <Button
                    Grid.Column="6"
                    Height="45"
                    VerticalAlignment="Center"
                    Background="#073C98"
                    Command="{Binding AddNewItemCommand}"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="White"
                            Icon="PlusCircle" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Add New Item" />
                    </StackPanel>
                </Button>
            </Grid>

            <!--  Row 3 – Inventory DataGrid  -->
            <Grid Grid.Row="3" Margin="0,0,0,18">

                <!--  Main table container  -->
                <Border
                    Padding="20"
                    Effect="{StaticResource CardDropShadow}"
                    Style="{StaticResource LargePanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Error message  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  Inventory Items DataGrid  -->
                        <DataGrid
                            Grid.Row="1"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding InventoryItems}"
                            MinRowHeight="42"
                            RowHeight="46"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItem="{Binding SelectedInventoryItem, Mode=TwoWay}"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Background" Value="#F0F0F0" />
                                            <Setter Property="Foreground" Value="#999999" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Binding="{Binding ItemId}"
                                    Header="Item Id"  />

                                <DataGridTextColumn
                                    Width="1.6*"
                                    MinWidth="160"
                                    Binding="{Binding ItemName}"
                                    Header="Item Name" />

                                <DataGridTextColumn
                                    Width="0.8*"
                                    MinWidth="90"
                                    Binding="{Binding Stock}"
                                    Header="Stock" />

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Binding="{Binding UnitPrice, StringFormat=&#x20B1;{0:N2}}"
                                    Header="Unit Price" />

                                <!--  Last Restock – pill badge  -->
                                <DataGridTemplateColumn
                                    Width="1.2*"
                                    MinWidth="140"
                                    Header="Last Restock">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="10,4"
                                                HorizontalAlignment="Center"
                                                Background="#DBEAFE"
                                                CornerRadius="12">
                                                <TextBlock
                                                    FontSize="13"
                                                    Foreground="#1D4ED8"
                                                    Text="{Binding LastRestock, StringFormat=MM/dd/yyyy}" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Status – colour-coded badge  -->
                                <DataGridTemplateColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Header="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="10,4"
                                                HorizontalAlignment="Center"
                                                CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Low Stock">
                                                                <Setter Property="Background" Value="#FEF3C7" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Out of Stock">
                                                                <Setter Property="Background" Value="#FEE2E2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="13">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#065F46" />
                                                            <Setter Property="Text" Value="{Binding Status}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Low Stock">
                                                                    <Setter Property="Foreground" Value="#92400E" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Out of Stock">
                                                                    <Setter Property="Foreground" Value="#991B1B" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!--  Actions: View | Edit | Archive  (active)  /  Restore  (inactive)  -->
                                <DataGridTemplateColumn
                                    Width="2*"
                                    MinWidth="250"
                                    Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                                <!--  Active row buttons  -->
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <!--  View Details  -->
                                                    <Button
                                                        Width="72"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Background="#223357"
                                                        Command="{Binding DataContext.ViewItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallActionButtonStyle}"
                                                        ToolTip="View Details">
                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconBlock
                                                                Margin="0,0,5,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="White"
                                                                Icon="FileAlt" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="View" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!--  Edit  -->
                                                    <Button
                                                        Width="68"
                                                        Height="32"
                                                        Margin="0,0,6,0"
                                                        Background="#22C84A"
                                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallActionButtonStyle}"
                                                        ToolTip="Edit Item">
                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconBlock
                                                                Margin="0,0,5,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="White"
                                                                Icon="Edit" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="Edit" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!--  Archive  -->
                                                    <Button
                                                        Width="86"
                                                        Height="32"
                                                        Background="#E31D1D"
                                                        Command="{Binding DataContext.ArchiveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallActionButtonStyle}"
                                                        ToolTip="Archive Item">
                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconBlock
                                                                Margin="0,0,5,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="White"
                                                                Icon="BoxArchive" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="Archive" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                                <!--  Archived row – Restore button  -->
                                                <Button
                                                    Height="30"
                                                    Padding="14,0"
                                                    Command="{Binding DataContext.RestoreItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand"
                                                    ToolTip="Restore Item">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border
                                                                x:Name="RestoreBorder"
                                                                Background="#22C84A"
                                                                CornerRadius="8"
                                                                Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <fa:IconBlock
                                                                        Margin="0,0,6,0"
                                                                        FontSize="12"
                                                                        Foreground="White"
                                                                        Icon="RotateLeft" />
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="White"
                                                                        Text="Restore" />
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="RestoreBorder" Property="Opacity" Value="0.82" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="RestoreBorder" Property="Opacity" Value="0.65" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
                
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Usage History Overlay                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="43" Visibility="{Binding IsUsageHistoryOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#88000000" />
            <Border
                Width="950"
                MaxHeight="800"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="64" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Center">
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="Black" Text="Item Usage History" />
                            <TextBlock FontSize="13" Foreground="#7A7A7A" Text="Complete log of all recorded item usages" />
                        </StackPanel>
                        <Button
                            Grid.Row="0"
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding CloseUsageHistoryCommand}"
                            Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <Border Grid.Row="1" Background="#E0E0E0" />
                    </Grid>

                    <!--  Search bar  -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid x:Name="UsageHistorySearchBox" Width="320" HorizontalAlignment="Left" Height="44">
                            <TextBox
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{Binding UsageHistorySearch, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="51,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#8A8A8A"
                                IsHitTestVisible="False"
                                Text="Search by item name or ID">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UsageHistorySearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding UsageHistorySearch}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <fa:IconBlock
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Black"
                                Icon="Search" />
                        </Grid>
                    </Grid>

                    <!--  Usage DataGrid  -->
                    <Border Grid.Row="2" Padding="0,0,0,4" Style="{StaticResource LargePanelStyle}">
                        <DataGrid
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding UsageHistoryItems}"
                            MinRowHeight="40"
                            RowHeight="44"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">
                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="0.65*" MinWidth="80"  Binding="{Binding UsageIdDisplay}" Header="Usage ID" />
                                <DataGridTextColumn Width="0.75*" MinWidth="90"  Binding="{Binding ItemId}"        Header="Item ID" />
                                <DataGridTextColumn Width="1.6*"  MinWidth="140" Binding="{Binding ItemName}"      Header="Item Name" />
                                <DataGridTextColumn Width="0.75*" MinWidth="90"  Binding="{Binding QuantityUsed}"  Header="Qty Used" />
                                <DataGridTextColumn Width="0.9*"  MinWidth="100" Binding="{Binding Date, StringFormat=MM/dd/yyyy}" Header="Date" />
                                <DataGridTextColumn Width="1.8*"  MinWidth="150" Binding="{Binding Notes}"         Header="Notes" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Close button  -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Width="130" Height="44" Command="{Binding CloseUsageHistoryCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="#223357" CornerRadius="22">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="White" Text="Close" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CloseBorder" Property="Opacity" Value="0.85" /></Trigger>
                                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="CloseBorder" Property="Opacity" Value="0.7" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!--  Pagination  -->
                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding UsageHasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Width="40" Height="40" Command="{Binding UsagePrevPageCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="16" Foreground="#444444" Icon="ChevronLeft" />
                        </Button>
                        <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#444444" Text="{Binding UsagePageInfo}" />
                        <Button Width="40" Height="40" Command="{Binding UsageNextPageCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="16" Foreground="#444444" Icon="ChevronRight" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Restock History Overlay                            -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="44" Visibility="{Binding IsRestockHistoryOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#88000000" />
            <Border
                Width="950"
                MaxHeight="800"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="64" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" VerticalAlignment="Center">
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="Black" Text="Restock History" />
                            <TextBlock FontSize="13" Foreground="#7A7A7A" Text="Complete log of all item restocks" />
                        </StackPanel>
                        <Button
                            Grid.Row="0"
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding CloseRestockHistoryCommand}"
                            Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <Border Grid.Row="1" Background="#E0E0E0" />
                    </Grid>

                    <!--  Search bar  -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid Width="320" HorizontalAlignment="Left" Height="44">
                            <TextBox
                                Style="{StaticResource SearchTextBoxStyle}"
                                Text="{Binding RestockHistorySearch, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="51,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Foreground="#8A8A8A"
                                IsHitTestVisible="False"
                                Text="Search by item name or ID">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RestockHistorySearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding RestockHistorySearch}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <fa:IconBlock
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Foreground="Black"
                                Icon="Search" />
                        </Grid>
                    </Grid>

                    <!--  Restock DataGrid  -->
                    <Border Grid.Row="2" Padding="0,0,0,4" Style="{StaticResource LargePanelStyle}">
                        <DataGrid
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding RestockHistoryItems}"
                            MinRowHeight="40"
                            RowHeight="44"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">
                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="0.65*" MinWidth="80"  Binding="{Binding RestockIdDisplay}"                              Header="Restock ID" />
                                <DataGridTextColumn Width="0.75*" MinWidth="90"  Binding="{Binding ItemId}"                                        Header="Item ID" />
                                <DataGridTextColumn Width="1.4*"  MinWidth="130" Binding="{Binding ItemName}"                                       Header="Item Name" />
                                <DataGridTextColumn Width="0.7*"  MinWidth="85"  Binding="{Binding StockAdded}"                                     Header="Stock Added" />
                                <DataGridTextColumn Width="0.85*" MinWidth="95"  Binding="{Binding UnitPrice, StringFormat=&#x20B1;{0:N2}}"         Header="Unit Price" />
                                <DataGridTextColumn Width="1.0*"  MinWidth="110" Binding="{Binding Supplier}"                                       Header="Supplier" />
                                <DataGridTextColumn Width="0.9*"  MinWidth="100" Binding="{Binding Date, StringFormat=MM/dd/yyyy}"                  Header="Date" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!--  Close button  -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Width="130" Height="44" Command="{Binding CloseRestockHistoryCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="#223357" CornerRadius="22">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="White" Text="Close" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CloseBorder" Property="Opacity" Value="0.85" /></Trigger>
                                        <Trigger Property="IsPressed" Value="True"><Setter TargetName="CloseBorder" Property="Opacity" Value="0.7" /></Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!--  Pagination  -->
                    <StackPanel
                        Grid.Row="3"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Visibility="{Binding RestockHasMultiplePages, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Width="40" Height="40" Command="{Binding RestockPrevPageCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="16" Foreground="#444444" Icon="ChevronLeft" />
                        </Button>
                        <TextBlock Margin="14,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#444444" Text="{Binding RestockPageInfo}" />
                        <Button Width="40" Height="40" Command="{Binding RestockNextPageCommand}" Cursor="Hand" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="16" Foreground="#444444" Icon="ChevronRight" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Item Information Overlay (View Details)            -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="45" Visibility="{Binding IsViewOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Background="#88000000" />

            <Border
                Width="600"
                Height="Auto"
                MaxHeight="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="Black"
                            Text="Item Information" />
                        <Button
                            Grid.Row="0"
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding CloseViewOverlayCommand}"
                            Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <Border Grid.Row="1" Background="#E0E0E0" />
                    </Grid>

                    <!--  Fields (all read-only)  -->
                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" MaxHeight="620" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!--  Item Name + Item Id  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Name :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock Margin="16,0" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemName}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Id :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#111111" Text="{Binding ViewItemId}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Current Stock + Unit Price + Stock Status badge  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Current Stock :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemStock}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Unit Price :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemPrice}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Stock Status :" />
                                    <Border Height="46" MinWidth="100" Padding="14,0" CornerRadius="14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ViewItemStockStatus}" Value="Low Stock">
                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ViewItemStockStatus}" Value="Out of Stock">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding ViewItemStockStatus}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ViewItemStockStatus}" Value="Low Stock">
                                                            <Setter Property="Foreground" Value="#92400E" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ViewItemStockStatus}" Value="Out of Stock">
                                                            <Setter Property="Foreground" Value="#991B1B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Date Added + Last Restock + Item Status badge  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Date Added :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemDateAdded}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Last Restock :" />
                                    <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemLastRestock}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Status :" />
                                    <Border Height="46" MinWidth="100" Padding="14,0" CornerRadius="14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ViewItemActiveStatus}" Value="Archived">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding ViewItemActiveStatus}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ViewItemActiveStatus}" Value="Archived">
                                                            <Setter Property="Foreground" Value="#991B1B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Low Stock Threshold  -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Low Stock Threshold :" />
                                <Border Height="46" Background="White" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding ViewItemThreshold}" />
                                </Border>
                            </StackPanel>

                            <!--  Notes  -->
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Notes :" />
                                <Border
                                    MinHeight="80"
                                    Padding="14,10"
                                    Background="White"
                                    BorderBrush="#C8DCF0"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <TextBlock
                                        FontSize="13"
                                        Foreground="#111111"
                                        Text="{Binding ViewItemNotes}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!--  Close button  -->
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                        <Button Width="130" Height="44" Command="{Binding CloseViewOverlayCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CloseBorder" Background="#223357" CornerRadius="22">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="Close" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="CloseBorder" Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>

        <!-- Add / Edit Item Overlay -->
        <Grid Panel.ZIndex="50" Visibility="{Binding IsItemOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border Background="#88000000" />

            <Border
                Width="600"
                Height="Auto"
                MaxHeight="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="80" />
                    </Grid.RowDefinitions>

                    <!--  Modal header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            VerticalAlignment="Center"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="Black"
                            Text="{Binding OverlayTitle}" />
                        <Button
                            Grid.Row="0"
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Command="{Binding CloseItemOverlayCommand}"
                            Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <!--  Divider line  -->
                        <Border
                            Grid.Row="1"
                            Background="#E0E0E0" />
                    </Grid>

                    <!--  Form fields  -->
                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" MaxHeight="580" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!--  Add-mode: Item Id banner (full-width)  -->
                            <StackPanel Margin="0,0,0,12" Visibility="{Binding EditIsAddMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Id :" />
                                <Border Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#111111" Text="{Binding PreviewItemId}" />
                                </Border>
                            </StackPanel>

                            <!--  Add-mode: Item Name (full-width)  -->
                            <StackPanel Margin="0,0,0,12" Visibility="{Binding EditIsAddMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Name :" />
                                <TextBox Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Enter Item Name" Text="{Binding EditItemName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Edit-mode: Item Name + Item Id side by side  -->
                            <Grid Margin="0,0,0,12" Visibility="{Binding EditIsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Name :" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Enter Item Name" Text="{Binding EditItemName, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Id :" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#666666" Text="{Binding PreviewItemId}" />
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <!--  Current Stock + Unit Price + Stock Status badge (edit only)  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Current Stock :" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="StockTextBox" Padding="12,0,40,0" Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Enter Item Stock" Text="{Binding EditStock, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="IntegerOnly_PreviewTextInput" />
                                            <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Command="{Binding EditStockIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                    <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                                </Button>
                                                <Button Command="{Binding EditStockDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                    <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Unit Price :" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <TextBox x:Name="UnitPriceTextBox" Padding="34,0,40,0" Style="{StaticResource InventoryOverlayPriceTextBoxStyle}" Tag="0.00" Text="{Binding EditUnitPrice, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="DecimalOnly_PreviewTextInput" />
                                            <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Command="{Binding EditUnitPriceIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                    <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                                </Button>
                                                <Button Command="{Binding EditUnitPriceDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                    <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Bottom" Visibility="{Binding EditIsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Stock Status :" />
                                    <Border Height="46" MinWidth="90" Padding="14,0" CornerRadius="14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditCurrentStatusDisplay}" Value="Low Stock">
                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EditCurrentStatusDisplay}" Value="Out of Stock">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding EditCurrentStatusDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EditCurrentStatusDisplay}" Value="Low Stock">
                                                            <Setter Property="Foreground" Value="#92400E" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding EditCurrentStatusDisplay}" Value="Out of Stock">
                                                            <Setter Property="Foreground" Value="#991B1B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Edit-mode: Item Date Added + Last Restock + Item Status  -->
                            <Grid Margin="0,0,0,12" Visibility="{Binding EditIsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Date Added :" />
                                    <Border Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#666666" Text="{Binding EditItemCreatedDisplay}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Last Restock :" />
                                    <Border Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#666666" Text="{Binding EditLastRestockDisplay}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Bottom">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Status :" />
                                    <Border Height="46" MinWidth="90" Padding="14,0" CornerRadius="14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#D1FAE5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EditItemStatusDisplay}" Value="Archived">
                                                        <Setter Property="Background" Value="#FEE2E2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Text="{Binding EditItemStatusDisplay}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#065F46" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EditItemStatusDisplay}" Value="Archived">
                                                            <Setter Property="Foreground" Value="#991B1B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Low Stock Threshold  -->
                            <StackPanel Margin="0,0,0,12" Visibility="{Binding EditIsAddMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Low Stock Threshold :" />
                                <Grid>
                                    <TextBox x:Name="ThresholdTextBox" Padding="12,0,40,0" Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Enter the minimum stock level for this item" Text="{Binding EditLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="IntegerOnly_PreviewTextInput" />
                                    <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Command="{Binding EditThresholdIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                            <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                        </Button>
                                        <Button Command="{Binding EditThresholdDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                            <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Margin="4,5,0,0" FontSize="11" Foreground="#7A7A7A" Text="Note: Set the minimum stock level for this item. The system will trigger a Low Stock alert when the available quantity reaches this threshold." TextWrapping="Wrap" />
                            </StackPanel>

                            <!--  Notes (optional)  -->
                            <StackPanel Margin="0,0,0,4" Visibility="{Binding EditIsAddMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Notes (optional) :" />
                                <TextBox
                                    Height="90"
                                    FontSize="13"
                                    Style="{StaticResource ModernTextAreaStyle}"
                                    Tag="Add any additional notes here..."
                                    Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Update modal only: Low Stock Threshold, then Notes full-width below  -->
                            <StackPanel Margin="0,0,0,4" Visibility="{Binding EditIsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">

                                <!--  Low Stock Threshold  -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Low Stock Threshold :" />
                                    <Grid>
                                        <TextBox Padding="12,0,40,0" Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Enter the minimum stock level for this item" Text="{Binding EditLowStockThreshold, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="IntegerOnly_PreviewTextInput" />
                                        <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Command="{Binding EditThresholdIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                            </Button>
                                            <Button Command="{Binding EditThresholdDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Margin="4,5,0,0" FontSize="11" Foreground="#7A7A7A" Text="Note: Set the minimum stock level for this item. The system will trigger a Low Stock alert when the available quantity reaches this threshold." TextWrapping="Wrap" />
                                </StackPanel>

                                <!--  Notes (optional) — full-width row below  -->
                                <StackPanel>
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Notes (optional) :" />
                                    <TextBox
                                        Height="90"
                                        FontSize="13"
                                        Style="{StaticResource ModernTextAreaStyle}"
                                        Tag="Add any additional notes here..."
                                        Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!--  Validation error + Cancel / Add Item buttons  -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ItemOverlayErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasItemOverlayError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <StackPanel
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Orientation="Horizontal">

                            <Button
                                Width="130"
                                Height="44"
                                Margin="0,0,16,0"
                                Command="{Binding CloseItemOverlayCommand}"
                                Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="CancelBorder"
                                            Background="#E31D1D"
                                            CornerRadius="22">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="Cancel" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CancelBorder" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CancelBorder" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button
                                Width="150"
                                Height="44"
                                Command="{Binding SaveItemCommand}"
                                Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="SaveBorder"
                                            Background="#22C84A"
                                            CornerRadius="22">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="16"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding SaveButtonLabel}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SaveBorder" Property="Opacity" Value="0.85" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="SaveBorder" Property="Opacity" Value="0.7" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Restock Item Overlay                               -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="55" Visibility="{Binding IsRestockOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#88000000" />
            <Border
                Width="600"
                Height="Auto"
                MaxHeight="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="80" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" VerticalAlignment="Center" FontSize="26" FontWeight="Bold" Foreground="Black" Text="Restock Item" />
                        <Button Grid.Row="0" Width="42" Height="42" HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding CloseRestockOverlayCommand}" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <Border Grid.Row="1" Background="#E0E0E0" />
                    </Grid>

                    <!--  Form fields  -->
                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" MaxHeight="580" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!--  Item Name + Item Id  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Name :" />
                                    <Grid>
                                        <ToggleButton x:Name="RestockItemDropdownBtn" Height="46" Cursor="Hand" HorizontalAlignment="Stretch">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="DropBorder" Height="46" Background="#FFFDFD" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                                        <Grid>
                                                            <TextBlock Margin="16,0,46,0" VerticalAlignment="Center" FontSize="14" Foreground="#111111" Text="{Binding RestockSelectedItemName}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RestockSelectedItemName}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding RestockSelectedItemName}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Margin="16,0,46,0" VerticalAlignment="Center" FontSize="14" Foreground="#A0A0A0" IsHitTestVisible="False" Text="Select Item">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RestockSelectedItemName}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding RestockSelectedItemName}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <fa:IconBlock Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="16" Foreground="Black" Icon="AngleDown" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="DropBorder" Property="BorderBrush" Value="#223357" />
                                                            <Setter TargetName="DropBorder" Property="BorderThickness" Value="2" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <Popup
                                            x:Name="RestockItemPopup"
                                            AllowsTransparency="True"
                                            IsOpen="{Binding IsChecked, ElementName=RestockItemDropdownBtn, Mode=TwoWay}"
                                            Placement="Bottom"
                                            PlacementTarget="{Binding ElementName=RestockItemDropdownBtn}"
                                            StaysOpen="False"
                                            Width="{Binding ActualWidth, ElementName=RestockItemDropdownBtn}">
                                            <Border Background="White" BorderBrush="#DADADA" BorderThickness="1" CornerRadius="8" MaxHeight="220">
                                                <ListBox
                                                    x:Name="RestockItemList"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    ItemsSource="{Binding ActiveItemNames}"
                                                    SelectedItem="{Binding RestockSelectedItemName, Mode=TwoWay}"
                                                    SelectionChanged="RestockItemList_SelectionChanged">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Height" Value="40" />
                                                            <Setter Property="Padding" Value="12,0" />
                                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Id :" />
                                    <Border Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#666666" Text="{Binding RestockItemIdDisplay}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Stock Added + Date of Restock  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Stock Added :" />
                                    <Grid>
                                        <TextBox Padding="12,0,40,0" Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="" Text="{Binding RestockStockAdded, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="IntegerOnly_PreviewTextInput" />
                                        <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Command="{Binding RestockQtyIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                            </Button>
                                            <Button Command="{Binding RestockQtyDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Date of Restock :" />
                                    <DatePicker SelectedDate="{Binding RestockDate, Mode=TwoWay}" SelectedDateFormat="Short" Style="{StaticResource InventoryOverlayDatePickerStyle}" />
                                </StackPanel>
                            </Grid>

                            <!--  Unit Price + Supplier  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Unit Price :" />
                                    <Grid>
                                        <TextBox Padding="34,0,40,0" Style="{StaticResource InventoryOverlayPriceTextBoxStyle}" Tag="0.00" Text="{Binding RestockUnitPriceStr, UpdateSourceTrigger=PropertyChanged}" PreviewTextInput="DecimalOnly_PreviewTextInput" />
                                        <StackPanel Margin="0,0,8,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Button Command="{Binding RestockPriceIncrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleUp" />
                                            </Button>
                                            <Button Command="{Binding RestockPriceDecrementCommand}" Style="{StaticResource SpinnerButtonStyle}">
                                                <fa:IconBlock FontSize="11" Foreground="#223357" Icon="AngleDown" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Supplier (optional) :" />
                                    <TextBox Style="{StaticResource InventoryOverlayTextBoxStyle}" Tag="Optional" Text="{Binding RestockSupplier, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <!--  Info boxes: Current Stock + New Stock Total  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#EBF5FF" BorderBrush="#B3D7FF" BorderThickness="1" CornerRadius="10" Padding="14,10">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#1A5FA8" Text="{Binding RestockCurrentStockDisplay}" TextWrapping="Wrap" />
                                </Border>
                                <Border Grid.Column="2" Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1" CornerRadius="10" Padding="14,10">
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#92400E" Text="{Binding RestockNewTotalDisplay}" TextWrapping="Wrap" />
                                </Border>
                            </Grid>

                            <!--  Notes (optional)  -->
                            <StackPanel Margin="0,0,0,4">
                                <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Notes (optional) :" />
                                <TextBox
                                    Height="100"
                                    FontSize="13"
                                    Style="{StaticResource ModernTextAreaStyle}"
                                    Tag="Add additional notes..."
                                    Text="{Binding RestockNotes, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                    <!--  Error + buttons  -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding RestockErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasRestockError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Orientation="Horizontal">
                            <Button Width="130" Height="44" Margin="0,0,16,0" Command="{Binding CloseRestockOverlayCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CancelBorder" Background="#E31D1D" CornerRadius="22">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="Cancel" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CancelBorder" Property="Opacity" Value="0.85" /></Trigger>
                                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="CancelBorder" Property="Opacity" Value="0.7" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Width="170" Height="44" Command="{Binding ConfirmRestockCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ConfirmBorder" Background="#22C84A" CornerRadius="22">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="White" Text="Confirm Restock" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.85" /></Trigger>
                                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ConfirmBorder" Property="Opacity" Value="0.7" /></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  Log Item Usage Overlay                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Panel.ZIndex="56" Visibility="{Binding IsUsageOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">
