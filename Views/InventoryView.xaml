                Width="600"
                Height="Auto"
                MaxHeight="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="14">

                <Grid Margin="34,24,34,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="68" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="80" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" VerticalAlignment="Center" FontSize="26" FontWeight="Bold" Foreground="Black" Text="Log Item Usage" />
                        <Button Grid.Row="0" Width="42" Height="42" HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding CloseUsageOverlayCommand}" Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock FontSize="22" Foreground="#444444" Icon="Times" />
                        </Button>
                        <Border Grid.Row="1" Background="#E0E0E0" />
                    </Grid>

                    <!--  Form fields  -->
                    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" MaxHeight="580" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!--  Item Name + Item Id  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Name :" />
                                    <Grid>
                                        <ToggleButton x:Name="UsageItemDropdownBtn" Height="46" Cursor="Hand" HorizontalAlignment="Stretch">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="DropBorder" Height="46" Background="#FFFDFD" BorderBrush="#C8DCF0" BorderThickness="1" CornerRadius="14">
                                                        <Grid>
                                                            <TextBlock Margin="16,0,46,0" VerticalAlignment="Center" FontSize="14" Foreground="#111111" Text="{Binding UsageSelectedItemName}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding UsageSelectedItemName}" Value=""><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding UsageSelectedItemName}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Margin="16,0,46,0" VerticalAlignment="Center" FontSize="14" Foreground="#A0A0A0" IsHitTestVisible="False" Text="Select Item">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding UsageSelectedItemName}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding UsageSelectedItemName}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <fa:IconBlock Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="16" Foreground="Black" Icon="AngleDown" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="DropBorder" Property="BorderBrush" Value="#223357" />
                                                            <Setter TargetName="DropBorder" Property="BorderThickness" Value="2" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                        <Popup
                                            x:Name="UsageItemPopup"
                                            AllowsTransparency="True"
                                            IsOpen="{Binding IsChecked, ElementName=UsageItemDropdownBtn, Mode=TwoWay}"
                                            Placement="Bottom"
                                            PlacementTarget="{Binding ElementName=UsageItemDropdownBtn}"
                                            StaysOpen="False"
                                            Width="{Binding ActualWidth, ElementName=UsageItemDropdownBtn}">
                                            <Border Background="White" BorderBrush="#DADADA" BorderThickness="1" CornerRadius="8" MaxHeight="220">
                                                <ListBox
                                                    x:Name="UsageItemList"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    ItemsSource="{Binding ActiveItemNames}"
                                                    SelectedItem="{Binding UsageSelectedItemName, Mode=TwoWay}"
                                                    SelectionChanged="UsageItemList_SelectionChanged">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Height" Value="40" />
                                                            <Setter Property="Padding" Value="12,0" />
                                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                                            <Setter Property="Cursor" Value="Hand" />
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="4,0,0,5" FontSize="13" FontWeight="SemiBold" Text="Item Id :" />
                                    <Border Height="46" Background="#F0F0F0" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="14">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#666666" Text="{Binding UsageItemIdDisplay}" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!--  Quantity Used + Date of Usage  -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
