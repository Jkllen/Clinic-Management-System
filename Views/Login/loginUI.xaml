<Window x:Class="Clinic_Management_System.Views.Login.LoginUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStyle="ThreeDBorderWindow"
        SizeToContent="Manual">

    <!-- Root Grid with scalable gradient -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                <GradientStop Color="#91EFEF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Use Viewbox for proportional scaling -->
        <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Width="544" Height="796">

                <!-- Glass Card -->
                <Border CornerRadius="40"
                        BorderBrush="White"
                        BorderThickness="1"
                        Background="#73FFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="19.65"/>
                    </Border.Effect>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/> <!-- Logo -->
                            <RowDefinition Height="3*"/> <!-- Form -->
                        </Grid.RowDefinitions>

                        <!-- Logo -->
                        <Image Grid.Row="0"
                               Source="C:\Users\Augustine\Documents\VSCode Projects\Clinic-Management-System\Assets\Logo\logo.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <!-- Login Form -->
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch">

                            <TextBlock Text="Login"
                                       FontFamily="Inria Serif"
                                       FontWeight="Bold"
                                       FontSize="36"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>

                            <!-- User ID -->
                            <TextBlock Text="User ID"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <Border CornerRadius="20" BorderBrush="#CCC" BorderThickness="1" Background="White" Margin="0,0,0,10">
                                <TextBox x:Name="UserIdBox"
                                         BorderThickness="0"
                                         FontSize="16"
                                         Height="52"
                                         Padding="12,0"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"/>
                            </Border>

                            <!-- Password -->
                            <TextBlock Text="Password"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <Border CornerRadius="20" BorderBrush="#CCC" BorderThickness="1" Background="White" Margin="0,0,0,10">
                                <PasswordBox x:Name="PasswordBox"
                                             BorderThickness="0"
                                             FontSize="16"
                                             Height="52"
                                             Padding="12,0"
                                             VerticalContentAlignment="Center"
                                             Background="Transparent"/>
                            </Border>

                            <!-- Forgot Password -->
                            <TextBlock Text="Forgot Password?"
                                       Foreground="#0077CC"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,20"
                                       Cursor="Hand"
                                       MouseDown="ForgotPassword_Click"/>

                            <!-- Login Button inside Border for rounded corners -->
                            <Border CornerRadius="30.5"
                                    Width="192"
                                    Height="61"
                                    HorizontalAlignment="Center"
                                    Background="#91EFEF"
                                    Margin="0,0,0,10">
                                <Button Content="Login"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Foreground="Black"
                                        FontWeight="Bold"
                                        FontSize="18"
                                        Click="Login_Click"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Viewbox>
    </Grid>
</Window>
