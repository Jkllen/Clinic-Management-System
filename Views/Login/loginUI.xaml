<Window x:Class="Clinic_Management_System.Views.Login.LoginUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="Transparent"
        WindowStyle="ThreeDBorderWindow"
        SizeToContent="Manual">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#FFFFFFFF"
                              Offset="0"/>
                <GradientStop Color="#91EFEF"
                              Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Viewbox Stretch="Uniform"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Grid Width="544"
                  Height="796">

                <Border CornerRadius="40"
                        BorderBrush="White"
                        BorderThickness="1"
                        Background="#73FFFFFF">
                    <Border.Effect>
                        <DropShadowEffect Color="Black"
                                          Opacity="0.25"
                                          BlurRadius="19.65"/>
                    </Border.Effect>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="3*"/>
                        </Grid.RowDefinitions>

                        <!-- LOGO -->
                        <Image Grid.Row="0"
                               Source="C:\Users\Augustine\Documents\VSCode Projects\Clinic-Management-System\Assets\Logo\logo.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <!-- LOGIN FORM -->
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch">

                            <TextBlock Text="Login"
                                       FontFamily="Inria Serif"
                                       FontWeight="Bold"
                                       FontSize="36"
                                       Foreground="Black"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,20"/>

                            <!-- USERNAME -->
                            <TextBlock Text="User ID"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>

                            <Border CornerRadius="20"
                                    BorderBrush="#CCC"
                                    BorderThickness="1"
                                    Background="White"
                                    Margin="0,0,0,5">
                                <Grid>
                                    <!-- Placeholder -->
                                    <TextBlock x:Name="UserPlaceholder"
                                               Text="Enter user ID"
                                               Foreground="#888"
                                               Margin="12,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>

                                    <TextBox x:Name="UserIdBox"
                                             BorderThickness="0"
                                             FontSize="16"
                                             Height="52"
                                             Padding="12,0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             TextChanged="UserIdBox_TextChanged"/>

                                </Grid>
                            </Border>

                            <!-- PASSWORD -->
                            <TextBlock Text="Password"
                                       Foreground="Black"
                                       FontWeight="SemiBold"
                                       Margin="0,10,0,5"/>

                            <Border CornerRadius="20"
                                    BorderBrush="#CCC"
                                    BorderThickness="1"
                                    Background="White"
                                    Margin="0,0,0,5">
                                <Grid>
                                    <!-- Placeholder -->
                                    <TextBlock x:Name="PassPlaceholder"
                                               Text="Enter password"
                                               Foreground="#888"
                                               Margin="12,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"/>

                                    <!-- PasswordBox -->
                                    <PasswordBox x:Name="PasswordBox"
                                                 BorderThickness="0"
                                                 FontSize="16"
                                                 Height="52"
                                                 Padding="12,0"
                                                 Background="Transparent"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                                    <!-- TextBox for showing password -->
                                    <TextBox x:Name="VisiblePasswordBox"
                                             BorderThickness="0"
                                             FontSize="16"
                                             Height="52"
                                             Padding="12,0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             TextChanged="VisiblePasswordBox_TextChanged"
                                             Visibility="Collapsed"/>

                                    <!-- Show/Hide button -->
                                    <Button x:Name="ShowPassBtn"
                                            Content="👁"
                                            Width="40"
                                            Height="40"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Click="TogglePassword_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="20">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>


                            <!-- Hidden TextBox (counts as a control) -->
                            <TextBox x:Name="HiddenField"
                                     Visibility="Collapsed"/>

                            <!-- Inline Error Text -->
                            <TextBlock x:Name="ErrorLabel"
                                       Text=""
                                       Foreground="Red"
                                       FontSize="14"
                                       Margin="0,5,0,10"
                                       Visibility="Collapsed"/>

                            <!-- Forgot Password -->
                            <TextBlock Text="Forgot Password?"
                                       Foreground="#0077CC"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,0,20"
                                       Cursor="Hand"
                                       MouseDown="ForgotPassword_Click"/>

                            <!-- Login Button -->
                            <Border CornerRadius="30.5"
                                    Width="192"
                                    Height="61"
                                    HorizontalAlignment="Center"
                                    Background="#91EFEF"
                                    Margin="0,0,0,10">
                                <Button Content="Login"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Foreground="Black"
                                        FontWeight="Bold"
                                        FontSize="18"
                                        Click="Login_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="30.5">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                </Button>
                            </Border>

                            <!-- Info Label -->
                            <TextBlock Text="Clinic Management System v1.0"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       Foreground="#444"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Viewbox>
    </Grid>
</Window>
