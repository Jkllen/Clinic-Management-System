<Window x:Class="EcoVision.Views.Login.LoginUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="1920" Height="1080"
        Background="{x:Null}"
        AllowsTransparency="True"
        WindowStyle="None">

    <!-- Background gradient -->
    <Grid Background="{LinearGradientBrush GradientStops={GradientStop Color=#FFFFFFFF Offset=0}, {GradientStop Color=#91EFEF Offset=1}}">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            
            <!-- Glass Card -->
            <Border Width="544" Height="796"
                    CornerRadius="40"
                    BorderBrush="White"
                    BorderThickness="1"
                    Background="#73FFFFFF"
                    Effect="{DynamicResource DropShadow}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.25" BlurRadius="19.65"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Logo/Image -->
                    <Image Grid.Row="0"
                           Width="349" Height="361"
                           Margin="0,40,0,0"
                           Stretch="UniformToFill"
                           Source="Assets/Logo/logo.png"
                           HorizontalAlignment="Center"/>

                    <!-- Login Form -->
                    <StackPanel Grid.Row="1" Margin="60,20,60,40" VerticalAlignment="Top">

                        <!-- Title -->
                        <TextBlock Text="Login"
                                   FontFamily="Inria Serif"
                                   FontWeight="Bold"
                                   FontSize="36"
                                   Foreground="Black"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,40"/>

                        <!-- User ID -->
                        <TextBlock Text="User ID"
                                   Foreground="Black"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="UserIdBox"
                                 Height="52"
                                 FontSize="16"
                                 Padding="12,0"
                                 BorderBrush="#CCC"
                                 BorderThickness="1"
                                 CornerRadius="10"
                                 Background="White"/>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   Foreground="Black"
                                   FontWeight="SemiBold"
                                   Margin="0,20,0,8"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Height="52"
                                     FontSize="16"
                                     Padding="12,0"
                                     BorderBrush="#CCC"
                                     BorderThickness="1"
                                     CornerRadius="10"
                                     Background="White"/>

                        <!-- Forgot Password -->
                        <TextBlock Text="Forgot Password?"
                                   Foreground="#0077CC"
                                   HorizontalAlignment="Right"
                                   Margin="0,10,0,20"
                                   Cursor="Hand"
                                   MouseDown="ForgotPassword_Click"/>

                        <!-- Login Button -->
                        <Button Content="Login"
                                Width="192"
                                Height="61"
                                HorizontalAlignment="Center"
                                Background="#91EFEF"
                                Foreground="Black"
                                FontWeight="Bold"
                                FontSize="18"
                                BorderBrush="Transparent"
                                CornerRadius="30.5"
                                Click="Login_Click"/>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
