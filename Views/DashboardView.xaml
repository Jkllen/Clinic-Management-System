<UserControl x:Class="CruzNeryClinic.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900">
    <UserControl.Resources>
        <!-- Tab button for the lower table section (Patient Queue / Recent Billing) -->
        <Style x:Key="DashboardTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7A7A7A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Day cell in the Appointment List week-strip -->
        <Style x:Key="DayCellButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="2"
                                Padding="0,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF3F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#16B5A0"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Status pill (e.g. Waiting) on appointment cards -->
        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF1F5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="StaffCalendarDayButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{Binding DayBackground}"/>
            <Setter Property="BorderBrush" Value="{Binding DayBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DayCell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{Binding DayNumber}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding DayForeground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                                <Border Width="16"
                                        Height="16"
                                        Margin="0,2,2,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Background="#E31D1D"
                                        CornerRadius="8"
                                        Visibility="{Binding AppointmentCountVisibility}">
                                    <TextBlock Text="{Binding AppointmentCount}"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                    <Condition Binding="{Binding IsSelected}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="DayCell" Property="Background" Value="#EEF6FF"/>
                                <Setter TargetName="DayCell" Property="BorderBrush" Value="#9FC0F0"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Soft drop shadow applied to dashboard cards, tables and panels ── -->
        <!-- These extend the shared styles and add the shadow only within the dashboard. -->
        <DropShadowEffect x:Key="CardDropShadow"
                          Color="#000000"
                          BlurRadius="14"
                          ShadowDepth="2"
                          Direction="270"
                          Opacity="0.16"/>

        <Style x:Key="DashboardCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardCardStyle}">
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
        </Style>

        <Style x:Key="DashboardTableContainerStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardTableContainerStyle}">
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
        </Style>

        <Style x:Key="LargePanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource LargePanelStyle}">
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">

        <Grid Margin="26,28,18,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════ LEFT DASHBOARD AREA ════════════════════ -->
            <Grid Grid.Column="0"
                    Margin="0,0,16,0">

                <Grid.RowDefinitions>
                    <!-- Row 0: Header and search -->
                    <RowDefinition Height="78"/>
                    <!-- Row 1: Top dashboard cards -->
                    <RowDefinition Height="190"/>
                    <!-- Row 2: Analytics charts (admin only) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 3: Tabbed Queue / Billing section -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- #region Row 0 : Header -->
                <Grid Grid.Row="0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                                Text="Dashboard"
                                FontSize="30"
                                FontWeight="Bold"
                                Foreground="Black"/>

                    <TextBlock Grid.Row="1"
                                Text="Overview of clinic operations"
                                FontSize="20"
                                Foreground="#7A7A7A"
                                Margin="0,4,0,0"/>
                </Grid>
                <!-- #endregion Row 0 -->

                <!-- #region Row 1 : Top dashboard cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total patients card -->
                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="0,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Total Patients Today -->
                            <Grid Grid.Row="0"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#2F98D0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Users"
                                                    Foreground="White"
                                                    FontSize="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Total New Patients Today"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding TotalPatients}"
                                                FontSize="24"
                                                Foreground="#50C878"/>
                                </Grid>
                            </Grid>

                            <!-- New Patients -->
                            <Grid Grid.Row="1"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#43B935"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="UserPlus"
                                                    Foreground="White"
                                                    FontSize="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="{Binding NewPatientsLabel}"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding NewPatientsThisMonth}"
                                                FontSize="24"
                                                Foreground="#50C878"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Low stock card -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>

                            <!-- Low stock header -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#FF981D"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Box"
                                                    Foreground="White"
                                                    FontSize="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Low Stock Items"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="Most Urgent"
                                                FontSize="15"
                                                Foreground="#D21E1E"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>

                            <!-- Low stock list -->
                            <Grid Grid.Row="1"
                                    Margin="0,8,0,0">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                            Text="Items"
                                            FontWeight="Bold"
                                            FontSize="14"
                                            Margin="0,0,0,6"/>

                                <ItemsControl Grid.Row="1"
                                                ItemsSource="{Binding LowStockItems}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                            Text="{Binding ItemName}"
                                                            FontSize="12"
                                                            TextWrapping="Wrap"
                                                            TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="1"
                                                            Text="{Binding QuantityLeft, StringFormat={}{0} Left}"
                                                            FontSize="12"
                                                            Foreground="#D21E1E"
                                                            HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Button Grid.Row="2"
                                    Content="View All"
                                    Command="{Binding ViewInventoryCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Payments card -->
                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <!-- Pending Payments -->
                            <Grid Grid.Row="0"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#D38C7F"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="ExclamationCircle"
                                                    Foreground="White"
                                                    FontSize="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Pending Payments"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding PendingPayments}"
                                                FontSize="24"
                                                Foreground="#C49D49"/>
                                </Grid>
                            </Grid>

                            <!-- Unpaid Balance -->
                            <Grid Grid.Row="1"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="Black"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Receipt"
                                                    Foreground="White"
                                                    FontSize="24"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Unpaid Balance"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding TotalUnpaidBalance, StringFormat=₱ {0:N2}}"
                                                FontSize="15"
                                                Foreground="Red"
                                                FontWeight="Bold"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>

                            <Button Grid.Row="2"
                                    Content="View All"
                                    Command="{Binding ViewBillingCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                </Grid>
                <!-- #endregion Row 1 -->

                <!-- #region Row 2 : Analytics charts (admin only) -->
                <Grid Grid.Row="2"
                        Height="205"
                        Margin="0,12,0,0"
                        Visibility="{Binding CanViewAdminDashboardAnalytics, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Patient visits trend chart -->
                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <TextBlock Text="Patient Visits Trend"
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                <Button Content="View All"
                                        Command="{Binding ViewPatientVisitsReportCommand}"
                                        Style="{StaticResource ViewAllButtonStyle}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Canvas x:Name="DashPatientVisitCanvas"
                                    Grid.Row="1"
                                    ClipToBounds="True"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Tag="patientVisit"
                                    ToolTip="Click to view chart details"
                                    MouseLeftButtonUp="Chart_Click"
                                    SizeChanged="DashPatientVisitCanvas_SizeChanged"/>
                        </Grid>
                    </Border>

                    <!-- Revenue trend chart -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="8,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <TextBlock Text="Revenue Trend"
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Left"/>
                                <Button Content="View All"
                                        Command="{Binding ViewRevenueReportCommand}"
                                        Style="{StaticResource ViewAllButtonStyle}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Canvas x:Name="DashRevenueCanvas"
                                    Grid.Row="1"
                                    ClipToBounds="True"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Tag="revenue"
                                    ToolTip="Click to view chart details"
                                    MouseLeftButtonUp="Chart_Click"
                                    SizeChanged="DashRevenueCanvas_SizeChanged"/>
                        </Grid>
                    </Border>
                </Grid>
                <!-- #endregion Row 2 -->

                <!-- #region Row 3 : Tabbed Queue / Billing section -->
                <Grid Grid.Row="3"
                        Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <!-- Tab bar -->
                        <RowDefinition Height="Auto"/>
                        <!-- Active table -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab bar -->
                    <Border Grid.Row="0"
                            Background="#F1F2F5"
                            CornerRadius="10"
                            Padding="4"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Patient Queue"
                                    Command="{Binding ShowQueueTabCommand}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource DashboardTabButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsQueueTabSelected}" Value="True">
                                                <Setter Property="Background" Value="#223357"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Recent Billing Transactions"
                                    Command="{Binding ShowTransactionsTabCommand}">
                                <Button.Style>
                                    <Style BasedOn="{StaticResource DashboardTabButtonStyle}" TargetType="Button">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsQueueTabSelected}" Value="False">
                                                <Setter Property="Background" Value="#223357"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Patient Queue table -->
                    <Border Grid.Row="1"
                            Style="{StaticResource DashboardTableContainerStyle}"
                            Visibility="{Binding IsQueueTabSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                        <DataGrid ItemsSource="{Binding TodayQueue}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No."
                                                    Binding="{Binding QueueNumber}"
                                                    Width="0.5*"
                                                    MinWidth="50"/>
                                <DataGridTextColumn Header="Time"
                                                    Binding="{Binding Time}"
                                                    Width="0.8*"
                                                    MinWidth="75"/>
                                <DataGridTextColumn Header="Patient ID"
                                                    Binding="{Binding PatientCode}"
                                                    Width="1*"
                                                    MinWidth="90"/>
                                <DataGridTextColumn Header="Patient Name"
                                                    Binding="{Binding PatientName}"
                                                    Width="1.7*"
                                                    MinWidth="140"/>
                                <DataGridTextColumn Header="Type"
                                                    Binding="{Binding AppointmentType}"
                                                    Width="1*"
                                                    MinWidth="90"/>
                                <DataGridTextColumn Header="Treatment"
                                                    Binding="{Binding Treatment}"
                                                    Width="1.4*"
                                                    MinWidth="120"/>
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="1*"
                                                    MinWidth="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Recent Billing Transactions table -->
                    <Border Grid.Row="1">
                        <Border.Style>
                            <Style BasedOn="{StaticResource DashboardTableContainerStyle}" TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsQueueTabSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <DataGrid ItemsSource="{Binding RecentTransactions}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"
                                                    Binding="{Binding Time}"
                                                    Width="0.8*"
                                                    MinWidth="75"/>
                                <DataGridTextColumn Header="Patient ID"
                                                    Binding="{Binding PatientCode}"
                                                    Width="1*"
                                                    MinWidth="90"/>
                                <DataGridTextColumn Header="Patient Name"
                                                    Binding="{Binding PatientName}"
                                                    Width="1.6*"
                                                    MinWidth="140"/>
                                <DataGridTextColumn Header="Service"
                                                    Binding="{Binding Service}"
                                                    Width="1.3*"
                                                    MinWidth="120"/>
                                <DataGridTextColumn Header="Amount"
                                                    Binding="{Binding Amount, StringFormat=₱ {0:N2}}"
                                                    Width="1*"
                                                    MinWidth="100"/>
                                <DataGridTextColumn Header="Payment Status"
                                                    Binding="{Binding PaymentStatus}"
                                                    Width="1.3*"
                                                    MinWidth="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
                <!-- #endregion Row 3 -->
            </Grid>

            <!-- ════════════════════ RIGHT PANEL ════════════════════ -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <!-- Search box -->
                    <RowDefinition Height="Auto"/>
                    <!-- Recent Activity Log (admin only; collapses for staff) -->
                    <RowDefinition Height="Auto"/>
                    <!-- Appointment List -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search box + period selector -->
                <Grid Grid.Row="0"
                        Height="52"
                        Margin="0,0,0,14">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="104"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search box with suggestion popup -->
                    <Grid Grid.Column="0">
                        <TextBox x:Name="DashboardSearchBox"
                                    Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Search user or patient ID"
                                    FontSize="14"
                                    Foreground="#8A8A8A"
                                    VerticalAlignment="Center"
                                    Margin="50,0,0,0"
                                    IsHitTestVisible="False">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <fa:IconBlock Icon="Search"
                                        FontSize="18"
                                        Foreground="#9A9A9A"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="18,0,0,0"/>

                        <!-- Patient / user suggestions -->
                        <Popup Width="{Binding ActualWidth, ElementName=DashboardSearchBox}"
                                AllowsTransparency="True"
                                IsOpen="{Binding IsSearchPopupOpen, Mode=TwoWay}"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=DashboardSearchBox}"
                                StaysOpen="False">

                            <Border MaxHeight="280"
                                    Background="White"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="10">

                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16"
                                                        Opacity="0.18"
                                                        ShadowDepth="3"/>
                                </Border.Effect>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="{x:Type ScrollBar}"
                                                BasedOn="{StaticResource BlueDataGridScrollBarStyle}"/>
                                    </ScrollViewer.Resources>

                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalContentAlignment="Stretch"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    Padding="12,8">
                                                                <ContentPresenter HorizontalAlignment="Stretch"
                                                                                    VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#EEF6FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                        FontSize="13"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="#111111"
                                                                        TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Subtitle}"
                                                                        FontSize="11"
                                                                        Foreground="#777777"
                                                                        Margin="0,2,0,0"/>
                                                        </StackPanel>

                                                        <Border Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                Background="#EEF1F5"
                                                                CornerRadius="8"
                                                                Padding="8,2">
                                                            <TextBlock Text="{Binding ResultType}"
                                                                        FontSize="10"
                                                                        Foreground="#555555"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Month / Year period selector -->
                    <ComboBox Grid.Column="2"
                                VerticalAlignment="Center"
                                Height="44"
                                ItemsSource="{Binding PeriodOptions}"
                                SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                                Style="{StaticResource ExactStyleComboBox}"
                                ToolTip="Period for dashboard analytics"/>
                </Grid>

                <!-- Recent Activity Log -->
                <Border Grid.Row="1"
                        Style="{StaticResource DashboardCardStyle}"
                        Height="215"
                        Margin="0,0,0,14"
                        Visibility="{Binding CanViewAdminDashboardAnalytics, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="10"
                                    Background="#D23B3B"
                                    VerticalAlignment="Center">
                                <fa:IconBlock Icon="Bullseye"
                                            Foreground="White"
                                            FontSize="22"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Recent Activity Log"
                                        FontSize="17"
                                        FontWeight="Bold"
                                        VerticalAlignment="Center"
                                        Margin="10,0,0,0"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                ItemsSource="{Binding RecentActivityLog}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                FontSize="11"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource BlueDataGridScrollBarStyle}"/>
                                </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp"
                                                    Binding="{Binding Timestamp}"
                                                    Width="1.4*"
                                                    MinWidth="120"/>
                                <DataGridTextColumn Header="Name"
                                                    Binding="{Binding Name}"
                                                    Width="1*"
                                                    MinWidth="70"/>
                                <DataGridTextColumn Header="Action"
                                                    Binding="{Binding Action}"
                                                    Width="0.9*"
                                                    MinWidth="60"/>
                                <DataGridTextColumn Header="Module"
                                                    Binding="{Binding Module}"
                                                    Width="1*"
                                                    MinWidth="70"/>
                                <DataGridTextColumn Header="Details"
                                                    Binding="{Binding Details}"
                                                    Width="1.6*"
                                                    MinWidth="190"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="2"
                                Content="View All"
                                Command="{Binding ViewActivityLogReportCommand}"
                                Style="{StaticResource ViewAllButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <!-- Staff appointment calendar (non-admin only) -->
                <Border Grid.Row="1"
                        Style="{StaticResource DashboardCardStyle}"
                        Height="245"
                        Margin="0,0,0,14"
                        Padding="18,14"
                        Visibility="{Binding CanViewStaffAppointmentCalendar, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{Binding PreviousStaffCalendarMonthCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    Cursor="Hand"
                                    Padding="6,0">
                                <fa:IconBlock Icon="ChevronLeft"
                                              FontSize="15"
                                              Foreground="#223357"/>
                            </Button>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding StaffCalendarMonthTitle}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#111111"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="2"
                                    Command="{Binding NextStaffCalendarMonthCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    Cursor="Hand"
                                    Padding="6,0">
                                <fa:IconBlock Icon="ChevronRight"
                                              FontSize="15"
                                              Foreground="#223357"/>
                            </Button>
                        </Grid>

                        <UniformGrid Grid.Row="1"
                                     Columns="7"
                                     Margin="0,0,0,4">
                            <TextBlock Text="S" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="M" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="T" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="W" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="T" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="F" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="S" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </UniformGrid>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding StaffCalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource StaffCalendarDayButtonStyle}"
                                            Margin="1.5"
                                            Command="{Binding DataContext.SelectStaffCalendarDateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Appointment List -->
                <Border Grid.Row="2"
                        Style="{StaticResource LargePanelStyle}"
                        Padding="20,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Title -->
                            <RowDefinition Height="Auto"/>
                            <!-- Date / time labels -->
                            <RowDefinition Height="Auto"/>
                            <!-- Month navigation -->
                            <RowDefinition Height="Auto"/>
                            <!-- Day strip -->
                            <RowDefinition Height="Auto"/>
                            <!-- Appointment cards -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                    Text="Appointment List"
                                    FontSize="24"
                                    FontWeight="Bold"/>

                        <Grid Grid.Row="1"
                                Margin="0,6,0,0">
                            <TextBlock Text="{Binding SelectedDateText}"
                                        FontSize="13"
                                        Foreground="#9A9A9A"
                                        HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding CurrentTimeText}"
                                        FontSize="13"
                                        Foreground="#9A9A9A"
                                        HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Month navigation -->
                        <Border Grid.Row="2"
                                Background="#F1F2F5"
                                CornerRadius="10"
                                Margin="0,12,0,10"
                                Padding="6,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Command="{Binding PreviousWeekCommand}"
                                        Style="{StaticResource ViewAllButtonStyle}"
                                        Cursor="Hand"
                                        Padding="8,0">
                                    <fa:IconBlock Icon="ChevronLeft" FontSize="14" Foreground="#555555"/>
                                </Button>

                                <TextBlock Grid.Column="1"
                                            Text="{Binding CurrentMonth}"
                                            FontSize="17"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                                <Button Grid.Column="2"
                                        Command="{Binding NextWeekCommand}"
                                        Style="{StaticResource ViewAllButtonStyle}"
                                        Cursor="Hand"
                                        Padding="8,0">
                                    <fa:IconBlock Icon="ChevronRight" FontSize="14" Foreground="#555555"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Day strip -->
                        <ItemsControl Grid.Row="3"
                                        ItemsSource="{Binding WeekDays}"
                                        Margin="0,0,0,6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DayCellButtonStyle}"
                                            Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DayNumber}"
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding DayName}"
                                                        FontSize="11"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Appointment cards -->
                        <ScrollViewer Grid.Row="4"
                                    VerticalScrollBarVisibility="Auto"
                                    HorizontalScrollBarVisibility="Disabled"
                                    Margin="0,6,0,0">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}"
                                    BasedOn="{StaticResource BlueDataGridScrollBarStyle}"/>
                            </ScrollViewer.Resources>

                            <ItemsControl ItemsSource="{Binding SelectedDateAppointments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White"
                                                BorderBrush="#E4E7EC"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="12,10"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="40"
                                                        Height="40"
                                                        CornerRadius="20"
                                                        Background="#16B5A0"
                                                        VerticalAlignment="Center">
                                                    <fa:IconBlock Icon="User"
                                                                Foreground="White"
                                                                FontSize="18"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding PatientName}"
                                                                FontSize="14"
                                                                FontWeight="SemiBold"
                                                                TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Time}"
                                                                FontSize="12"
                                                                Foreground="#9A9A9A"
                                                                Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource StatusPillStyle}">
                                                    <TextBlock Text="{Binding Status}"
                                                                FontSize="11"
                                                                Foreground="#555555"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Chart detail side panel (snaps to the right when a chart is clicked) -->
        <Grid Panel.ZIndex="50"
              Visibility="{Binding IsChartDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#22000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseChartDetailCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border HorizontalAlignment="Right"
                    Width="440"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" Direction="180" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <Grid Margin="22,20,22,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ChartDetailTitle}" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Button HorizontalAlignment="Right" Width="34" Height="34"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseChartDetailCommand}">
                            <fa:IconBlock Icon="Times" FontSize="18" Foreground="#666666"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="220" Background="#FAFAFA" CornerRadius="8" Padding="6">
                        <Canvas x:Name="ChartDetailCanvas" ClipToBounds="True" Background="Transparent"
                                SizeChanged="ChartDetailCanvas_SizeChanged"/>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="What this shows" FontWeight="SemiBold" FontSize="13" Foreground="#223357"/>
                        <TextBlock Text="{Binding ChartDetailDescription}" TextWrapping="Wrap"
                                   FontSize="12" Foreground="#555555" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock Text="Interpretation" FontWeight="SemiBold" FontSize="13" Foreground="#223357"/>
                        <TextBlock Text="{Binding ChartDetailInsight}" TextWrapping="Wrap"
                                   FontSize="12" Foreground="#555555" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,14,0,0">
                        <TextBlock Text="Key figures" FontWeight="SemiBold" FontSize="13"
                                   Foreground="#223357" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding ChartDetailFigures}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#666666"
                                                   HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding Value}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#111111" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
