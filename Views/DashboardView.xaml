<UserControl x:Class="CruzNeryClinic.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900">

    <Grid Background="{StaticResource ScreenBackgroundBrush}">

        <!-- 
            MinWidth and MinHeight preserve the dashboard layout.
            If the window becomes smaller than this, scrollbars appear instead of crushing the UI.
        -->
        <Grid MinWidth="1050"
                MinHeight="820"
                Margin="26,28,18,14">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="410"/>
            </Grid.ColumnDefinitions>

            <!-- Left dashboard area -->
            <Grid Grid.Column="0"
                    Margin="0,0,16,0">

                <Grid.RowDefinitions>
                    <!-- Row 0: Header and search -->
                    <RowDefinition Height="78"/>

                    <!-- Row 1: Top dashboard cards -->
                    <RowDefinition Height="220"/>

                    <!-- Row 2: Middle cards -->
                    <RowDefinition Height="155"/>

                    <!-- Row 3: Queue title -->
                    <RowDefinition Height="70"/>

                    <!-- Row 4: Queue panel -->
                    <RowDefinition Height="140"/>

                    <!-- Row 5: Recent transactions title -->
                    <RowDefinition Height="70"/>

                    <!-- Row 6: Recent transactions panel -->
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <!-- Header and search -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                    Text="Dashboard"
                                    FontSize="30"
                                    FontWeight="Bold"
                                    Foreground="Black"/>

                        <TextBlock Grid.Row="1"
                                    Text="Overview of clinic operations"
                                    FontSize="20"
                                    Foreground="#7A7A7A"
                                    Margin="0,4,0,0"/>
                    </Grid>

                    <!-- Search box -->
                    <Grid Grid.Column="1"
                            Width="230"
                            Height="52"
                            HorizontalAlignment="Right">

                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Search user or patient ID"
                                    FontSize="14"
                                    Foreground="#8A8A8A"
                                    VerticalAlignment="Center"
                                    Margin="54,0,0,0"
                                    IsHitTestVisible="False">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <fa:IconBlock Icon="Search"
                                        FontSize="18"
                                        Foreground="#9A9A9A"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Left"
                                        Margin="18,0,0,0"/>
                    </Grid>
                </Grid>

                <!-- Top dashboard cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total patients card -->
                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="0,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Total Patients -->
                            <Grid Grid.Row="0"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#2F98D0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Users"
                                                    Foreground="White"
                                                    FontSize="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Total Patients"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding TotalPatients}"
                                                FontSize="24"
                                                Foreground="#50C878"/>
                                </Grid>
                            </Grid>

                            <!-- New Patients -->
                            <Grid Grid.Row="1"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#43B935"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="UserPlus"
                                                    Foreground="White"
                                                    FontSize="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="New Patients This Month"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding NewPatientsThisMonth}"
                                                FontSize="24"
                                                Foreground="#50C878"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Low stock card -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="70"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="25"/>
                            </Grid.RowDefinitions>

                            <!-- Low stock header -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#FF981D"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Box"
                                                    Foreground="White"
                                                    FontSize="32"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Low Stock Items"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="Most Urgent"
                                                FontSize="15"
                                                Foreground="#D21E1E"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>

                            <!-- Low stock list -->
                            <Grid Grid.Row="1"
                                    Margin="0,8,0,0">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                            Text="Items"
                                            FontWeight="Bold"
                                            FontSize="14"
                                            Margin="0,0,0,6"/>

                                <ItemsControl Grid.Row="1"
                                                ItemsSource="{Binding LowStockItems}">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                            Text="{Binding ItemName}"
                                                            FontSize="12"
                                                            TextWrapping="Wrap"
                                                            TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="1"
                                                            Text="{Binding QuantityLeft, StringFormat={}{0} Left}"
                                                            FontSize="12"
                                                            Foreground="#D21E1E"
                                                            HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <Button Grid.Row="2"
                                    Content="View All"
                                    Command="{Binding ViewInventoryCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <!-- Payments card -->
                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <!-- Pending Payments -->
                            <Grid Grid.Row="0"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="#D38C7F"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="ExclamationCircle"
                                                    Foreground="White"
                                                    FontSize="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Pending Payments"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding PendingPayments}"
                                                FontSize="24"
                                                Foreground="#C49D49"/>
                                </Grid>
                            </Grid>

                            <!-- Unpaid Balance -->
                            <Grid Grid.Row="1"
                                    VerticalAlignment="Center">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="60"
                                        Height="60"
                                        CornerRadius="14"
                                        Background="Black"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Receipt"
                                                    Foreground="White"
                                                    FontSize="34"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                                </Border>

                                <Grid Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                                Text="Unpaid Balance"
                                                FontSize="15"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Grid.Row="1"
                                                Text="{Binding TotalUnpaidBalance, StringFormat=₱ {0:N2}}"
                                                FontSize="15"
                                                Foreground="Red"
                                                FontWeight="Bold"
                                                TextWrapping="Wrap"
                                                TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Grid>

                            <Button Grid.Row="2"
                                    Content="View All"
                                    Command="{Binding ViewBillingCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Middle cards -->
                <Grid Grid.Row="2"
                        Margin="0,10,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent activity card -->
                    <Border Grid.Column="0"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="0,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="50"
                                        Height="50"
                                        CornerRadius="12"
                                        Background="#D23B3B"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">

                                    <fa:IconBlock Icon="Bullseye"
                                                Foreground="White"
                                                FontSize="30"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1"
                                        Text="Recent Activity Log"
                                        FontSize="17"
                                        TextWrapping="Wrap"
                                        VerticalAlignment="Center"
                                        Margin="4,0,0,0"/>
                            </Grid>

                            <!-- Scroll only inside the activity list -->
                            <ScrollViewer Grid.Row="1"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Disabled"
                                        CanContentScroll="False">

                                <ItemsControl ItemsSource="{Binding RecentActivities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}"
                                                    FontSize="12"
                                                    TextWrapping="Wrap"
                                                    Margin="0,0,0,3"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <Button Grid.Row="2"
                                    Content="View All"
                                    Command="{Binding ViewReportsCommand}"
                                    Style="{StaticResource ViewAllButtonStyle}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- Patient visits trend card -->
                    <Border Grid.Column="1"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,10,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                        Text="Patient Visits Trend"
                                        FontSize="17"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"/>

                            <fa:IconBlock Grid.Row="1"
                                            Icon="ChartBar"
                                            FontSize="46"
                                            Foreground="#8C8C8C"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2"
                                        Text="Line/Bar Chart"
                                        Foreground="#B5B5B5"
                                        HorizontalAlignment="Center"
                                        FontSize="12"/>

                            <TextBlock Grid.Row="3"
                                        Text="Monthly patient visualization"
                                        Foreground="#B5B5B5"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        TextWrapping="Wrap"
                                        TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Revenue summary card -->
                    <Border Grid.Column="2"
                            Style="{StaticResource DashboardCardStyle}"
                            Margin="10,0,0,0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                        Text="Revenue Summary"
                                        FontSize="17"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"/>

                            <fa:IconBlock Grid.Row="1"
                                            Icon="ChartLine"
                                            FontSize="46"
                                            Foreground="#8C8C8C"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2"
                                        Text="Area Chart"
                                        Foreground="#B5B5B5"
                                        HorizontalAlignment="Center"
                                        FontSize="12"/>

                            <TextBlock Grid.Row="3"
                                        Text="Monthly revenue trends"
                                        Foreground="#B5B5B5"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        TextWrapping="Wrap"
                                        TextAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Queue title -->
                <TextBlock Grid.Row="3"
                            Text="Queue"
                            FontSize="30"
                            FontWeight="Bold"
                            VerticalAlignment="Center"/>

                <!-- Queue panel -->
                <Border Grid.Row="4"
                        Style="{StaticResource DashboardCardStyle}"
                        Padding="16">

                    <DataGrid ItemsSource="{Binding TodayQueue}"
                            Style="{StaticResource DashboardDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No."
                                                Binding="{Binding QueueNumber}"
                                                Width="55"/>

                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding Time}"
                                                Width="90"/>

                            <DataGridTextColumn Header="Patient ID"
                                                Binding="{Binding PatientCode}"
                                                Width="100"/>

                            <DataGridTextColumn Header="Patient Name"
                                                Binding="{Binding PatientName}"
                                                Width="180"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding AppointmentType}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Treatment"
                                                Binding="{Binding Treatment}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Recent transactions title -->
                <TextBlock Grid.Row="5"
                            Text="Recent Patient Transactions"
                            FontSize="30"
                            FontWeight="Bold"
                            VerticalAlignment="Center"/>

                <!-- Transactions panel -->
                <Border Grid.Row="6"
                        Style="{StaticResource DashboardCardStyle}"
                        Padding="16">

                    <DataGrid ItemsSource="{Binding RecentTransactions}"
                            Style="{StaticResource DashboardDataGridStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding Time}"
                                                Width="90"/>

                            <DataGridTextColumn Header="Patient Name"
                                                Binding="{Binding PatientName}"
                                                Width="180"/>

                            <DataGridTextColumn Header="Service"
                                                Binding="{Binding Service}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Amount"
                                                Binding="{Binding Amount, StringFormat=₱ {0:N2}}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Payment Status"
                                                Binding="{Binding PaymentStatus}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- Right appointments panel -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="370"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Real appointment calendar -->
                <Grid Grid.Row="0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                                Text="Appointments"
                                FontSize="30"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                                Text="{Binding CurrentMonth}"
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#12A8EF"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,6"/>

                    <Viewbox Grid.Row="2"
                                Stretch="Uniform"
                                StretchDirection="Both"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Width="500"
                                Height="500">

                        <Calendar SelectedDate="{Binding SelectedCalendarDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    DisplayDate="{Binding SelectedCalendarDate, Mode=TwoWay}"
                                    FirstDayOfWeek="Sunday"
                                    Width="340"
                                    Height="245"/>
                    </Viewbox>
                </Grid>

                <!-- Today's appointment panel -->
                <Border Grid.Row="1"
                        Style="{StaticResource LargePanelStyle}"
                        Padding="22">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="80"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                    Text="TODAY’S APPOINTMENT"
                                    FontSize="28"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Center"/>

                        <Border Grid.Row="1"
                                Height="1"
                                Background="Black"
                                Margin="14,12,14,22"/>

                        <TextBlock Grid.Row="2"
                                    Text="{Binding SelectedAppointmentHeader}"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Margin="0,0,0,18"/>

                        <DataGrid Grid.Row="3"
                                    ItemsSource="{Binding SelectedDateAppointments}"
                                    Style="{StaticResource DashboardDataGridStyle}"
                                    ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                    CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto"
                                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                    ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME"
                                                    Binding="{Binding Time}"
                                                    Width="75"/>

                                <DataGridTextColumn Header="P-ID"
                                                    Binding="{Binding PatientCode}"
                                                    Width="75"/>

                                <DataGridTextColumn Header="PATIENT NAME"
                                                    Binding="{Binding PatientName}"
                                                    Width="150"/>

                                <DataGridTextColumn Header="TREATMENT"
                                                    Binding="{Binding Treatment}"
                                                    Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="4"
                                Style="{StaticResource HelpButtonStyle}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <fa:IconBlock Grid.Column="0"
                                                Icon="QuestionCircle"
                                                FontSize="36"
                                                Foreground="White"
                                                VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                            Text="HELP"
                                            FontSize="26"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>