<UserControl x:Class="CruzNeryClinic.Views.Shared.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="390"
             d:DesignHeight="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width"
                    Value="8"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <!-- Track -->
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <!-- The actual "Slider" piece -->
                                                <Border CornerRadius="4"
                                                        Background="#445577"
                                                        Opacity="0.6"
                                                        Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Reusable sidebar used by Dashboard, Users, Patients, Appointment, Billing, etc. -->
    <Border x:Name="SidebarRoot"
            Background="#223357"
            CornerRadius="0,15,15,0">

        <Grid>
            <Grid.RowDefinitions>
                <!-- Row 0: Clinic logo -->
                <RowDefinition Height="190"/>
                <!-- Row 1: Separator -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: User Information -->
                <RowDefinition Height="110"/>
                <!-- Row 3: Separator -->
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Buttons -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Clinic logo -->
            <Image Grid.Row="0"
                   Source="/Assets/Images/logo.png"
                   Width="180"
                   Height="180"
                   Margin="0,-10,0,0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Effect>
                    <DropShadowEffect Color="#000000"
                                        Direction="180"
                                      BlurRadius="5"
                                      ShadowDepth="5"
                                      Opacity="0.5"/>
                </Image.Effect>
            </Image>

            <!-- Separator -->
            <Rectangle Grid.Row="1"
                       Height="1"
                       Fill="#2E4470"
                       Margin="0,8,0,8"/>

            <!-- User information -->
            <Border Grid.Row="2"
                    Margin="18,6,18,6"
                    Background="#1A2B47"
                    CornerRadius="10"
                    Padding="12,10">
                <StackPanel>

                    <!-- Profile row: icon + name/role -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Border Width="38"
                                Height="38"
                                CornerRadius="19"
                                Background="#2E4470"
                                VerticalAlignment="Center">
                            <fa:IconBlock Icon="UserCircle"
                                          FontSize="20"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUserName, Mode=OneWay}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="{Binding CurrentUserRole, Mode=OneWay}"
                                       FontSize="12"
                                       Foreground="#8EAACB"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Height="1"
                               Fill="#2E4470"
                               Margin="0,8,0,8"/>

                    <!-- User ID row -->
                    <Grid>
                        <TextBlock Text="User ID:"
                                   FontSize="12"
                                   Foreground="#8EAACB"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentUserCode, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="White"
                                   Margin="8,0,0,0"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Separator -->
            <Rectangle Grid.Row="3"
                       Height="1"
                       Fill="#2E4470"
                       Margin="0,8,0,8"/>

            <!-- Menu buttons -->
            <ScrollViewer Grid.Row="4"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="6,5,10,0">

                    <!-- Dashboard -->
                    <Button Command="{Binding DashboardCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding DashboardBackground}"
                            Foreground="{Binding DashboardForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="ThLarge"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding DashboardForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding DashboardForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Manage Users: Admin only -->
                    <Button Command="{Binding ManageUsersCommand}"
                            Visibility="{Binding CanAccessAdminOnlyModules, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding ManageUsersBackground}"
                            Foreground="{Binding ManageUsersForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="UserCog"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding ManageUsersForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Manage Users"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ManageUsersForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Patients -->
                    <Button Command="{Binding PatientsCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding PatientsBackground}"
                            Foreground="{Binding PatientsForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Users"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding PatientsForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Patients"
                                       FontSize="16"

                                       FontWeight="SemiBold"
                                       Foreground="{Binding PatientsForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Appointment -->
                    <Button Command="{Binding AppointmentCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding AppointmentBackground}"
                            Foreground="{Binding AppointmentForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CalendarAlt"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding AppointmentForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Appointment"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding AppointmentForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Billing -->
                    <Button Command="{Binding BillingCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding BillingBackground}"
                            Foreground="{Binding BillingForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="CashRegister"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding BillingForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Billing"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding BillingForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Inventory -->
                    <Button Command="{Binding InventoryCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding InventoryBackground}"
                            Foreground="{Binding InventoryForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Box"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding InventoryForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Inventory"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding InventoryForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Maintenance: Admin only -->
                    <Button Command="{Binding MaintenanceCommand}"
                            Visibility="{Binding CanAccessAdminOnlyModules, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding MaintenanceBackground}"
                            Foreground="{Binding MaintenanceForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="Tools"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding MaintenanceForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Maintenance"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding MaintenanceForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reports: Admin only -->
                    <Button Command="{Binding ReportsCommand}"
                            Visibility="{Binding CanAccessAdminOnlyModules, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding ReportsBackground}"
                            Foreground="{Binding ReportsForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="ChartBar"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding ReportsForeground}"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Reports"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding ReportsForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Help: available to all roles -->
                    <Button Command="{Binding HelpCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Background="{Binding HelpBackground}"
                            Foreground="{Binding HelpForeground}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="QuestionCircle"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="{Binding HelpForeground}"
                                          VerticalAlignment="Center"/>

                            <TextBlock Text="Help"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding HelpForeground}"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Separator -->
                    <Rectangle Grid.Row="3"
                            Height="1"
                            Fill="#2E4470"
                            Margin="0,8,0,8"/>

                    <!-- Logout -->
                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarMenuButtonStyle}"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Icon="SignOutAlt"
                                          Width="32"
                                          FontSize="18"
                                          Foreground="White"
                                          VerticalAlignment="Center"/>
                            <TextBlock Text="Log Out"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Border>
</UserControl>