<UserControl
    x:Class="CruzNeryClinic.Views.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    d:DesignHeight="900"
    d:DesignWidth="1300"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Soft drop shadow for cards and panels (scoped to this view) -->
        <DropShadowEffect x:Key="CardDropShadow"
                          Color="#000000"
                          BlurRadius="14"
                          ShadowDepth="2"
                          Direction="270"
                          Opacity="0.16" />

        <!-- Adds the shadow to the shared table container, scoped to this view -->
        <Style x:Key="DashboardTableContainerStyle"
               TargetType="Border"
               BasedOn="{StaticResource DashboardTableContainerStyle}">
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}" />
        </Style>

        <!-- ── Tab button (unselected state) ── -->
        <Style x:Key="ReportTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="92" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#555555" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Filter button ── -->
        <Style x:Key="FilterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#444444" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="17"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chart card border -->
        <Style x:Key="ChartCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="#E8E8E8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Effect" Value="{StaticResource CardDropShadow}" />
        </Style>

        <!-- Table section header -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <!-- ── Custom range DatePickerTextBox sub-style (clears default chrome) ── -->
        <Style x:Key="ReportDatePickerTextBoxStyle" TargetType="DatePickerTextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid>
                            <ContentControl
                                x:Name="PART_Watermark"
                                Focusable="False"
                                Foreground="#A0A0A0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="Hidden" />
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Background="Transparent"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden"
                                VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Custom range DatePicker (rounded, app-themed) ── -->
        <Style x:Key="ReportDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="42" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DADADA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border
                            x:Name="DatePickerBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox
                                    x:Name="PART_TextBox"
                                    Grid.Column="0"
                                    Margin="10,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Focusable="True"
                                    FontSize="{TemplateBinding FontSize}"
                                    Foreground="{TemplateBinding Foreground}"
                                    Style="{StaticResource ReportDatePickerTextBoxStyle}"
                                    VerticalAlignment="Center" />
                                <Button
                                    x:Name="PART_Button"
                                    Grid.Column="1"
                                    Width="32"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False"
                                    VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent" CornerRadius="6" Padding="4">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="#F0F0F0" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <fa:IconBlock FontSize="13" Foreground="#777777" Icon="CalendarAlt" />
                                </Button>
                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Placement="Bottom"
                                    StaysOpen="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="DatePickerBorder" Property="BorderBrush" Value="#223357" />
                                <Setter TargetName="DatePickerBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <Grid Margin="26,24,18,12">
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="Auto" />
                <!-- Tab buttons -->
                <RowDefinition Height="Auto" />
                <!-- Filter bar -->
                <RowDefinition Height="Auto" />
                <!-- Content (charts + splitter + table) -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    FontSize="28"
                    FontWeight="Bold"
                    Text="Reports and Analytics" />
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="0"
                    FontSize="15"
                    Foreground="#7A7A7A"
                    Margin="0,2,0,0"
                    Text="Comprehensive clinic reports and data visualization" />

                <!-- Print Report Button (opens the print options dialog) -->
                <Button
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="1"
                    Height="38"
                    Padding="26,0"
                    VerticalAlignment="Center"
                    Command="{Binding OpenPrintOptionsCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#111111" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#333333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="8,0,5,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="White"
                            Icon="Print" />
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Print Report" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ═══════════════════════════════ TAB BUTTONS ══════════════════════════ -->
            <!-- Each button is its own card; gap columns create visible spacing between them -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Patient Visits -->
                <Button Grid.Column="0" Command="{Binding SelectPatientVisitsCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ReportTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPatientVisitsSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="Users" />
                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            HorizontalAlignment="Center"
                            Text="Patient Visits" />
                    </StackPanel>
                </Button>

                <!-- Transaction Reports -->
                <Button Grid.Column="2" Command="{Binding SelectTransactionReportsCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ReportTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTransactionReportsSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="PesoSign" />
                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            HorizontalAlignment="Center"
                            Text="Transaction Reports" />
                    </StackPanel>
                </Button>

                <!-- Inventory Reports -->
                <Button Grid.Column="4" Command="{Binding SelectInventoryReportsCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ReportTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInventoryReportsSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="BoxOpen" />
                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            HorizontalAlignment="Center"
                            Text="Inventory Reports" />
                    </StackPanel>
                </Button>

                <!-- User Activity Log -->
                <Button Grid.Column="6" Command="{Binding SelectUserActivityLogCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ReportTabButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUserActivityLogSelected}" Value="True">
                                    <Setter Property="Background" Value="#223357" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="#223357" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconBlock
                            HorizontalAlignment="Center"
                            FontSize="28"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Icon="WaveSquare" />
                        <TextBlock
                            Margin="0,7,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            HorizontalAlignment="Center"
                            Text="User Activity Log" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- ═══════════════════════════════ FILTER BAR ═══════════════════════════ -->
            <Border
                Grid.Row="2"
                Margin="0,0,0,10"
                Padding="16,10,16,10"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ── Row 0: Controls ── -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Filter icon -->
                        <fa:IconBlock
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            FontSize="14"
                            Foreground="#555555"
                            Icon="Filter"
                            VerticalAlignment="Center" />

                        <!-- "Quick Filter:" -->
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#444444"
                            Text="Quick Filter:"
                            VerticalAlignment="Center" />

                        <!-- This Month -->
                        <Button
                            Grid.Column="2"
                            Margin="0,0,6,0"
                            Command="{Binding ApplyThisMonthCommand}"
                            Content="This Month">
                            <Button.Style>
                                <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThisMonthSelected}" Value="True">
                                            <Setter Property="Background" Value="#223357" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="#223357" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- This Year -->
                        <Button
                            Grid.Column="3"
                            Margin="0,0,6,0"
                            Command="{Binding ApplyThisYearCommand}"
                            Content="This Year">
                            <Button.Style>
                                <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThisYearSelected}" Value="True">
                                            <Setter Property="Background" Value="#223357" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="#223357" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Custom Range -->
                        <Button
                            Grid.Column="4"
                            Command="{Binding ApplyCustomRangeCommand}"
                            Content="Custom Range">
                            <Button.Style>
                                <Style BasedOn="{StaticResource FilterButtonStyle}" TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCustomRangeSelected}" Value="True">
                                            <Setter Property="Background" Value="#223357" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="BorderBrush" Value="#223357" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Spacer -->

                        <!-- Calendar icon -->
                        <fa:IconBlock
                            Grid.Column="6"
                            Margin="0,0,8,0"
                            FontSize="14"
                            Foreground="#555555"
                            Icon="CalendarDays"
                            VerticalAlignment="Center" />

                        <!-- "Data Range:" label -->
                        <TextBlock
                            Grid.Column="7"
                            Margin="0,0,10,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="#444444"
                            Text="Data Range:"
                            VerticalAlignment="Center" />

                        <!-- Adaptive date controls -->
                        <Grid Grid.Column="8">

                            <!-- This Month: Month + Year ComboBoxes -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThisMonthSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox
                                    Width="130"
                                    Margin="0,0,8,0"
                                    FontSize="12"
                                    VerticalContentAlignment="Center"
                                    ItemsSource="{Binding MonthNames}"
                                    Style="{StaticResource ExactStyleComboBox}"
                                    SelectedIndex="{Binding SelectedFilterMonthIndex, Mode=TwoWay}" />
                                <ComboBox
                                    Width="95"
                                    FontSize="12"
                                    VerticalContentAlignment="Center"
                                    ItemsSource="{Binding AvailableYears}"
                                    Style="{StaticResource ExactStyleComboBox}"
                                    SelectedItem="{Binding SelectedFilterYear, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- This Year: Year ComboBox only -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsThisYearSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ComboBox
                                    Width="95"
                                    FontSize="12"
                                    VerticalContentAlignment="Center"
                                    ItemsSource="{Binding AvailableYears}"
                                    Style="{StaticResource ExactStyleComboBox}"
                                    SelectedItem="{Binding SelectedFilterYear, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- Custom Range: From / To date pickers -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCustomRangeSelected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Margin="0,0,6,0" FontSize="12" Foreground="#888888" Text="From:" VerticalAlignment="Center" />
                                <DatePicker Width="140" Margin="0,0,10,0" Style="{StaticResource ReportDatePickerStyle}" SelectedDate="{Binding FilterFromDate, Mode=TwoWay}" />
                                <TextBlock Margin="0,0,6,0" FontSize="12" Foreground="#888888" Text="To:" VerticalAlignment="Center" />
                                <DatePicker Width="140" Style="{StaticResource ReportDatePickerStyle}" SelectedDate="{Binding FilterToDate, Mode=TwoWay}" />
                            </StackPanel>

                        </Grid>

                    </Grid>

                    <!-- ── Row 1: Showing label (bottom-right) ── -->
                    <TextBlock
                        Grid.Row="1"
                        Margin="0,6,0,0"
                        FontSize="12"
                        Foreground="#888888"
                        HorizontalAlignment="Right"
                        Text="{Binding ShowingText}" />
                </Grid>
            </Border>

            <!-- ═══════════════════════════════ CONTENT ══════════════════════════════ -->
            <Grid Grid.Row="3" x:Name="ReportContentArea">
                <Grid.RowDefinitions>
                    <!-- Charts area -->
                    <RowDefinition Height="2*" MinHeight="160" />
                    <!-- GridSplitter -->
                    <RowDefinition Height="8" />
                    <!-- Table area -->
                    <RowDefinition Height="3*" MinHeight="160" />
                </Grid.RowDefinitions>

                <!-- ─────────────────── CHARTS AREA (Row 0) ─────────────────── -->

                <!-- Patient Visits Charts -->
                <Border
                    Grid.Row="0"
                    Style="{StaticResource ChartCardStyle}"
                    Visibility="{Binding IsPatientVisitsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Margin="0,0,0,6"
                            Text="Patients Visit Trend" />
                        <Canvas
                            x:Name="PatientVisitCanvas"
                            Grid.Row="1"
                            ClipToBounds="True"
                            Background="Transparent"
                            Cursor="Hand"
                            Tag="patientVisit"
                            ToolTip="Click to view chart details"
                            MouseLeftButtonUp="Chart_Click"
                            SizeChanged="PatientVisitCanvas_SizeChanged" />
                    </Grid>
                </Border>

                <!-- Transaction Charts (two side-by-side) -->
                <Grid
                    Grid.Row="0"
                    Visibility="{Binding IsTransactionReportsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ChartCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,0,0,6"
                                Text="Revenue Trend" />
                            <Canvas
                                x:Name="RevenueTrendCanvas"
                                Grid.Row="1"
                                ClipToBounds="True"
                                Background="Transparent"
                                Cursor="Hand"
                                Tag="revenue"
                                ToolTip="Click to view chart details"
                                MouseLeftButtonUp="Chart_Click"
                                SizeChanged="RevenueTrendCanvas_SizeChanged" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ChartCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,0,0,6"
                                Text="Daily Transactions" />
                            <Canvas
                                x:Name="DailyTransactionsCanvas"
                                Grid.Row="1"
                                ClipToBounds="True"
                                Background="Transparent"
                                Cursor="Hand"
                                Tag="dailyTx"
                                ToolTip="Click to view chart details"
                                MouseLeftButtonUp="Chart_Click"
                                SizeChanged="DailyTransactionsCanvas_SizeChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Inventory Chart -->
                <Border
                    Grid.Row="0"
                    Style="{StaticResource ChartCardStyle}"
                    Visibility="{Binding IsInventoryReportsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Margin="0,0,0,6"
                            Text="Stock Levels vs Threshold" />
                        <Canvas
                            x:Name="InventoryBarCanvas"
                            Grid.Row="1"
                            ClipToBounds="True"
                            Background="Transparent"
                            Cursor="Hand"
                            Tag="inventory"
                            ToolTip="Click to view chart details"
                            MouseLeftButtonUp="Chart_Click"
                            SizeChanged="InventoryBarCanvas_SizeChanged" />
                    </Grid>
                </Border>

                <!-- Activity Log Charts (two side-by-side) -->
                <Grid
                    Grid.Row="0"
                    Visibility="{Binding IsUserActivityLogSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ChartCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,0,0,6"
                                Text="Activity Distribution by Type" />
                            <Canvas
                                x:Name="ActivityPieCanvas"
                                Grid.Row="1"
                                ClipToBounds="True"
                                Background="Transparent"
                                Cursor="Hand"
                                Tag="activityType"
                                ToolTip="Click to view chart details"
                                MouseLeftButtonUp="Chart_Click"
                                SizeChanged="ActivityPieCanvas_SizeChanged" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ChartCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,0,0,6"
                                Text="Activity by Module" />
                            <Canvas
                                x:Name="ActivityModuleCanvas"
                                Grid.Row="1"
                                ClipToBounds="True"
                                Background="Transparent"
                                Cursor="Hand"
                                Tag="activityModule"
                                ToolTip="Click to view chart details"
                                MouseLeftButtonUp="Chart_Click"
                                SizeChanged="ActivityModuleCanvas_SizeChanged" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- ─────────────── GRID SPLITTER (Row 1) ─────────────── -->
                <GridSplitter
                    Grid.Row="1"
                    Height="4"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="#D0D0D0"
                    Cursor="SizeNS"
                    ShowsPreview="True" />

                <!-- ─────────────────── TABLE AREA (Row 2) ─────────────────── -->
                <Grid Grid.Row="2">

                    <!-- Patient Visits Table -->
                    <Grid Visibility="{Binding IsPatientVisitsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="Patient Visits Report" />
                        <Border Grid.Row="1" Style="{StaticResource DashboardTableContainerStyle}">
                            <DataGrid
                                ItemsSource="{Binding PatientVisitsItems}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="1.2*" MinWidth="100" />
                                    <DataGridTemplateColumn Header="Patient ID" Width="1*" MinWidth="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PatientCode}" Foreground="#2F98D0" FontSize="13" VerticalAlignment="Center" Margin="6,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding PatientName}" Width="2*" MinWidth="140" />
                                    <DataGridTextColumn Header="Visit Type" Binding="{Binding VisitType}" Width="1.2*" MinWidth="100" />
                                    <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="1.5*" MinWidth="120" />
                                    <DataGridTextColumn Header="Dentist" Binding="{Binding Dentist}" Width="1.5*" MinWidth="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Transaction Table -->
                    <Grid Visibility="{Binding IsTransactionReportsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="Transaction Report" />
                        <Border Grid.Row="1" Style="{StaticResource DashboardTableContainerStyle}">
                            <DataGrid
                                ItemsSource="{Binding TransactionItems}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="1.2*" MinWidth="100" />
                                    <DataGridTextColumn Header="Receipt No." Binding="{Binding ReceiptNumber}" Width="1.8*" MinWidth="150" />
                                    <DataGridTemplateColumn Header="Patient ID" Width="1*" MinWidth="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PatientCode}" Foreground="#2F98D0" FontSize="13" VerticalAlignment="Center" Margin="6,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Patient Name" Binding="{Binding PatientName}" Width="2*" MinWidth="140" />
                                    <DataGridTextColumn Header="Service" Binding="{Binding Service}" Width="1.4*" MinWidth="120" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₱ {0:N2}'}" Width="1.2*" MinWidth="100" />
                                    <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMethod}" Width="1.4*" MinWidth="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Inventory Table -->
                    <Grid Visibility="{Binding IsInventoryReportsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="Inventory Reports" />
                        <Border Grid.Row="1" Style="{StaticResource DashboardTableContainerStyle}">
                            <DataGrid
                                ItemsSource="{Binding InventoryItems}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Item Name" Binding="{Binding ItemName}" Width="2.5*" MinWidth="160" />
                                    <DataGridTextColumn Header="Current Stock" Binding="{Binding CurrentStock}" Width="1.2*" MinWidth="110" />
                                    <DataGridTextColumn Header="Threshold" Binding="{Binding Threshold}" Width="1*" MinWidth="90" />
                                    <DataGridTextColumn Header="Last Restocked" Binding="{Binding LastRestocked}" Width="1.5*" MinWidth="130" />
                                    <DataGridTemplateColumn Header="Status" Width="1.2*" MinWidth="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Text="{Binding Status}"
                                                    Foreground="{Binding StatusColor}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    VerticalAlignment="Center"
                                                    Margin="6,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- Activity Log Table -->
                    <Grid Visibility="{Binding IsUserActivityLogSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Style="{StaticResource SectionHeaderStyle}"
                            Text="User Activity Log Reports" />
                        <Border Grid.Row="1" Style="{StaticResource DashboardTableContainerStyle}">
                            <DataGrid
                                ItemsSource="{Binding ActivityLogItems}"
                                Style="{StaticResource DashboardDataGridStyle}"
                                ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                                CellStyle="{StaticResource DashboardDataGridCellStyle}"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="1.8*" MinWidth="150" />
                                    <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="1*" MinWidth="80" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.2*" MinWidth="100" />
                                    <DataGridTemplateColumn Header="Action" Width="1*" MinWidth="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Text="{Binding Action}"
                                                    Foreground="{Binding ActionColor}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    VerticalAlignment="Center"
                                                    Margin="6,0" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="1.4*" MinWidth="110" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="3*" MinWidth="200" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!--  Print Options Dialog  -->
        <Grid Background="#66000000" Panel.ZIndex="40"
              Visibility="{Binding IsPrintOptionsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="420" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="White" CornerRadius="16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.25" ShadowDepth="3" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Print Options" FontSize="22" FontWeight="Bold" Foreground="#223357" />
                    <TextBlock Margin="0,6,0,18" FontSize="13" Foreground="#777777" TextWrapping="Wrap"
                               Text="Choose what to include in the printed report." />

                    <CheckBox Margin="0,0,0,10" FontSize="14" Foreground="#333333"
                              Content="Include charts" IsChecked="{Binding PrintIncludeCharts, Mode=TwoWay}" />
                    <CheckBox Margin="0,0,0,10" FontSize="14" Foreground="#333333"
                              Content="Include summary" IsChecked="{Binding PrintIncludeSummary, Mode=TwoWay}" />
                    <CheckBox Margin="0,0,0,14" FontSize="14" Foreground="#333333"
                              Content="Include detailed records" IsChecked="{Binding PrintIncludeDetailedRecords, Mode=TwoWay}" />

                    <StackPanel Orientation="Horizontal" Margin="22,0,0,4"
                                IsEnabled="{Binding PrintIncludeDetailedRecords}">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#444444" Text="Rows to print:" />
                        <ComboBox Width="80" Height="32" VerticalContentAlignment="Center"
                                  ItemsSource="{Binding PrintRowOptions}"
                                  SelectedItem="{Binding SelectedPrintRowLimit, Mode=TwoWay}"
                                  ToolTip="Maximum number of detail rows to print" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Width="110" Height="42" Margin="0,0,10,0"
                                Background="White" BorderBrush="#999999" BorderThickness="1"
                                Foreground="#333333" Content="Cancel"
                                Command="{Binding ClosePrintOptionsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Width="160" Height="42"
                                Background="#223357" Foreground="White" Content="Generate Preview"
                                Command="{Binding PrintReportCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--  Report Print Preview Overlay  -->
        <Grid Background="#66000000" Visibility="{Binding IsReportPrintPreviewOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="980"
                Height="720"
                Padding="26"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#223357"
                        Text="{Binding ReportPrintPreviewTitle}" />

                    <wv2:WebView2 x:Name="ReportPrintWebView" Grid.Row="2" />

                    <StackPanel
                        Grid.Row="4"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="120"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#223357"
                            Click="OpenReportPrintDialog_Click"
                            Content="Print"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="120"
                            Height="42"
                            Background="White"
                            BorderBrush="#111111"
                            BorderThickness="1"
                            Command="{Binding CloseReportPrintPreviewCommand}"
                            Content="Close"
                            FontWeight="Bold"
                            Foreground="Black"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Chart detail side panel (snaps to the right when a chart is clicked) -->
        <Grid Panel.ZIndex="50"
              Visibility="{Binding IsChartDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#22000000">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseChartDetailCommand}"/>
                </Border.InputBindings>
            </Border>
            <Border HorizontalAlignment="Right"
                    Width="440"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" Direction="180" ShadowDepth="2" Opacity="0.18"/>
                </Border.Effect>
                <Grid Margin="22,20,22,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ChartDetailTitle}" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Button HorizontalAlignment="Right" Width="34" Height="34"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Command="{Binding CloseChartDetailCommand}">
                            <fa:IconBlock Icon="Times" FontSize="18" Foreground="#666666"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Height="220" Background="#FAFAFA" CornerRadius="8" Padding="6">
                        <Canvas x:Name="ChartDetailCanvas" ClipToBounds="True" Background="Transparent"
                                SizeChanged="ChartDetailCanvas_SizeChanged"/>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,14,0,0">
                        <TextBlock Text="What this shows" FontWeight="SemiBold" FontSize="13" Foreground="#223357"/>
                        <TextBlock Text="{Binding ChartDetailDescription}" TextWrapping="Wrap"
                                   FontSize="12" Foreground="#555555" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock Text="Interpretation" FontWeight="SemiBold" FontSize="13" Foreground="#223357"/>
                        <TextBlock Text="{Binding ChartDetailInsight}" TextWrapping="Wrap"
                                   FontSize="12" Foreground="#555555" Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,14,0,0">
                        <TextBlock Text="Key figures" FontWeight="SemiBold" FontSize="13"
                                   Foreground="#223357" Margin="0,0,0,4"/>
                        <ItemsControl ItemsSource="{Binding ChartDetailFigures}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#666666"
                                                   HorizontalAlignment="Left"/>
                                        <TextBlock Text="{Binding Value}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="#111111" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
