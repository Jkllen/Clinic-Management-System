<UserControl
    x:Class="CruzNeryClinic.Views.PatientManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:patientViews="clr-namespace:CruzNeryClinic.Views.PatientManagement"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PatientManagement/PatientManagementStyles.xaml" />
                <ResourceDictionary Source="UserManagement/UserManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">

        <!-- Main content -->
        <Grid Margin="24,28,24,18">

            <Grid.RowDefinitions>
                <!-- Row 0: Page title and subtitle -->
                <RowDefinition Height="78" />

                <!-- Row 1: Summary cards -->
                <RowDefinition Height="150" />

                <!-- Row 2: Search, filter, sort, add patient -->
                <RowDefinition Height="88" />

                <!-- Row 3: Patient table -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- =========================
                 Row 0: Header
                 ========================= -->
            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Patient Management" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="View, Add &amp; Update Patient" />
            </StackPanel>

            <!-- =========================
                 Row 1: Summary cards
                 ========================= -->
            <Grid Grid.Row="1" Margin="20,0,20,0">

                <Grid.ColumnDefinitions>
                    <!-- Card 1 -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />

                    <!-- Card 2 -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />

                    <!-- Card 3 -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />

                    <!-- Card 4 -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Total Patients -->
                <Border
                    Grid.Column="0"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="34"
                                Foreground="White"
                                Icon="Users" />
                        </Border>

                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" Text="Total Patients" />
                            <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding TotalPatients}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- New Patients This Month -->
                <Border
                    Grid.Column="2"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <!-- Icon column -->
                            <ColumnDefinition Width="60"/>

                            <!-- Space between icon and text -->
                            <ColumnDefinition Width="18"/>

                            <!-- Text column, constrained so wrapping works -->
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="60"
                                Height="60"
                                Background="#2F98D0"
                                CornerRadius="14">

                            <fa:IconBlock Icon="UserPlus"
                                        Foreground="White"
                                        FontSize="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">

                            <TextBlock Text="New Patients This Month"
                                    FontSize="16"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="150"/>

                            <TextBlock Text="{Binding NewPatientsThisMonth}"
                                    Style="{StaticResource SummaryNumberStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- PWD/Senior Patients -->
                <Border
                    Grid.Column="4"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <!-- Icon column -->
                            <ColumnDefinition Width="60" />

                            <!-- Space between icon and text -->
                            <ColumnDefinition Width="18" />

                            <!-- Text column, constrained so wrapping works -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Icon="HandHoldingUsd" />
                        </Border>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center">

                            <TextBlock
                                FontSize="16"
                                Text="PWD/Senior Patients"
                                TextWrapping="Wrap"
                                TextTrimming="CharacterEllipsis"
                                MaxWidth="150" />

                            <TextBlock
                                Style="{StaticResource SummaryNumberStyle}"
                                Text="{Binding PwdSeniorPatients}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Patients With Balance -->
                <Border
                    Grid.Column="6"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <!-- Icon column -->
                            <ColumnDefinition Width="60" />

                            <!-- Space between icon and text -->
                            <ColumnDefinition Width="18" />

                            <!-- Text column, constrained so wrapping works -->
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Icon="HandHoldingUsd" />
                        </Border>

                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center">

                            <TextBlock
                                FontSize="16"
                                Text="Patients With Balance"
                                TextWrapping="Wrap"
                                TextTrimming="CharacterEllipsis"
                                MaxWidth="150" />

                            <TextBlock
                                Style="{StaticResource SummaryNumberStyle}"
                                Text="{Binding PatientsWithBalance}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- =========================
                 Row 2: Search, filter, sort, add patient
                 ========================= -->
            <Grid Grid.Row="2" Margin="0,12,0,0">

                <Grid.ColumnDefinitions>
                    <!-- Column 0: Search textbox -->
                    <ColumnDefinition Width="230" />

                    <!-- Column 1: Space between Search and Filter -->
                    <ColumnDefinition Width="28" />

                    <!-- Column 2: Filter dropdown -->
                    <ColumnDefinition Width="190" />

                    <!-- Column 3: Space between Filter and Sort -->
                    <ColumnDefinition Width="10" />

                    <!-- Column 4: Sort dropdown -->
                    <ColumnDefinition Width="220" />

                    <!-- Column 5: Flexible empty space -->
                    <ColumnDefinition Width="*" />

                    <!-- Column 6: Add New Patient button -->
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <!-- Search Patient -->
                <Grid
                    Grid.Column="0"
                    Height="52"
                    VerticalAlignment="Center">

                    <TextBox
                        Style="{StaticResource SearchTextBoxStyle}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="51,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="#8A8A8A"
                        IsHitTestVisible="False"
                        Text="Search Patient">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <fa:IconBlock
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="Black"
                        Icon="Search" />
                </Grid>

                <!-- Filter dropdown -->
                <ComboBox
                    Grid.Column="2"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Filter" />

                <!-- Sort dropdown -->
                <ComboBox
                    Grid.Column="4"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Sort By" />

                <!-- Add New Patient button -->
                <Button
                    Grid.Column="6"
                    Height="45"
                    VerticalAlignment="Center"
                    Background="#073C98"
                    Command="{Binding AddNewPatientCommand}"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource SecondaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="White"
                            Icon="UserPlus" />

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Add New Patient" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- =========================
                 Row 3: Patient table
                 No help button here because Help will be moved to sidebar
                 ========================= -->
            <Grid Grid.Row="3" Margin="0,0,0,18">

                <Border
                    Padding="20"
                    Style="{StaticResource LargePanelStyle}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- Row 0: Error message -->
                            <RowDefinition Height="Auto" />

                            <!-- Row 1: DataGrid -->
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Error message -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Patients table -->
                        <DataGrid
                            Grid.Row="1"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding Patients}"
                            MinRowHeight="42"
                            RowHeight="46"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItem="{Binding SelectedPatient, Mode=TwoWay}"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="105"
                                    Binding="{Binding PatientCode}"
                                    Header="Patient ID" />

                                <DataGridTextColumn
                                    Width="1.1*"
                                    MinWidth="130"
                                    Binding="{Binding LastName}"
                                    Header="Last Name" />

                                <DataGridTextColumn
                                    Width="1.1*"
                                    MinWidth="130"
                                    Binding="{Binding FirstName}"
                                    Header="First Name" />

                                <DataGridTextColumn
                                    Width="1.1*"
                                    MinWidth="135"
                                    Binding="{Binding MiddleName}"
                                    Header="Middle Name" />

                                <DataGridTextColumn
                                    Width="1.2*"
                                    MinWidth="140"
                                    Binding="{Binding PhoneNumber}"
                                    Header="Phone Number" />

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding DateOfBirthDisplay}"
                                    Header="DoB" />

                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="100"
                                    Binding="{Binding Gender}"
                                    Header="Gender" />

                                <DataGridTextColumn
                                    Width="1.1*"
                                    MinWidth="125"
                                    Binding="{Binding Treatment}"
                                    Header="Treatment" />

                                <!-- Patient History column
                                    Opens the Patient History view/modal.
                                    Future sections inside:
                                    1. Dental History
                                    2. Medical History -->
                                <DataGridTemplateColumn
                                    Width="1.1*"
                                    MinWidth="135"
                                    Header="Patient History">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button
                                                Command="{Binding DataContext.ViewPatientHistoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Foreground="#00A423"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Content="View" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- PWD Status column -->
                                <DataGridTemplateColumn
                                    Width="0.9*"
                                    MinWidth="110"
                                    Header="PWD Status">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="Bold"
                                                Text="{Binding PwdStatusText}"
                                                Foreground="{Binding PwdStatusBrush}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Actions column same complete style as User Management -->
                                <DataGridTemplateColumn
                                    Width="1.8*"
                                    MinWidth="220"
                                    Header="Actions">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">

                                                <!-- Update button -->
                                                <Button
                                                    Width="75"
                                                    Height="32"
                                                    Margin="0,0,8,0"
                                                    Background="#22C84A"
                                                    Command="{Binding DataContext.UpdatePatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}">

                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconBlock
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="13"
                                                            Foreground="White"
                                                            Icon="Edit" />

                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="Update" />
                                                    </StackPanel>
                                                </Button>

                                                <!-- Archive button -->
                                                <Button
                                                    Width="82"
                                                    Height="32"
                                                    Background="{Binding ArchiveButtonBrush}"
                                                    Command="{Binding DataContext.ArchivePatientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}">

                                                    <StackPanel
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal">

                                                        <fa:IconBlock
                                                            Margin="0,0,5,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="13"
                                                            Foreground="White"
                                                            Icon="{Binding ArchiveButtonIcon}" />

                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="{Binding ArchiveButtonText}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
                <!-- Add Patient Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsAddPatientOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <patientViews:AddPatientOverlayView
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Grid>

        <!-- Update Patient Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsUpdatePatientOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <patientViews:UpdatePatientOverlayView
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        </Grid>

        <!-- Patient History Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsPatientHistoryOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="760"
                MaxHeight="620"
                Padding="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="26">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="Patient History" />

                        <TextBlock
                            Margin="0,4,0,24"
                            FontSize="16"
                            Foreground="#777777"
                            Text="{Binding HistoryPatientName}" />

                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Dental History" />

                        <TextBlock
                            Margin="0,8,0,24"
                            FontSize="15"
                            Foreground="#333333"
                            Text="{Binding HistoryDentalHistory}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Medical History" />

                        <TextBlock
                            Margin="0,8,0,24"
                            FontSize="15"
                            Foreground="#333333"
                            Text="{Binding HistoryMedicalHistory}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Allergy / Medication Notes" />

                        <TextBlock
                            Margin="0,8,0,28"
                            FontSize="15"
                            Foreground="#333333"
                            Text="{Binding HistoryAllergyMedicationNotes}"
                            TextWrapping="Wrap" />

                        <Button
                            Width="120"
                            Height="44"
                            HorizontalAlignment="Right"
                            Background="#073C98"
                            Command="{Binding ClosePatientHistoryCommand}"
                            Content="Close"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>