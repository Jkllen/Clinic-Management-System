<UserControl x:Class="CruzNeryClinic.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900">

    <!--
        LoginView
        This is the login screen of the system.
        The layout is wrapped in a Viewbox so the card scales down when the window becomes smaller.
    -->

    <UserControl.Resources>

        <!-- Converts bool values into Visibility for error messages. -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Rounded textbox style for login inputs -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#9A9A9A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,0,20,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                            Margin="{TemplateBinding Padding}"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#223357"/>
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBoxBorder" Property="BorderBrush" Value="#223357"/>
                                <Setter TargetName="TextBoxBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 
            Modern link button style.
            Used for Forgot Password.
        -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                Text="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                FontSize="{TemplateBinding FontSize}"
                                FontWeight="{TemplateBinding FontWeight}"/>

                        <ControlTemplate.Triggers>
                            <!-- Changes color and underlines text when hovered -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="Foreground" Value="#223357"/>
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                            </Trigger>

                            <!-- Slight pressed feedback -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="LinkText" Property="Foreground" Value="#182641"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>

        <!-- 
            Background gradient based on Figma design:
            top-left #FFFFFF to bottom-right #91EFEF.
        -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0.00"/>
                <GradientStop Color="#91EFEF" Offset="1.00"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 
            Viewbox makes the login card scale properly on smaller window sizes.
            It keeps the card proportions while allowing the screen to remain flexible.
        -->
        <Viewbox Stretch="Uniform"
                 StretchDirection="DownOnly"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Margin="30">

            <!-- 
                This Grid is the original design canvas for the login card.
                The Viewbox scales this whole area down if needed.
            -->
            <Grid Width="560" Height="780">

                <!-- Login card background -->
                <Border CornerRadius="36"
                        Background="#EAFDFD"
                        BorderBrush="White"
                        BorderThickness="1"
                        Padding="44"
                        SnapsToDevicePixels="True">

                    <Border.Effect>
                        <DropShadowEffect Color="#707070"
                                          BlurRadius="10"
                                          ShadowDepth="4"
                                          Opacity="0.28"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 0: Logo area -->
                            <RowDefinition Height="285"/>

                            <!-- 1: Login title -->
                            <RowDefinition Height="Auto"/>
                            
                            <!-- 2: User ID title -->
                            <RowDefinition Height="Auto"/>

                            <!-- 3: User ID textbox -->
                            <RowDefinition Height="Auto"/>
                            
                            <!-- 4: Password title -->
                            <RowDefinition Height="Auto"/>

                            <!-- 5: Password textbox -->
                            <RowDefinition Height="Auto"/>

                            <!-- 6: Forgot password -->
                            <RowDefinition Height="Auto"/>

                            <!-- 7: Error message -->
                            <RowDefinition Height="40"/>

                            <!-- 8: Login button -->
                            <RowDefinition Height="70"/>

                            <!-- Extra bottom spacing -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Clinic logo -->
                        <Image Grid.Row="0"
                               Source="/Assets/Images/logo.png"
                               Width="280"
                               Height="280"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <!-- Login title -->
                        <TextBlock Grid.Row="1"
                                   Text="Login"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#111111"
                                   Margin="0,0,0,12"/>
                        
                        <!-- User ID title -->
                        <TextBlock Grid.Row="2"
                                   Text="User ID"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111111"
                                   Margin="0,0,0,12"/>
                        
                        <!-- User ID input with FontAwesome user icon -->
                        <Grid Grid.Row="3"
                              Height="58"
                              Margin="0,0,0,18">

                            <TextBox Style="{StaticResource LoginTextBoxStyle}"
                                     Text="{Binding LoginInput, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter your user ID"/>

                            <!-- Placeholder text -->
                            <TextBlock Text="Enter your user id"
                                       FontFamily="{StaticResource AppFont}"
                                       FontSize="22"
                                       Foreground="#8A8A8A"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="62,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LoginInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LoginInput}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <fa:IconBlock Icon="User"
                                          Foreground="#08CFA5"
                                          FontSize="26"
                                          Width="32"
                                          Height="32"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="18,2,0,0"/>
                        </Grid>
                        
                        <!-- Password title -->
                        <TextBlock Grid.Row="4"
                                   Text="Password"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#111111"
                                   Margin="0,0,0,12"/>

                        <!-- Password input with FontAwesome lock and eye-slash icon -->
                        <Grid Grid.Row="5"
                            Height="58"
                            Margin="0,0,0,8">

                            <!-- Hidden password mode -->
                            <PasswordBox x:Name="PasswordInput"
                                        Style="{StaticResource LoginPasswordBoxStyle}"
                                        PasswordChanged="PasswordInput_PasswordChanged"
                                        ToolTip="Enter your password"/>

                            <!-- Visible password mode -->
                            <TextBox x:Name="VisiblePasswordInput"
                                    Style="{StaticResource LoginTextBoxStyle}"
                                    TextChanged="VisiblePasswordInput_TextChanged"
                                    Visibility="Collapsed"
                                    ToolTip="Enter your password"/>

                            <!-- Placeholder text for password -->
                            <TextBlock x:Name="PasswordPlaceholder"
                                    Text="Enter your password"
                                    FontFamily="{StaticResource AppFont}"
                                    FontSize="22"
                                    Foreground="#8A8A8A"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    Margin="62,2,0,0"/>

                            <!-- Lock icon -->
                            <fa:IconBlock Icon="Lock"
                                        Foreground="#08CFA5"
                                        FontSize="25"
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="18,2,0,0"/>

                            <!-- Functional show/hide password button -->
                            <Button x:Name="TogglePasswordButton"
                                    Width="42"
                                    Height="42"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,2,8,0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    Cursor="Hand"
                                    Click="TogglePasswordButton_Click"
                                    Style="{StaticResource IconButtonStyle}">

                                <fa:IconBlock x:Name="PasswordEyeIcon"
                                            Icon="EyeSlash"
                                            Foreground="#666666"
                                            FontSize="22"
                                            Width="32"
                                            Height="32"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Margin="0,5,0,0"/>
                            </Button>
                        </Grid>

                        <!-- Forgot password button -->
                        <Button Grid.Row="6"
                                Content="Forgot Password?"
                                Command="{Binding ForgotPasswordCommand}"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="Black"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Padding="0"
                                Margin="0,2,0,20"
                                Style="{StaticResource LinkButtonStyle}"/>

                        <!-- Error message -->
                        <TextBlock Grid.Row="7"
                                   Text="{Binding ErrorMessage}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Foreground="#C62828"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                        <!-- Login button -->
                        <Button Grid.Row="8"
                                Content="Login"
                                Command="{Binding LoginCommand}"
                                Width="170"
                                Height="56"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,4,0,0"
                                Background="#223357"
                                Foreground="White"
                                FontFamily="{StaticResource AppFont}"
                                FontSize="28"
                                FontWeight="Bold"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Viewbox>
    </Grid>
</UserControl>