<UserControl
    x:Class="CruzNeryClinic.Views.UserManagement.UpdateUserOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UserManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <!--  Dim background  -->
        <Border Background="#99000000" />

        <!--  Main modal card  -->
        <Border
            Width="760"
            Height="640"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            BorderBrush="#9A9A9A"
            BorderThickness="1"
            CornerRadius="8">

            <Grid Margin="34,24,34,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="72" />
                </Grid.RowDefinitions>

                <!--  Header  -->
                <Grid Grid.Row="0">
                    <TextBlock
                        VerticalAlignment="Top"
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="Black"
                        Text="Update user" />

                    <Button
                        Width="42"
                        Height="42"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding CloseUpdateUserOverlayCommand}"
                        Style="{StaticResource IconButtonStyle}">
                        <fa:IconBlock
                            FontSize="26"
                            Foreground="Black"
                            Icon="Times" />
                    </Button>
                </Grid>

                <!--  Tab buttons  -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Height="40"
                        Background="{Binding UpdateAccountTabBrush}"
                        BorderBrush="#2E86DE"
                        BorderThickness="1"
                        Command="{Binding ShowUpdateAccountInfoTabCommand}"
                        Cursor="Hand"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{Binding UpdateAccountTabForeground}"
                        Style="{StaticResource SmallActionButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="1) Account Info" />
                        </StackPanel>
                    </Button>

                    <Button
                        Grid.Column="2"
                        Height="40"
                        Background="{Binding UpdatePasswordTabBrush}"
                        BorderBrush="#2E86DE"
                        BorderThickness="1"
                        Command="{Binding ShowUpdatePasswordTabCommand}"
                        Cursor="Hand"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{Binding UpdatePasswordTabForeground}"
                        Style="{StaticResource PrimaryButtonStyle}">
                        <TextBlock VerticalAlignment="Center" Text="2) Change Password" />
                    </Button>

                    <Button
                        Grid.Column="4"
                        Height="40"
                        Background="{Binding UpdateSecurityTabBrush}"
                        BorderBrush="#2E86DE"
                        BorderThickness="1"
                        Command="{Binding ShowUpdateSecurityTabCommand}"
                        Cursor="Hand"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{Binding UpdateSecurityTabForeground}"
                        Style="{StaticResource PrimaryButtonStyle}">
                        <TextBlock VerticalAlignment="Center" Text="3) Security" />
                    </Button>
                </Grid>

                <!--  Main content  -->
                <Grid Grid.Row="2">

                    <!--#region TAB 1: Account Information-->
                    <Grid Visibility="{Binding IsUpdateAccountInfoTabVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="105" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!--  Icon  -->
                                <ColumnDefinition Width="Auto" />
                                <!--  Space  -->
                                <ColumnDefinition Width="15" />
                                <!--  Content  -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="86"
                                Height="86"
                                Background="#FFF9FD"
                                BorderBrush="#F0D7EF"
                                BorderThickness="1"
                                CornerRadius="43">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="40"
                                    Foreground="#223357"
                                    Icon="UserEdit" />
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="Account Information" />

                                <TextBlock
                                    MaxWidth="600"
                                    Margin="0,8,0,0"
                                    FontSize="14"
                                    Foreground="#6F6F6F"
                                    Text="Update the selected user's name, contact number, and role."
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="90" />
                                <RowDefinition Height="90" />
                                <RowDefinition Height="90" />
                            </Grid.RowDefinitions>

                            <!--  First name  -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="First Name" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <TextBox
                                    Margin="0,8,0,0"
                                    Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                    Tag="Enter first name"
                                    Text="{Binding UpdateUserFirstName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Role  -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="Role" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <ComboBox
                                    Margin="0,8,0,0"
                                    ItemsSource="{Binding Roles}"
                                    SelectedItem="{Binding UpdateUserRole, Mode=TwoWay}"
                                    Style="{StaticResource ExactStyleComboBox}"
                                    Tag="Choose a role" />
                            </StackPanel>

                            <!--  Last name  -->
                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="Last Name" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <TextBox
                                    Margin="0,8,0,0"
                                    Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                    Tag="Enter last name"
                                    Text="{Binding UpdateUserLastName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Contact number  -->
                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="Contact Number" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <TextBox
                                    Margin="0,8,0,0"
                                    Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                    Tag="Enter contact number"
                                    Text="{Binding UpdateUserContactNumber, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <!--  Middle name  -->
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock
                                    FontSize="16"
                                    Foreground="#777777"
                                    Text="Middle Name" />

                                <TextBox
                                    Margin="0,8,0,0"
                                    Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                    Tag="Enter middle name"
                                    Text="{Binding UpdateUserMiddleName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <!--#endregion TAB 1-->

                    <!--  TAB 2: Change Password  -->
                    <Grid Visibility="{Binding IsUpdatePasswordTabVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <!--  Row 0: Change Password header with icon and description  -->
                            <RowDefinition Height="110" />

                            <!--  Row 1: Entire password form area  -->
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  #region Header section  -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!--  Icon column  -->
                                <ColumnDefinition Width="Auto" />
                                <!--  Space  -->
                                <ColumnDefinition Width="15" />
                                <!--  Text content column  -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Grid.Column="0"
                                Width="86"
                                Height="86"
                                Background="#FFF9FD"
                                BorderBrush="#F0D7EF"
                                BorderThickness="1"
                                CornerRadius="43">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="40"
                                    Foreground="#223357"
                                    Icon="UserLock" />
                            </Border>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="Change Password" />

                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="14"
                                    Foreground="#6F6F6F"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="600"
                                    Text="Choose a strong password you haven’t used before, then log in next time with it." />
                            </StackPanel>
                        </Grid>
                        <!-- #endregion Header-->

                        <!--  Form layout  -->
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <!--  Row 0: Password fields  -->
                                <RowDefinition Height="Auto" />
                                <!--  Row 1: Spacing between first row and second row  -->
                                <RowDefinition Height="20" />
                                <!--  Row 2: Second password row  -->
                                <RowDefinition Height="300" />
                                <!--  Row 3: Remaining flexible space  -->
                                <RowDefinition Height="Auto" />
                                <!--  Row 4: Bottom Area of Button  -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Hidden legacy field kept only for password-box synchronization compatibility.  -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Visibility="Collapsed">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="Legacy Password" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <Grid Margin="0,8,0,0">
                                    <PasswordBox
                                        x:Name="UpdateOldPasswordBox"
                                        PasswordChanged="UpdateOldPasswordBox_PasswordChanged"
                                        Style="{StaticResource AddUserOverlayPasswordBoxStyle}"
                                        Visibility="{Binding IsUpdateOldPasswordHidden, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Text="{Binding UpdateOldPassword, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="UpdateOldPasswordTextBox_TextChanged"
                                        Visibility="{Binding IsUpdateOldPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBlock
                                        Margin="16,0,48,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#A0A0A0"
                                        IsHitTestVisible="False"
                                        Text="Legacy password"
                                        Visibility="{Binding IsUpdateOldPasswordEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button
                                        Margin="0,0,14,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ToggleUpdateOldPasswordVisibilityCommand}"
                                        Style="{StaticResource IconButtonStyle}">
                                        <fa:IconBlock
                                            FontSize="20"
                                            Foreground="#8A8A8A"
                                            Icon="{Binding UpdateOldPasswordEyeIcon}" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!--  Confirm New Password  -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="Confirm New Password" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <Grid Margin="0,8,0,0">
                                    <PasswordBox
                                        x:Name="UpdateConfirmNewPasswordBox"
                                        PasswordChanged="UpdateConfirmNewPasswordBox_PasswordChanged"
                                        Style="{StaticResource AddUserOverlayPasswordBoxStyle}"
                                        Visibility="{Binding IsUpdateConfirmNewPasswordHidden, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Text="{Binding UpdateConfirmNewPassword, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="UpdateConfirmNewPasswordTextBox_TextChanged"
                                        Visibility="{Binding IsUpdateConfirmNewPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBlock
                                        Margin="16,0,48,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#A0A0A0"
                                        IsHitTestVisible="False"
                                        Text="Enter your confirm new password"
                                        Visibility="{Binding IsUpdateConfirmNewPasswordEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button
                                        Margin="0,0,14,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ToggleUpdateConfirmNewPasswordVisibilityCommand}"
                                        Style="{StaticResource IconButtonStyle}">
                                        <fa:IconBlock
                                            FontSize="20"
                                            Foreground="#8A8A8A"
                                            Icon="{Binding UpdateConfirmNewPasswordEyeIcon}" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!--  New Password  -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock FontSize="16" Foreground="#777777">
                                    <Run Text="New Password" />
                                    <Run Foreground="#E53935" Text=" *" />
                                </TextBlock>

                                <Grid Margin="0,8,0,0">
                                    <PasswordBox
                                        x:Name="UpdateNewPasswordBox"
                                        PasswordChanged="UpdateNewPasswordBox_PasswordChanged"
                                        Style="{StaticResource AddUserOverlayPasswordBoxStyle}"
                                        Visibility="{Binding IsUpdateNewPasswordHidden, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Text="{Binding UpdateNewPassword, UpdateSourceTrigger=PropertyChanged}"
                                        TextChanged="UpdateNewPasswordTextBox_TextChanged"
                                        Visibility="{Binding IsUpdateNewPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <TextBlock
                                        Margin="16,0,48,0"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#A0A0A0"
                                        IsHitTestVisible="False"
                                        Text="Enter your new password"
                                        Visibility="{Binding IsUpdateNewPasswordEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

                                    <Button
                                        Margin="0,0,14,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Command="{Binding ToggleUpdateNewPasswordVisibilityCommand}"
                                        Style="{StaticResource IconButtonStyle}">
                                        <fa:IconBlock
                                            FontSize="20"
                                            Foreground="#8A8A8A"
                                            Icon="{Binding UpdateNewPasswordEyeIcon}" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!--  Password Rules / Helper  -->
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,6,0,0">
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Foreground="#E53935"
                                    Text="Please add all necessary characters to create&#x0a;safe password."
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="13"
                                    Foreground="{Binding UpdateMinLengthRuleBrush}"
                                    Text="• Minimum characters of 12" />

                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="13"
                                    Foreground="{Binding UpdateUppercaseRuleBrush}"
                                    Text="• One uppercase character" />

                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="13"
                                    Foreground="{Binding UpdateLowercaseRuleBrush}"
                                    Text="• One lowercase character" />

                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="13"
                                    Foreground="{Binding UpdateSpecialCharRuleBrush}"
                                    Text="• One special character" />

                                <TextBlock
                                    Margin="0,2,0,0"
                                    FontSize="13"
                                    Foreground="{Binding UpdateNumberRuleBrush}"
                                    Text="• One number" />
                            </StackPanel>
                        </Grid>

                    </Grid>

                    <!--  TAB 3: Security  -->
                    <Grid Visibility="{Binding IsUpdateSecurityTabVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Grid.RowDefinitions>
                            <!--  Row 0: Security header  -->
                            <RowDefinition Height="110" />

                            <!--  Row 1: Scrollable security questions area  -->
                            <RowDefinition Height="*" />

                        </Grid.RowDefinitions>

                        <!--
                            =========================
                            Row 0: Header section
                            =========================
                        -->
                        <StackPanel
                            Grid.Row="0"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">

                            <Border
                                Width="86"
                                Height="86"
                                Background="#FFF9FD"
                                BorderBrush="#F0D7EF"
                                BorderThickness="1"
                                CornerRadius="43">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="40"
                                    Foreground="#223357"
                                    Icon="UserShield" />
                            </Border>

                            <StackPanel Margin="20,10,0,0">
                                <TextBlock
                                    FontSize="28"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Text="Security Questions" />

                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontSize="18"
                                    Foreground="#6F6F6F"
                                    Text="Change the selected user's password recovery questions." />
                            </StackPanel>
                        </StackPanel>

                        <!--
                            =========================
                            Row 1: Scrollable content
                            Only this part scrolls
                            =========================
                        -->
                        <ScrollViewer
                            Grid.Row="1"
                            Margin="0,18,0,0"
                            Padding="0,0,10,0"
                            CanContentScroll="True"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">

                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <!--  Question 1  -->
                                    <RowDefinition Height="120" />

                                    <!--  Space  -->
                                    <RowDefinition Height="5" />

                                    <!--  Question 2  -->
                                    <RowDefinition Height="120" />

                                    <!--  Space  -->
                                    <RowDefinition Height="5" />

                                    <!--  Question 3  -->
                                    <RowDefinition Height="120" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <!--  Left side: dropdown  -->
                                    <ColumnDefinition Width="1.45*" />

                                    <!--  Space  -->
                                    <ColumnDefinition Width="32" />

                                    <!--  Right side: answer  -->
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <!--
                                    =========================
                                    SECURITY QUESTION 1
                                    =========================
                                -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 1:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />

                                    <ComboBox
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding UpdateSelectedSecurityQuestion1, Mode=TwoWay}"
                                        Style="{StaticResource AddUserOverlayComboBoxStyle}"
                                        Tag="Choose a security question" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="0,34,0,0">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="13"
                                        Foreground="#777777"
                                        Text="Answer" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding UpdateSecurityAnswer1, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--
                                    =========================
                                    SECURITY QUESTION 2
                                    =========================
                                -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 2:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />

                                    <ComboBox
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding UpdateSelectedSecurityQuestion2, Mode=TwoWay}"
                                        Style="{StaticResource AddUserOverlayComboBoxStyle}"
                                        Tag="Choose a security question" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,34,0,0">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="13"
                                        Foreground="#777777"
                                        Text="Answer" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding UpdateSecurityAnswer2, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--
                                    =========================
                                    SECURITY QUESTION 3
                                    =========================
                                -->
                                <StackPanel Grid.Row="4" Grid.Column="0">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 3:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>

                                    <TextBlock
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />

                                    <ComboBox
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding UpdateSelectedSecurityQuestion3, Mode=TwoWay}"
                                        Style="{StaticResource AddUserOverlayComboBoxStyle}"
                                        Tag="Choose a security question" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="0,34,0,0">
                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="13"
                                        Foreground="#777777"
                                        Text="Answer" />

                                    <TextBox
                                        Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding UpdateSecurityAnswer3, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!--  Error and Save Button  -->
                <Grid Grid.Row="3">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#C62828"
                        Text="{Binding UpdateUserErrorMessage}"
                        TextWrapping="Wrap"
                        Visibility="{Binding HasUpdateUserError, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!--  Save Account Info button  -->
                    <Button
                        Width="170"
                        Height="48"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#223357"
                        Command="{Binding SaveUpdateAccountInfoCommand}"
                        Content="Save Changes"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SmallActionButtonStyle}"
                        Visibility="{Binding IsUpdateAccountInfoTabVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!--  Save Password button  -->
                    <Button
                        Width="250"
                        Height="48"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#223357"
                        Command="{Binding SaveUpdatePasswordCommand}"
                        Content="Save new password"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SmallActionButtonStyle}"
                        Visibility="{Binding IsUpdatePasswordTabVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <!--  Save Security button  -->
                    <Button
                        Width="170"
                        Height="48"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#223357"
                        Command="{Binding SaveUpdateSecurityCommand}"
                        Content="Save Changes"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Style="{StaticResource SmallActionButtonStyle}"
                        Visibility="{Binding IsUpdateSecurityTabVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>

                <!--  Admin Password Prompt  -->
                <Grid
                    Grid.RowSpan="4"
                    Panel.ZIndex="18"
                    Visibility="{Binding IsAdminPasswordPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Border Background="#88FFFFFF" />

                    <Border
                        Width="420"
                        Padding="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        BorderBrush="#9A9A9A"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="Bold"
                                        Foreground="#111111"
                                        Text="Admin Authorization" />

                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="13"
                                        Foreground="#777777"
                                        Text="Enter the current admin password to save this password change."
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <Button
                                    Grid.Column="1"
                                    Width="32"
                                    Height="32"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding CancelAdminPasswordPromptCommand}"
                                    Cursor="Hand">
                                    <fa:IconBlock
                                        FontSize="16"
                                        Foreground="#555555"
                                        Icon="Times" />
                                </Button>
                            </Grid>

                            <TextBlock
                                Margin="0,20,0,6"
                                FontSize="14"
                                Foreground="#777777"
                                Text="Admin Password *" />

                            <Grid>
                                <PasswordBox
                                    x:Name="UpdateAdminPasswordBox"
                                    PasswordChanged="UpdateAdminPasswordBox_PasswordChanged"
                                    Style="{StaticResource AddUserOverlayPasswordBoxStyle}"
                                    Visibility="{Binding IsUpdateAdminPasswordHidden, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <TextBox
                                    Style="{StaticResource AddUserOverlayTextBoxStyle}"
                                    Text="{Binding UpdateAdminPassword, UpdateSourceTrigger=PropertyChanged}"
                                    TextChanged="UpdateAdminPasswordTextBox_TextChanged"
                                    Visibility="{Binding IsUpdateAdminPasswordVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <TextBlock
                                    Margin="16,0,48,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="#A0A0A0"
                                    IsHitTestVisible="False"
                                    Text="Enter admin password"
                                    Visibility="{Binding IsUpdateAdminPasswordEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <Button
                                    Margin="0,0,14,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ToggleUpdateAdminPasswordVisibilityCommand}"
                                    Style="{StaticResource IconButtonStyle}">
                                    <fa:IconBlock
                                        FontSize="20"
                                        Foreground="#8A8A8A"
                                        Icon="{Binding UpdateAdminPasswordEyeIcon}" />
                                </Button>
                            </Grid>

                            <StackPanel
                                Margin="0,24,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">

                                <Button
                                    Width="100"
                                    Height="36"
                                    Margin="0,0,10,0"
                                    Background="#999999"
                                    Command="{Binding CancelAdminPasswordPromptCommand}"
                                    Content="Cancel"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Style="{StaticResource PrimaryButtonStyle}" />

                                <Button
                                    Width="150"
                                    Height="36"
                                    Background="#223357"
                                    Command="{Binding ConfirmUpdatePasswordWithAdminCommand}"
                                    Content="Authorize"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  Success Prompt  -->
                <Grid
                    Grid.RowSpan="4"
                    Panel.ZIndex="20"
                    Visibility="{Binding IsUpdateSuccessPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Border Background="#88FFFFFF" />

                    <Border
                        Width="360"
                        Height="200"
                        Padding="20"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="White"
                        BorderBrush="#9A9A9A"
                        BorderThickness="1"
                        CornerRadius="8">

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock
                                    Margin="0,0,10,0"
                                    FontSize="16"
                                    Foreground="#19C929"
                                    Icon="CheckSquare" />

                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{Binding UpdateSuccessTitle}"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock
                                Margin="32,12,0,0"
                                FontSize="12"
                                Foreground="#777777"
                                Text="{Binding UpdateSuccessMessage}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="32,12,0,0"
                                FontSize="11"
                                FontStyle="Italic"
                                Foreground="#999999"
                                Text="You may now close this window or continue updating this user."
                                TextWrapping="Wrap" />

                            <StackPanel
                                Margin="0,24,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">

                                <Button
                                    Width="90"
                                    Height="32"
                                    Margin="0,0,12,0"
                                    Background="#999999"
                                    Command="{Binding CloseUpdateUserOverlayCommand}"
                                    Content="Close"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Style="{StaticResource PrimaryButtonStyle}" />

                                <Button
                                    Width="110"
                                    Height="32"
                                    Background="#223357"
                                    Command="{Binding CloseUpdateSuccessPromptCommand}"
                                    Content="Continue"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
