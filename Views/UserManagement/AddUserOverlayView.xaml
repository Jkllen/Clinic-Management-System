<UserControl x:Class="CruzNeryClinic.Views.UserManagement.AddUserOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UserManagementStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

            <Style x:Key="GeneratedPasswordButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Background" Value="#223357" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="16,0" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border
                                x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.78" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

        <!--  Add New User Overlay  -->
        <Grid>
            <!--  Dim background  -->
            <Border Background="#99000000" />

            <!--  Main modal card  -->
            <Border
                Width="760"
                Height="740"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="#9A9A9A"
                BorderThickness="1"
                CornerRadius="8">

                <Grid Margin="34,24,34,24">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="58" />
                        <RowDefinition Height="58" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="72" />
                    </Grid.RowDefinitions>

                    <!--  Header  -->
                    <Grid Grid.Row="0">
                        <TextBlock
                            VerticalAlignment="Top"
                            FontSize="30"
                            FontWeight="Bold"
                            Foreground="Black"
                            Text="Add a new user" />

                        <Button
                            Width="42"
                            Height="42"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding CloseAddUserOverlayCommand}"
                            Style="{StaticResource IconButtonStyle}">
                            <fa:IconBlock
                                FontSize="26"
                                Foreground="Black"
                                Icon="Times" />
                        </Button>
                    </Grid>

                    <!--  Step progress bar  -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="18" />
                            <RowDefinition Height="30" />
                        </Grid.RowDefinitions>

                        <!--  Chevron segments  -->
                        <Canvas
                            Grid.Row="0"
                            Width="660"
                            Height="14"
                            HorizontalAlignment="Center">

                            <Polygon Fill="{Binding Step1SegmentBrush}" Points="0,0 250,0 260,7 250,14 0,14" />

                            <Polygon Fill="{Binding Step2SegmentBrush}" Points="250,0 500,0 510,7 500,14 250,14 260,7" />

                            <Polygon Fill="{Binding Step3SegmentBrush}" Points="500,0 660,0 670,7 660,14 500,14 510,7" />
                        </Canvas>

                        <!--  Step labels  -->
                        <Grid
                            Grid.Row="1"
                            Width="660"
                            HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="{Binding Step1TextBrush}"
                                Text="1) Basics" />

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="{Binding Step2TextBrush}"
                                Text="2) Security Questions" />

                            <TextBlock
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="{Binding Step3TextBrush}"
                                Text="3) Confirmation" />
                        </Grid>
                    </Grid>

                    <!--  Step content  -->
                    <Grid Grid.Row="2">

                        <!--  #region STEP 1: Basics  -->
                        <Grid Visibility="{Binding IsBasicsStepVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <!-- Let's Get Started -->
                                <RowDefinition Height="105" />
                                <!-- Form fields -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- #region Let's Get Started -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <!-- Icon -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Spacing -->
                                    <ColumnDefinition Width="15" />
                                    <!-- Content -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="86"
                                    Height="86"
                                    Background="#FFF9FD"
                                    BorderBrush="#F0D7EF"
                                    BorderThickness="1"
                                    CornerRadius="43">
                                    <fa:IconBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="40"
                                        Foreground="#223357"
                                        Icon="UserPlus" />
                                </Border>

                                <StackPanel 
                                    Grid.Column="2"
                                    VerticalAlignment="Center">

                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        Text="Let’s get started." />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="14"
                                        Foreground="#6F6F6F"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"
                                        MaxWidth="600"
                                        Text="Provide the required information then choose a role before proceeding to the next part." />
                                </StackPanel>
                            </Grid>
                            <!-- #endregion Let's Get Started -->

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="85" />
                                    <RowDefinition Height="85" />
                                    <RowDefinition Height="98" />
                                    <RowDefinition Height="15" />
                                    <RowDefinition Height="82" />
                                </Grid.RowDefinitions>
                            <!-- #region Fields -->
                                <!--  First name  -->
                                <StackPanel 
                                    Grid.Row="0" 
                                    Grid.Column="0">
                                    <TextBlock 
                                        FontSize="16" 
                                        Foreground="#777777">
                                        <Run Text="First name" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBox
                                        Margin="0,8,0,0"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your first name"
                                        Text="{Binding NewUserFirstName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--  Role  -->
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Role" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <ComboBox
                                        Margin="0,8,0,0"
                                        ItemsSource="{Binding Roles}"
                                        SelectedItem="{Binding NewUserRole, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Choose a role" />
                                </StackPanel>

                                <!--  Last name  -->
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Last name" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBox
                                        Margin="0,8,0,0"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your last name"
                                        Text="{Binding NewUserLastName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--  Contact number  -->
                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock FontSize="16" Foreground="#777777">
                                        <Run Text="Contact Number" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBox
                                        Margin="0,8,0,0"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your contact number"
                                        Text="{Binding NewUserContactNumber, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--  Middle name  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,0,0,18">
                                    <TextBlock
                                        FontSize="16"
                                        Foreground="#777777"
                                        Text="Middle name" />
                                    <TextBox
                                        Margin="0,8,0,0"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your middle name"
                                        Text="{Binding NewUserMiddleName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!--  Divider  -->
                                <Border
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Height="1"
                                    Margin="0,12,0,0"
                                    Background="#D0D0D0" />

                                <!--  Generate password  -->
                                <StackPanel
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,16,0,0">
                                    <TextBlock
                                        FontSize="16"
                                        Foreground="#777777"
                                        Text="Generate password" />

                                    <Button
                                        MinWidth="190"
                                        Height="36"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        Background="#223357"
                                        Command="{Binding GenerateNewUserPasswordCommand}"
                                        Content="Generate Password"
                                        Style="{StaticResource GeneratedPasswordButtonStyle}" />
                                </StackPanel>

                            <!-- #endregion Fields -->
                            </Grid>
                        </Grid>
                        <!--  #endregion STEP 1: Basics  -->

                        <!--  STEP 2: Security Questions  -->
                        <Grid Visibility="{Binding IsSecurityStepVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="110" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <!-- Icon -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Spacing -->
                                    <ColumnDefinition Width="15" />
                                    <!-- Content -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="86"
                                    Height="86"
                                    Background="#FFF9FD"
                                    BorderBrush="#F0D7EF"
                                    BorderThickness="1"
                                    CornerRadius="43">
                                    <fa:IconBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="40"
                                        Foreground="#223357"
                                        Icon="UserShield" />
                                </Border>

                                <StackPanel 
                                    Grid.Column="2"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        Text="Security Questions" />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="14"
                                        Foreground="#6F6F6F"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"
                                        MaxWidth="600"
                                        Text="Choose a question that only you can answer. Used for password recovery." />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,20,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="120" />
                                    <RowDefinition Height="120" />
                                </Grid.RowDefinitions>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.45*" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <!--  Q1  -->
                                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.45*" />
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 1:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        Foreground="#777777"
                                        Text="Answer" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding SelectedSecurityQuestion1, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Choose a security question" />
                                    <TextBox
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding SecurityAnswer1, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!--  Q2  -->
                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.45*" />
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 2:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        Foreground="#777777"
                                        Text="Answer" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding SelectedSecurityQuestion2, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Choose a security question" />
                                    <TextBox
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding SecurityAnswer2, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>

                                <!--  Q3  -->
                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.45*" />
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="16" Foreground="#777777">
                                        <Run Text="Security question 3:" />
                                        <Run Foreground="#E53935" Text=" *" />
                                    </TextBlock>
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        FontStyle="Italic"
                                        Foreground="#777777"
                                        Text="Choose a question:" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Margin="0,4,0,6"
                                        FontSize="12"
                                        Foreground="#777777"
                                        Text="Answer" />
                                    <ComboBox
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        DisplayMemberPath="QuestionText"
                                        ItemsSource="{Binding SecurityQuestions}"
                                        SelectedItem="{Binding SelectedSecurityQuestion3, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Choose a security question" />
                                    <TextBox
                                        Grid.Row="2"
                                        Grid.Column="2"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Tag="Enter your answer"
                                        Text="{Binding SecurityAnswer3, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>
                        </Grid>

                        <!--  STEP 3: Confirmation  -->
                        <Grid Visibility="{Binding IsConfirmationStepVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="110" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <!-- Icon -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Spacing -->
                                    <ColumnDefinition Width="15" />
                                    <!-- Content -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="86"
                                    Height="86"
                                    Background="#FFF9FD"
                                    BorderBrush="#F0D7EF"
                                    BorderThickness="1"
                                    CornerRadius="43">
                                    <fa:IconBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="44"
                                        Foreground="#223357"
                                        Icon="UserCircle" />
                                </Border>

                                <StackPanel 
                                    Grid.Column="2" 
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Foreground="Black"
                                        Text="Confirmation" />

                                    <TextBlock
                                        Margin="0,8,0,0"
                                        FontSize="14"
                                        Foreground="#6F6F6F"
                                        TextWrapping="Wrap"
                                        TextTrimming="CharacterEllipsis"
                                        MaxWidth="600"
                                        Text="Review user information before final submission." />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1" Background="#D0D0D0" />

                                <!--  User information confirmation  -->
                                <StackPanel Grid.Column="0" Margin="0,0,28,0">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="16"
                                        Foreground="#2E86DE"
                                        Text="User Information" />

                                    <UniformGrid Columns="2" Rows="4">
                                        <StackPanel Margin="0,0,10,14">
                                            <TextBlock Text="First name" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding NewUserFirstName, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="Role" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding NewUserRole, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,10,14">
                                            <TextBlock Text="Last name" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding NewUserLastName, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="Contact number" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding NewUserContactNumber, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,10,14">
                                            <TextBlock Text="Middle name" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding NewUserMiddleName, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,14">
                                            <TextBlock Text="Username" />
                                            <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding GeneratedUsername, Mode=OneWay}" />
                                        </StackPanel>

                                        <StackPanel Margin="0,0,10,14">
                                            <TextBlock Text="Password" />
                                            <Grid>
                                                <TextBox Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}" Text="{Binding ConfirmationPasswordDisplay, Mode=OneWay}" />

                                                <Button
                                                    Width="32"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding ToggleConfirmationPasswordVisibilityCommand}"
                                                    Style="{StaticResource IconButtonStyle}">
                                                    <fa:IconBlock
                                                        FontSize="16"
                                                        Foreground="#666666"
                                                        Icon="{Binding ConfirmationPasswordEyeIcon}" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>

                                <!--  Security question confirmation  -->
                                <StackPanel Grid.Column="2" Margin="28,0,0,0">
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="16"
                                        Foreground="#2E86DE"
                                        Text="Security question" />

                                    <TextBlock
                                        Foreground="#777777"
                                        Text="{Binding SelectedQuestionText1, StringFormat=1. {0}}"
                                        TextWrapping="Wrap" />
                                    <TextBox
                                        Width="190"
                                        Margin="16,6,0,36"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}"
                                        Text="{Binding SecurityAnswer1}" />

                                    <TextBlock
                                        Foreground="#777777"
                                        Text="{Binding SelectedQuestionText2, StringFormat=2. {0}}"
                                        TextWrapping="Wrap" />
                                    <TextBox
                                        Width="190"
                                        Margin="16,6,0,36"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}"
                                        Text="{Binding SecurityAnswer2}" />

                                    <TextBlock
                                        Foreground="#777777"
                                        Text="{Binding SelectedQuestionText3, StringFormat=3. {0}}"
                                        TextWrapping="Wrap" />
                                    <TextBox
                                        Width="190"
                                        Margin="16,6,0,0"
                                        HorizontalAlignment="Left"
                                        Style="{StaticResource UserOverlayReadOnlyTextBoxStyle}"
                                        Text="{Binding SecurityAnswer3}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!--  Error and bottom buttons  -->
                    <Grid Grid.Row="3">

                        <!--  Add user validation error  -->
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding AddUserErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasAddUserError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  Back button: hidden on Step 1, visible on Step 2 and Step 3  -->
                        <Button
                            Width="120"
                            Height="48"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Background="#B6B6B6"
                            Command="{Binding PreviousStepCommand}"
                            Content="Back"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Visibility="{Binding IsBackButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  Next button: visible on Step 1 and Step 2 only  -->
                        <Button
                            Width="120"
                            Height="48"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#223357"
                            Command="{Binding NextStepCommand}"
                            Content="Next"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Visibility="{Binding IsNextButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  Add User button: visible on Step 3 only  -->
                        <Button
                            Width="150"
                            Height="48"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#223357"
                            Command="{Binding SaveNewUserCommand}"
                            Content="Add User"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Visibility="{Binding IsAddUserButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <!-- Generated password prompt -->
                    <Grid
                        Grid.RowSpan="4"
                        Panel.ZIndex="18"
                        Visibility="{Binding IsGeneratedPasswordPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Border
                            Width="420"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="White"
                            BorderBrush="#DADADA"
                            BorderThickness="1"
                            CornerRadius="8">

                            <StackPanel>
                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="#111111"
                                    Text="Temporary password generated" />

                                <TextBlock
                                    Margin="0,8,0,14"
                                    FontSize="12"
                                    Foreground="#777777"
                                    Text="Copy this password. It will also appear in the confirmation step."
                                    TextWrapping="Wrap" />

                                <Grid>
                                    <TextBox
                                        Height="42"
                                        Padding="12,0,88,0"
                                        IsReadOnly="True"
                                        Style="{StaticResource UserOverlayTextBoxStyle}"
                                        Text="{Binding NewUserPassword, Mode=OneWay}" />

                                    <Button
                                        Width="76"
                                        Height="30"
                                        Margin="0,0,6,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Background="#223357"
                                        Command="{Binding CopyGeneratedPasswordCommand}"
                                        Content="Copy"
                                        Style="{StaticResource GeneratedPasswordButtonStyle}" />
                                </Grid>

                                <Button
                                    Width="90"
                                    Height="34"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Right"
                                    Background="#223357"
                                    Command="{Binding CloseGeneratedPasswordPromptCommand}"
                                    Content="Done"
                                    Style="{StaticResource GeneratedPasswordButtonStyle}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  Success prompt in Add User Overlay -->
                    <Grid
                        Grid.RowSpan="4"
                        Panel.ZIndex="20"
                        Visibility="{Binding IsSuccessPromptVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Border Background="#88FFFFFF" />

                        <Border
                            Width="Auto"
                            Height="Auto"
                            Padding="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="White"
                            BorderBrush="#9A9A9A"
                            BorderThickness="1"
                            CornerRadius="8">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- Header -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Content -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Button -->
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <!-- Icon -->
                                    <ColumnDefinition Width="Auto" />
                                    <!-- Spacing -->
                                    <ColumnDefinition Width="10" />
                                    <!-- Content -->
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border 
                                    Grid.Column="0"
                                    Width="46"
                                    Height="46"
                                    CornerRadius="20"
                                    Background="#FFF9FD"
                                    BorderBrush="#F0D7EF">
                                    <fa:IconBlock
                                        FontSize="26"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="#19C929"
                                        Icon="CheckSquare" />
                                </Border>

                                <StackPanel
                                    Grid.Column="2"
                                    VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Text="User created successfully"
                                        TextWrapping="Wrap"
                                        TextTrimming="WordEllipsis"
                                        MaxWidth="300" />
                                </StackPanel>
                            </Grid>


                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <!-- User Display Name -->
                                    <RowDefinition Height="Auto" />
                                    <!-- Instruction -->
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                
                                <StackPanel 
                                    Grid.Row="0"
                                    VerticalAlignment="Center">

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="#777777"
                                        Text="{Binding CreatedUserDisplayName, StringFormat={}{0} has been added as user.}"
                                        TextTrimming="WordEllipsis"
                                        TextWrapping="Wrap"
                                        MaxWidth="300" />
                                </StackPanel>

                                <StackPanel
                                    Grid.Row="1"
                                    VerticalAlignment="Center">

                                    <TextBlock
                                        Margin="32,12,0,0"
                                        FontSize="11"
                                        FontStyle="Italic"
                                        Foreground="#999999"
                                        Text="Copy this temporary password before closing this prompt."
                                        TextWrapping="Wrap" />

                                    <Grid Margin="32,12,0,0" MaxWidth="300">
                                        <TextBox
                                            Height="38"
                                            Padding="12,0,88,0"
                                            IsReadOnly="True"
                                            Style="{StaticResource UserOverlayTextBoxStyle}"
                                            Text="{Binding CreatedTemporaryPassword, Mode=OneWay}" />

                                        <Button
                                            Width="76"
                                            Height="28"
                                            Margin="0,0,6,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Background="#223357"
                                            Command="{Binding CopyCreatedPasswordCommand}"
                                            Content="Copy"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <StackPanel
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">

                                    <Button
                                        Width="70"
                                        Height="30"
                                        Margin="0,0,12,0"
                                        Background="#999999"
                                        Command="{Binding CloseSuccessPromptCommand}"
                                        Content="Close"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Style="{StaticResource PrimaryButtonStyle}" />

                                    <Button
                                        Width="110"
                                        Height="30"
                                        Background="#223357"
                                        Command="{Binding RegisterAgainCommand}"
                                        Content="Register again?"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
</UserControl>

