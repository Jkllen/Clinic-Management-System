<UserControl x:Class="CruzNeryClinic.Views.MainShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             xmlns:shared="clr-namespace:CruzNeryClinic.Views.Shared"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="900">

    <!--
        MainShellView is the logged-in layout.
        The sidebar stays fixed.
        Only ModuleContent changes when clicking sidebar buttons.
    -->

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Storyboard x:Key="LoginSuccessToastInStoryboard">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                From="0"
                To="1"
                Duration="0:0:0.22" />
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                From="44"
                To="0"
                Duration="0:0:0.55">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.35" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                From="0.96"
                To="1"
                Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.25" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                From="0.96"
                To="1"
                Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.25" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <!-- Sidebar column scales with window size but stays within a usable range. -->
            <ColumnDefinition Width="0.28*" MinWidth="260" MaxWidth="390"/>

            <!-- Main content changes depending on selected module. -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <shared:SidebarView x:Name="Sidebar"
                            Grid.Column="0"
                            SelectedModule="{Binding SelectedModule, Mode=TwoWay}"/>

        <ContentControl x:Name="ModuleContent"
                        Grid.Column="1"
                        Content="{Binding CurrentModuleView}"/>

        <Grid
            Grid.ColumnSpan="2"
            Background="#99000000"
            Visibility="{Binding IsEmployeePrivacyAcknowledgementOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="760"
                MaxHeight="650"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="14">

                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="24"
                        Opacity="0.25"
                        ShadowDepth="4" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="Employee Privacy Notice" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="14"
                            Foreground="#64748B"
                            Text="Please review and acknowledge this notice before accessing the system."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Grid.Row="2"
                        Padding="18"
                        Background="#F8FAFC"
                        BorderBrush="#D8E2EE"
                        BorderThickness="1"
                        CornerRadius="10">

                        <ScrollViewer
                            MaxHeight="360"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">

                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>

                            <TextBlock
                                FontSize="14"
                                Foreground="#333333"
                                LineHeight="22"
                                Text="{Binding EmployeePrivacyNoticeText}"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>

                    <CheckBox
                        Grid.Row="4"
                        IsChecked="{Binding HasConfirmedEmployeePrivacyNotice}">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#111111"
                            Text="I have read and understood how my staff account and system activity data will be handled."
                            TextWrapping="Wrap" />
                    </CheckBox>

                    <Button
                        Grid.Row="6"
                        Width="240"
                        Height="44"
                        HorizontalAlignment="Right"
                        Background="#223357"
                        Command="{Binding AcknowledgeEmployeePrivacyCommand}"
                        Content="Acknowledge and Continue"
                        Foreground="White"
                        FontWeight="Bold"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.ColumnSpan="2"
            Panel.ZIndex="100"
            Width="330"
            MinHeight="96"
            Margin="0,0,34,34"
            Padding="18,16"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Background="#1F3B66"
            BorderBrush="#6FB8F9"
            BorderThickness="3,0,0,0"
            CornerRadius="4"
            Opacity="0"
            Visibility="{Binding IsLoginSuccessToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                    <TranslateTransform Y="0" />
                </TransformGroup>
            </Border.RenderTransform>

            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoginSuccessToastVisible}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource LoginSuccessToastInStoryboard}" />
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="16"
                    Direction="270"
                    Opacity="0.30"
                    ShadowDepth="4"
                    Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <fa:IconBlock
                    Grid.Column="0"
                    Icon="Check"
                    FontSize="22"
                    Foreground="#00FF66"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top" />

                <StackPanel Grid.Column="1">
                    <TextBlock
                        Text="Congratulations!"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White" />

                    <TextBlock
                        Margin="0,2,0,0"
                        Text="You've successfully logged in."
                        FontSize="13"
                        Foreground="#E8EEF8" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
