<UserControl
    x:Class="CruzNeryClinic.Views.PatientManagement.AddPatientOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PatientManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Width="920"
        MaxHeight="780"
        Padding="34"
        Background="White"
        CornerRadius="26">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}"
                    TargetType="{x:Type ScrollBar}" />
            </ScrollViewer.Resources>
            <StackPanel>

                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#111111"
                    Text="{Binding PatientFormTitle}" />

                <TextBlock
                    Margin="0,4,0,22"
                    FontSize="15"
                    Foreground="#777777"
                    Text="Enter the patient personal information, history, and initial visit details." />

                <TextBlock
                    Margin="0,0,0,14"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#C62828"
                    Text="{Binding PatientFormErrorMessage}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasPatientFormError, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Personal Information" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="First name *"
                        Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="Middle name"
                        Text="{Binding FormMiddleName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="Last name *"
                        Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBox
                        Grid.Row="2"
                        Grid.Column="2"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="Contact number *"
                        Text="{Binding FormPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />

                    <DatePicker
                        Grid.Row="4"
                        Grid.Column="0"
                        Height="46"
                        SelectedDate="{Binding FormDateOfBirth, Mode=TwoWay}" />

                    <ComboBox
                        Grid.Row="4"
                        Grid.Column="2"
                        ItemsSource="{Binding GenderOptions}"
                        SelectedItem="{Binding FormGender, Mode=TwoWay}"
                        Style="{StaticResource PatientOverlayComboBoxStyle}"
                        Tag="Gender *" />

                    <StackPanel
                        Grid.Row="6"
                        Grid.Column="0"
                        Orientation="Horizontal">

                        <CheckBox
                            VerticalAlignment="Center"
                            Content="PWD Patient"
                            FontSize="15"
                            IsChecked="{Binding FormIsPwd}" />

                        <CheckBox
                            Margin="24,0,0,0"
                            VerticalAlignment="Center"
                            Content="Senior Citizen"
                            FontSize="15"
                            IsChecked="{Binding FormIsSeniorCitizen}" />
                    </StackPanel>

                    <TextBox
                        Grid.Row="6"
                        Grid.Column="2"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="Address"
                        Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Patient History" />

                <TextBox
                    Height="90"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource PatientOverlayTextAreaStyle}"
                    Tag="Dental History / Treatment Notes"
                    Text="{Binding FormDentalHistory, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Height="90"
                    Margin="0,14,0,0"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource PatientOverlayTextAreaStyle}"
                    Tag="Medical History / Health Conditions"
                    Text="{Binding FormMedicalHistory, UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Height="90"
                    Margin="0,14,0,0"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Style="{StaticResource PatientOverlayTextAreaStyle}"
                    Tag="Allergy / Medication Notes"
                    Text="{Binding FormAllergyMedicationNotes, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Initial Visit" />

                <TextBox
                    Style="{StaticResource PatientOverlayTextBoxStyle}"
                    Tag="Initial Treatment / Service"
                    Text="{Binding FormInitialTreatment, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel
                    Margin="0,28,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="120"
                        Height="44"
                        Margin="0,0,12,0"
                        Background="#777777"
                        Command="{Binding CancelAddPatientCommand}"
                        Content="Cancel"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Width="150"
                        Height="44"
                        Background="#073C98"
                        Command="{Binding SaveNewPatientCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Icon="Save" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="Save Patient" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>