<UserControl
    x:Class="CruzNeryClinic.Views.PatientManagement.UpdatePatientOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PatientManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border
            Width="920"
            MaxHeight="780"
            Padding="34,28,12,34"
            Background="White"
            CornerRadius="26">

        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="0,0,18,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="{Binding PatientFormTitle}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="15"
                        Foreground="#777777"
                        Text="Update the selected patient information, medical background, and initial visit details." />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding CancelUpdatePatientCommand}"
                    Cursor="Hand">
                    <fa:IconBlock
                        FontSize="18"
                        Foreground="#555555"
                        Icon="Times" />
                </Button>
            </Grid>

        <ScrollViewer
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Resources>
                <Style
                    BasedOn="{StaticResource BlueDataGridScrollBarStyle}"
                    TargetType="{x:Type ScrollBar}" />
            </ScrollViewer.Resources>

            <StackPanel Margin="0,0,18,0">
                <!-- Personal Information -->
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Personal Information" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- First Name -->
                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="First Name *" />

                        <TextBox
                            Style="{StaticResource PatientOverlayTextBoxStyle}"
                            Tag="First name *"
                            Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Middle Name -->
                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Middle Name" />

                        <TextBox
                            Style="{StaticResource PatientOverlayTextBoxStyle}"
                            Tag="Middle name"
                            Text="{Binding FormMiddleName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Last Name -->
                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Last Name *" />

                        <TextBox
                            Style="{StaticResource PatientOverlayTextBoxStyle}"
                            Tag="Last name *"
                            Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Contact Number -->
                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Contact Number *" />

                        <TextBox
                            MaxLength="11"
                            Style="{StaticResource PatientOverlayTextBoxStyle}"
                            Tag="Contact number *"
                            Text="{Binding FormPhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!-- Date of Birth -->
                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Date of Birth *" />

                        <DatePicker
                            Height="46"
                            SelectedDate="{Binding FormDateOfBirth, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- Gender -->
                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Gender *" />

                        <ComboBox
                            ItemsSource="{Binding GenderOptions}"
                            SelectedItem="{Binding FormGender, Mode=TwoWay}"
                            Style="{StaticResource ExactStyleComboBox}"
                            Tag="Gender *" />
                    </StackPanel>

                    <!-- PWD / Senior -->
                    <StackPanel
                        Grid.Row="6"
                        Grid.Column="0">

                        <StackPanel Orientation="Horizontal">
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="PWD Patient"
                                FontSize="15"
                                IsChecked="{Binding FormIsPwd}" />

                            <CheckBox
                                Margin="24,0,0,0"
                                VerticalAlignment="Center"
                                Content="Senior Citizen"
                                FontSize="15"
                                IsEnabled="False"
                                IsChecked="{Binding FormIsSeniorCitizen, Mode=OneWay}" />
                            <TextBlock
                                Margin="24,0,0,0"
                                FontSize="15"
                                Foreground="#777777"
                                Text="{Binding CalculatedAgeDisplay}" />
                        </StackPanel>


                    </StackPanel>

                    <!-- Address -->
                    <StackPanel Grid.Row="6" Grid.Column="2">
                        <TextBlock
                            Style="{StaticResource PatientOverlayFieldLabelStyle}"
                            Text="Address" />

                        <TextBox
                            Style="{StaticResource PatientOverlayTextBoxStyle}"
                            Tag="Address"
                            Text="{Binding FormAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <!-- Medical Background -->
                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Medical Background" />

                <StackPanel Margin="0,0,0,14">
                    <CheckBox
                        Content="Patient has medical condition"
                        FontSize="15"
                        IsChecked="{Binding FormHasMedicalCondition}" />
                </StackPanel>

                <StackPanel Visibility="{Binding MedicalConditionNotesVisibility}">
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Medical Conditions / Health Notes" />

                    <TextBox
                        Style="{StaticResource PatientOverlayTextAreaStyle}"
                        Tag="Example: diabetes, heart condition, hypertension, asthma, etc."
                        Text="{Binding FormMedicalConditionNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Allergy Notes" />

                    <TextBox
                        Style="{StaticResource PatientOverlayTextAreaStyle}"
                        Tag="Example: medicine allergy, latex allergy, anesthesia reaction, etc."
                        Text="{Binding FormAllergyNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Current Medication" />

                    <TextBox
                        Style="{StaticResource PatientOverlayTextAreaStyle}"
                        Tag="Enter current medication if any"
                        Text="{Binding FormCurrentMedication, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel Margin="0,14,0,14">
                    <CheckBox
                        Content="Requires medical clearance"
                        FontSize="15"
                        IsChecked="{Binding FormRequiresMedicalClearance}" />
                </StackPanel>

                <StackPanel Visibility="{Binding ClearanceNotesVisibility}">
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Clearance Notes" />

                    <TextBox
                        Style="{StaticResource PatientOverlayTextAreaStyle}"
                        Tag="Enter clearance details or reminder"
                        Text="{Binding FormClearanceNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Initial Visit -->
                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Initial Visit Summary" />

                <TextBlock
                    Margin="0,0,0,14"
                    FontSize="13"
                    Foreground="#777777"
                    Text="Initial visit details are read-only here. New treatments should be recorded through appointments or completed visits later."
                    TextWrapping="Wrap" />

                <StackPanel>
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Initial Treatment / Service" />

                    <TextBox
                        IsReadOnly="True"
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Text="{Binding FormInitialTreatment}" />
                </StackPanel>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Initial Treatment Notes" />

                    <TextBox
                        IsReadOnly="True"
                        Style="{StaticResource PatientOverlayTextAreaStyle}"
                        Text="{Binding FormInitialTreatmentNotes}" />
                </StackPanel>

                <StackPanel
                    Margin="0,14,0,0"
                    Visibility="{Binding IsOtherServiceSelected, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock
                        Style="{StaticResource PatientOverlayFieldLabelStyle}"
                        Text="Other Treatment / Service *" />

                    <TextBox
                        Style="{StaticResource PatientOverlayTextBoxStyle}"
                        Tag="Type other treatment or service"
                        Text="{Binding OtherServiceName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel
                    Margin="0,28,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="120"
                        Height="44"
                        Margin="0,0,12,0"
                        Background="#777777"
                        Command="{Binding CancelUpdatePatientCommand}"
                        Content="Cancel"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Width="160"
                        Height="44"
                        Background="#073C98"
                        Command="{Binding SaveUpdatedPatientCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Icon="Save" />

                            <TextBlock
                                VerticalAlignment="Center"
                                FontWeight="Bold"
                                Text="Save Changes" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        </DockPanel>
        </Border>

        <Grid
            Width="920"
            MaxHeight="780"
            Background="#66000000"
            Visibility="{Binding IsUpdatePatientPromptOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="12">

                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="Patient Form" />

                    <TextBlock
                        Margin="0,12,0,22"
                        FontSize="14"
                        Foreground="#444444"
                        Text="{Binding UpdatePatientPromptMessage}"
                        TextWrapping="Wrap" />

                    <Button
                        Width="110"
                        Height="40"
                        HorizontalAlignment="Right"
                        Background="#073C98"
                        Command="{Binding CloseUpdatePatientPromptCommand}"
                        Content="OK"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
