<UserControl
    x:Class="CruzNeryClinic.Views.AppointmentManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appointmentViews="clr-namespace:CruzNeryClinic.Views.AppointmentManagement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PatientManagement/PatientManagementStyles.xaml" />
                <ResourceDictionary Source="UserManagement/UserManagementStyles.xaml" />
                <ResourceDictionary Source="AppointmentManagement/AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">

        <Grid Margin="24,28,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="230" />
                <RowDefinition Height="88" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Appointment Management" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="Manage Scheduled Appointments and Walk-in Visits" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- Summary cards area -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="18" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Width="60" Height="60" Background="#2F98D0" CornerRadius="14">
                                <fa:IconBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="White" Icon="CalendarDay" />
                            </Border>

                            <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="17" Text="Today’s Appointments" />
                                <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding TodaysAppointments}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="18" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Width="60" Height="60" Background="#2F98D0" CornerRadius="14">
                                <fa:IconBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="White" Icon="CheckCircle" />
                            </Border>

                            <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="17" Text="Completed Today" />
                                <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding CompletedToday}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Padding="18" Style="{StaticResource DashboardCardStyle}">
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <Border Width="60" Height="60" Background="#2F98D0" CornerRadius="14">
                                <fa:IconBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" Foreground="White" Icon="TimesCircle" />
                            </Border>

                            <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                                <TextBlock FontSize="17" Text="Cancelled Today" />
                                <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding CancelledToday}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Mini Appointment Calendar -->
                <Border Grid.Column="2" Padding="14" Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Calendar header -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PreviousCalendarMonthCommand}"
                                Cursor="Hand">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="#223357"
                                    Icon="ChevronLeft" />
                            </Button>

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="#111111"
                                Text="{Binding CalendarMonthTitle}" />

                            <Button
                                Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding NextCalendarMonthCommand}"
                                Cursor="Hand">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="#223357"
                                    Icon="ChevronRight" />
                            </Button>
                        </Grid>

                        <!-- Day names -->
                        <UniformGrid Grid.Row="1" Columns="7">
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="S" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="M" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="T" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="W" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="T" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="F" />
                            <TextBlock HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Text="S" />
                        </UniformGrid>

                        <!-- Calendar days -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="2"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.SelectCalendarDateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">

                                        <Border
                                            MinHeight="24"
                                            Background="{Binding DayBackground}"
                                            BorderBrush="{Binding DayBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">

                                            <Grid>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{Binding DayForeground}"
                                                    Text="{Binding DayNumber}" />

                                                <Border
                                                    Width="16"
                                                    Height="16"
                                                    Margin="0,-4,-4,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Background="#E31D1D"
                                                    CornerRadius="8"
                                                    Visibility="{Binding AppointmentCountVisibility}">

                                                    <TextBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="9"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="{Binding AppointmentCount}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="185" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Height="52"
                    VerticalAlignment="Center">
                    <TextBox Style="{StaticResource SearchTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="51,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="18"
                        Foreground="#8A8A8A"
                        IsHitTestVisible="False"
                        Text="Search">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <fa:IconBlock
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="Black"
                        Icon="Search" />
                </Grid>

                <ComboBox
                    Grid.Column="2"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Filter" />

                <ComboBox
                    Grid.Column="4"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Sort By" />

                <Button
                    Grid.Column="6"
                    Height="45"
                    Background="#073C98"
                    Command="{Binding OpenWalkInOverlayCommand}"
                    Foreground="White"
                    Style="{StaticResource SecondaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="0,0,8,0"
                            Foreground="White"
                            Icon="Walking" />
                        <TextBlock FontWeight="Bold" Text="Add Walk-in Visit" />
                    </StackPanel>
                </Button>

                <Button
                    Grid.Column="8"
                    Height="45"
                    Background="#073C98"
                    Command="{Binding OpenScheduledOverlayCommand}"
                    Foreground="White"
                    Style="{StaticResource SecondaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="0,0,8,0"
                            Foreground="White"
                            Icon="CalendarPlus" />
                        <TextBlock FontWeight="Bold" Text="Add Schedule" />
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,18">
                <Border Padding="20" Style="{StaticResource LargePanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,10"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="{Binding SelectedCalendarDateTitle}" />

                        <TextBlock
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <DataGrid
                            Grid.Row="2"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding Appointments}"
                            MinRowHeight="42"
                            RowHeight="46"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="0.7*"
                                    MinWidth="80"
                                    Binding="{Binding QueueNumberDisplay}"
                                    Header="Queue No." />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="105"
                                    Binding="{Binding PatientCode}"
                                    Header="Patient ID" />
                                <DataGridTextColumn
                                    Width="1.5*"
                                    MinWidth="170"
                                    Binding="{Binding PatientName}"
                                    Header="Patient Name" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Binding="{Binding AppointmentType}"
                                    Header="Type" />
                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="100"
                                    Binding="{Binding Category}"
                                    Header="Category" />
                                <DataGridTextColumn
                                    Width="1.4*"
                                    MinWidth="150"
                                    Binding="{Binding ServiceName}"
                                    Header="Service" />
                                <DataGridTextColumn
                                    Width="1.3*"
                                    MinWidth="145"
                                    Binding="{Binding DentistName}"
                                    Header="Dentist" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding AppointmentDateDisplay}"
                                    Header="Date" />
                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="95"
                                    Binding="{Binding AppointmentTimeDisplay}"
                                    Header="Time" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding WaitingDurationDisplay}"
                                    Header="Waiting Time" />
                                
                                <DataGridTemplateColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Header="Priority">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="{Binding PriorityBrush}"
                                                Text="{Binding PriorityDisplay}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Header="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="{Binding StatusBrush}"
                                                Text="{Binding Status}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Width="2.8*"
                                    MinWidth="330"
                                    Header="Actions">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                                <Button
                                                    Width="80"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="#073C98"
                                                    Command="{Binding DataContext.MarkArrivedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding MarkArrivedButtonVisibility}">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="Arrived" />
                                                </Button>
        
                                                <Button
                                                    Width="80"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="#777777"
                                                    Command="{Binding DataContext.MarkNoShowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding NoShowButtonVisibility}">
                                                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White" Text="No Show" />
                                                </Button>

                                                <Button
                                                    Width="70"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="#22C84A"
                                                    Command="{Binding DataContext.StartTreatmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding StartTreatmentButtonVisibility}">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="Start" />
                                                </Button>

                                                <Button
                                                    Width="80"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="#00A423"
                                                    Command="{Binding DataContext.CompleteAppointmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding CompleteButtonVisibility}">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="Complete" />
                                                </Button>

                                                <Button
                                                    Width="105"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="{Binding UrgentButtonBrush}"
                                                    Command="{Binding DataContext.ToggleUrgentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding UrgentButtonVisibility}">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="{Binding UrgentButtonText}" />
                                                </Button>

                                                <Button
                                                    Width="70"
                                                    Height="32"
                                                    Background="#E31D1D"
                                                    Command="{Binding DataContext.CancelAppointmentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding CancelButtonVisibility}">
                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="Cancel" />
                                                </Button>

                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding IsWalkInOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <appointmentViews:AddWalkInAppointmentOverlayView HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding IsScheduledOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <appointmentViews:AddScheduledAppointmentOverlayView HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

    </Grid>
</UserControl>
