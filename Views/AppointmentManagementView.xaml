<UserControl
    x:Class="CruzNeryClinic.Views.AppointmentManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:appointmentViews="clr-namespace:CruzNeryClinic.Views.AppointmentManagement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="PatientManagement/PatientManagementStyles.xaml" />
                <ResourceDictionary Source="UserManagement/UserManagementStyles.xaml" />
                <ResourceDictionary Source="AppointmentManagement/AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <!-- Soft drop shadow for cards and panels (scoped to this view) -->
            <DropShadowEffect x:Key="CardDropShadow"
                              Color="#000000"
                              BlurRadius="14"
                              ShadowDepth="2"
                              Direction="270"
                              Opacity="0.16" />

            <Style x:Key="DashboardCardStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource DashboardCardStyle}">
                <Setter Property="Effect" Value="{StaticResource CardDropShadow}" />
            </Style>

            <Style x:Key="LargePanelStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource LargePanelStyle}">
                <Setter Property="Effect" Value="{StaticResource CardDropShadow}" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">

        <Grid Margin="24,28,24,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="230" />
                <RowDefinition Height="88" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="Appointment Management" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="Manage Scheduled Appointments and Walk-in Visits" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!--  Summary cards area  -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="18"
                        Style="{StaticResource DashboardCardStyle}">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <!-- Icon column -->
                                <ColumnDefinition Width="60" />
                                <!-- Space between icon and text -->
                                <ColumnDefinition Width="18" />
                                <!-- Text column, constrained so wrapping works -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Border
                                Grid.Column="0"
                                Width="60"
                                Height="60"
                                Background="#2F98D0"
                                CornerRadius="14">
                                
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="32"
                                    Foreground="White"
                                    Icon="CalendarDay" />
                            </Border>

                            <StackPanel 
                                Grid.Column="2"
                                VerticalAlignment="Center">

                                <TextBlock 
                                    FontSize="17" 
                                    Text="Today’s Appointments"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="150" />
                                <TextBlock 
                                    Style="{StaticResource SummaryNumberStyle}" 
                                    Text="{Binding TodaysAppointments}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="18"
                        Style="{StaticResource DashboardCardStyle}">
                        
                        <Grid 
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <!-- Icon column -->
                                <ColumnDefinition Width="60" />
                                <!-- Space between icon and text -->
                                <ColumnDefinition Width="18" />
                                <!-- Text column, constrained so wrapping works -->
                                <ColumnDefinition Width="*" /> 
                            </Grid.ColumnDefinitions>
                            
                            <Border
                                Grid.Column="0"
                                Width="60"
                                Height="60"
                                Background="#2F98D0"
                                CornerRadius="14">
                                
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="32"
                                    Foreground="White"
                                    Icon="CheckCircle" />
                            </Border>

                            <StackPanel 
                                Grid.Column="2" 
                                VerticalAlignment="Center">

                                <TextBlock 
                                    FontSize="17" 
                                    Text="Completed Today"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="150"/>
                                <TextBlock 
                                    Style="{StaticResource SummaryNumberStyle}" 
                                    Text="{Binding CompletedToday}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="4"
                        Padding="18"
                        Style="{StaticResource DashboardCardStyle}">
                        
                        <Grid 
                            VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <!-- Icon column -->
                                <ColumnDefinition Width="60" />
                                <!-- Space between icon and text -->
                                <ColumnDefinition Width="18" />
                                <!-- Text column, constrained so wrapping works -->
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Border
                                Grid.Column="0"
                                Width="60"
                                Height="60"
                                Background="#2F98D0"
                                CornerRadius="14">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="32"
                                    Foreground="White"
                                    Icon="TimesCircle" />
                            </Border>

                            <StackPanel 
                                Grid.Column="2"
                                VerticalAlignment="Center">

                                <TextBlock 
                                    FontSize="17" 
                                    Text="Cancelled Today"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxWidth="150"/>
                                <TextBlock 
                                    Style="{StaticResource SummaryNumberStyle}" 
                                    Text="{Binding CancelledToday}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!--  Mini Appointment Calendar  -->
                <Border
                    Grid.Column="2"
                    Padding="14"
                    Style="{StaticResource DashboardCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Calendar header  -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding PreviousCalendarMonthCommand}"
                                Cursor="Hand">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="#223357"
                                    Icon="ChevronLeft" />
                            </Button>

                            <TextBlock
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="#111111"
                                Text="{Binding CalendarMonthTitle}" />

                            <Button
                                Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding NextCalendarMonthCommand}"
                                Cursor="Hand">
                                <fa:IconBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Foreground="#223357"
                                    Icon="ChevronRight" />
                            </Button>
                        </Grid>

                        <!--  Day names  -->
                        <UniformGrid Grid.Row="1" Columns="7">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="S" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="M" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="T" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="W" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="T" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="F" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                FontWeight="Bold"
                                Text="S" />
                        </UniformGrid>

                        <!--  Calendar days  -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Margin="1.5"
                                        Padding="0"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Background="{Binding DayBackground}"
                                        BorderBrush="{Binding DayBorderBrush}"
                                        Command="{Binding DataContext.SelectCalendarDateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border
                                                    x:Name="DayCell"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1.4"
                                                    CornerRadius="7">

                                                    <Grid>
                                                        <TextBlock
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Foreground="{Binding DayForeground}"
                                                            Text="{Binding DayNumber}" />

                                                        <Border
                                                            Width="16"
                                                            Height="16"
                                                            Margin="0,3,3,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Background="#E31D1D"
                                                            CornerRadius="8"
                                                            Visibility="{Binding AppointmentCountVisibility}">

                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="9"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="{Binding AppointmentCount}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <!-- Hover highlight only when the day is not already selected -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                                            <Condition Binding="{Binding IsSelected}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="DayCell" Property="Background" Value="#EEF4FF" />
                                                        <Setter TargetName="DayCell" Property="BorderBrush" Value="#9FC0F0" />
                                                        <Setter TargetName="DayCell" Property="BorderThickness" Value="1.4" />
                                                    </MultiDataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    ClipToBounds="True"
                    HorizontalAlignment="Left"
                    Orientation="Horizontal">

                    <Grid
                        Width="230"
                        Height="52"
                        VerticalAlignment="Center">
                        <TextBox Style="{StaticResource SearchTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Margin="51,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="18"
                            Foreground="#8A8A8A"
                            IsHitTestVisible="False"
                            Text="Search">

                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <fa:IconBlock
                            Margin="18,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="20"
                            Foreground="Black"
                            Icon="Search" />
                    </Grid>

                    <ComboBox
                        Width="230"
                        Height="42"
                        Margin="12,0,0,0"
                        FontSize="15"
                        ItemsSource="{Binding FilterOptions}"
                        SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                        Style="{StaticResource ExactStyleComboBox}"
                        Tag="Filter" />

                    <ComboBox
                        Width="160"
                        Height="42"
                        Margin="10,0,0,0"
                        FontSize="15"
                        ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                        Style="{StaticResource ExactStyleComboBox}"
                        Tag="Sort By" />
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="185"
                        Height="45"
                        Margin="0,0,10,0"
                        Background="#073C98"
                        Command="{Binding OpenWalkInOverlayCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock
                                Margin="0,0,8,0"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Icon="Walking" />
                            <TextBlock 
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Add Walk-in Visit" />
                        </StackPanel>
                    </Button>

                    <Button
                        Width="160"
                        Height="45"
                        Background="#073C98"
                        Command="{Binding OpenScheduledOverlayCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock
                                Margin="0,0,8,0"
                                FontSize="16"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Icon="CalendarPlus" />
                            <TextBlock 
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="White"
                                Text="Add Schedule" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,18">
                <Border Padding="20" Style="{StaticResource LargePanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,10"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="{Binding SelectedCalendarDateTitle}" />

                        <TextBlock
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <DataGrid
                            Grid.Row="2"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding Appointments}"
                            MinRowHeight="42"
                            RowHeight="46"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="0.7*"
                                    MinWidth="80"
                                    Binding="{Binding QueueNumberDisplay}"
                                    Header="Queue No." />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="105"
                                    Binding="{Binding PatientCode}"
                                    Header="Patient ID" />
                                <DataGridTextColumn
                                    Width="1.5*"
                                    MinWidth="170"
                                    Binding="{Binding PatientName}"
                                    Header="Patient Name" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Binding="{Binding AppointmentType}"
                                    Header="Type" />
                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="100"
                                    Binding="{Binding Category}"
                                    Header="Category" />
                                <DataGridTextColumn
                                    Width="1.4*"
                                    MinWidth="150"
                                    Binding="{Binding ServiceName}"
                                    Header="Service" />
                                <DataGridTextColumn
                                    Width="1.3*"
                                    MinWidth="145"
                                    Binding="{Binding DentistName}"
                                    Header="Dentist" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding AppointmentDateDisplay}"
                                    Header="Date" />
                                <DataGridTextColumn
                                    Width="0.9*"
                                    MinWidth="95"
                                    Binding="{Binding AppointmentTimeDisplay}"
                                    Header="Time" />
                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="115"
                                    Binding="{Binding WaitingDurationDisplay}"
                                    Header="Waiting Time" />

                                <DataGridTemplateColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Header="Priority">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="{Binding PriorityBrush}"
                                                Text="{Binding PriorityDisplay}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Header="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Foreground="{Binding StatusBrush}"
                                                Text="{Binding Status}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn
                                    Width="170"
                                    MinWidth="170"
                                    Header="Actions">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel
                                                Width="154"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal">

                                                <!-- Always visible primary action -->
                                                <Button
                                                    Width="65"
                                                    Height="32"
                                                    Margin="0,0,6,0"
                                                    Background="#073C98"
                                                    Command="{Binding DataContext.ViewAppointmentDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}">

                                                    <TextBlock
                                                        FontSize="11"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="View" />
                                                </Button>

                                                <!-- Dropdown actions -->
                                                <Menu
                                                    Height="32"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}">

                                                    <MenuItem
                                                        Header="More"
                                                        IsEnabled="{Binding CanUseMoreActions}"
                                                        Style="{StaticResource ModernMoreMenuHeaderStyle}">

                                                        <MenuItem
                                                            Header="Arrived"
                                                            Command="{Binding Tag.MarkArrivedCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding MarkArrivedButtonVisibility}" />

                                                        <MenuItem
                                                            Header="Reschedule"
                                                            Command="{Binding Tag.OpenRescheduleOverlayCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding RescheduleButtonVisibility}" />

                                                        <MenuItem
                                                            Header="No Show"
                                                            Command="{Binding Tag.MarkNoShowCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding NoShowButtonVisibility}" />

                                                        <MenuItem
                                                            Header="Start"
                                                            Command="{Binding Tag.StartTreatmentCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding StartTreatmentButtonVisibility}" />

                                                        <MenuItem
                                                            Header="Operation Details"
                                                            Command="{Binding Tag.OpenOperationDetailsCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding OperationDetailsButtonVisibility}" />

                                                        <MenuItem
                                                            Header="Complete"
                                                            Command="{Binding Tag.CompleteAppointmentCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding CompleteButtonVisibility}" />

                                                        <MenuItem
                                                            Header="{Binding UrgentButtonText}"
                                                            Command="{Binding Tag.ToggleUrgentCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding UrgentButtonVisibility}" />

                                                        <Separator />

                                                        <MenuItem
                                                            Header="Cancel"
                                                            Command="{Binding Tag.CancelAppointmentCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding CancelButtonVisibility}" />
                                                    </MenuItem>
                                                </Menu>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding IsWalkInOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <appointmentViews:AddWalkInAppointmentOverlayView HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <Grid Background="#99000000" Visibility="{Binding IsScheduledOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <appointmentViews:AddScheduledAppointmentOverlayView HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Reschedule Appointment Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsRescheduleOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="720"
                MaxHeight="720"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="24">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="Reschedule Appointment" />

                        <TextBlock
                            Margin="0,4,0,20"
                            FontSize="15"
                            Foreground="#777777"
                            Text="Update the date, time, service, dentist, or notes for this scheduled appointment."
                            TextWrapping="Wrap" />

                        <TextBlock
                            Margin="0,0,0,14"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding RescheduleErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasRescheduleError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Text="Patient Information" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient ID" />
                                <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding ReschedulePatientCode, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient Name" />
                                <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding ReschedulePatientName, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Type" />
                                <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding RescheduleAppointmentType, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Category" />
                                <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding RescheduleCategory, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,26,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Text="Reschedule Details" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Appointment Date" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                <DatePicker
                                    SelectedDate="{Binding RescheduleDate, Mode=TwoWay}"
                                    Style="{StaticResource AppointmentDatePickerStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Appointment Time" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding RescheduleTimeText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Service / Treatment" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                <ComboBox
                                    Height="42"
                                    ItemsSource="{Binding ServiceOptions}"
                                    SelectedItem="{Binding SelectedRescheduleService, Mode=TwoWay}"
                                    Style="{StaticResource ExactStyleComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Dentist" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                <ComboBox
                                    Height="42"
                                    ItemsSource="{Binding DentistOptions}"
                                    SelectedItem="{Binding SelectedRescheduleDentist, Mode=TwoWay}"
                                    Style="{StaticResource ExactStyleComboBox}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,14,0,0">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Notes / Remarks" />
                            <TextBox
                                Style="{StaticResource AppointmentOverlayTextAreaStyle}"
                                Text="{Binding RescheduleNotes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel
                            Margin="0,28,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">

                            <Button
                                Width="120"
                                Height="44"
                                Margin="0,0,12,0"
                                Background="#777777"
                                Command="{Binding CloseRescheduleOverlayCommand}"
                                Content="Cancel"
                                Foreground="White"
                                Style="{StaticResource SecondaryButtonStyle}" />

                            <Button
                                Width="170"
                                Height="44"
                                Background="#073C98"
                                Command="{Binding SaveRescheduleCommand}"
                                Content="Save Changes"
                                Foreground="White"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Appointment Details Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsAppointmentDetailsOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="820"
                MaxHeight="760"
                Padding="32,28,32,32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="24">

                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontSize="26"
                                FontWeight="Bold"
                                Foreground="#111111"
                                Text="Appointment Details" />

                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="15"
                                Foreground="#777777"
                                Text="View full appointment, queue, and patient alert information." />
                        </StackPanel>

                        <Button
                            Grid.Column="1"
                            Width="36"
                            Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding CloseAppointmentDetailsCommand}"
                            Cursor="Hand">
                            <fa:IconBlock
                                FontSize="18"
                                Foreground="#555555"
                                Icon="Times" />
                        </Button>
                    </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Patient Information -->
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Patient Information" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient ID" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.PatientCode, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient Name" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.PatientName, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Category" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.Category, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient Internal ID" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.PatientId, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <!-- Appointment Information -->
                        <TextBlock
                            Margin="0,26,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Appointment Information" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Type" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.AppointmentType, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Service / Treatment" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.ServiceName, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Dentist" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.DentistName, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Date and Time" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.AppointmentDateDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Time" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.AppointmentTimeDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Status" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.Status, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Treatment Step" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.ServiceStageDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="6" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Return Date / Next Step" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.FollowUpDateDisplay, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,18,0,8"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Treatment Details" />

                        <TextBox
                            Height="95"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource AppointmentOverlayTextAreaStyle}"
                            Text="{Binding SelectedAppointmentDetails.TreatmentDetailsDisplay, Mode=OneWay}" />

                        <StackPanel Margin="0,14,0,0" Visibility="{Binding SelectedAppointmentDetails.HasSelectedTeeth, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Involved Chart" />

                            <ItemsControl ItemsSource="{Binding SelectedAppointmentDetails.ToothChart}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="16" Rows="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Width="36"
                                            Height="44"
                                            Margin="2"
                                            CornerRadius="6"
                                            >

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F8FBFF" />
                                                    <Setter Property="BorderBrush" Value="#D7E3E4" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Opacity" Value="0.45" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#CFF4EF" />
                                                            <Setter Property="BorderBrush" Value="#073C98" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <fa:IconBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="30"
                                                    Foreground="#2E7E82"
                                                    Icon="Tooth" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Margin="0,4,0,0"
                                                    FontSize="12"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding DisplayText}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Queue / Timeline -->
                        <TextBlock
                            Margin="0,26,0,12"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Queue / Timeline" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Arrival Time" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.ArrivalTimeDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Started At" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.StartedAtDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Completed At" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.CompletedAtDisplay, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Cancelled At" />
                                <TextBox
                                    Style="{StaticResource AppointmentReadOnlyTextBoxStyle}"
                                    Text="{Binding SelectedAppointmentDetails.CancelledAtDisplay, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>

                        <!-- Medical Alert -->
                        <Border
                            Margin="0,24,0,0"
                            Padding="14"
                            Background="#FFEBEE"
                            BorderBrush="#E31D1D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Visibility="{Binding AppointmentDetailsHasMedicalAlert, Converter={StaticResource BoolToVisibilityConverter}}">

                            <StackPanel>
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="#B71C1C"
                                    Text="Medical Alert" />

                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontSize="13"
                                    Foreground="#4A1C1C"
                                    Text="{Binding AppointmentDetailsMedicalAlertText}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Notes -->
                        <TextBlock
                            Margin="0,26,0,8"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Notes / Remarks" />

                        <TextBox
                            Height="100"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            Style="{StaticResource AppointmentOverlayTextAreaStyle}"
                            Text="{Binding SelectedAppointmentDetails.NotesDisplay, Mode=OneWay}" />

                        <!-- Teeth Images -->
                        <TextBlock
                            Margin="0,26,0,8"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#223357"
                            Text="Teeth Images" />

                        <Button
                            Width="170"
                            Height="40"
                            HorizontalAlignment="Left"
                            Background="#073C98"
                            Click="UploadAppointmentDetailsImage_Click"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Margin="0,0,8,0" Foreground="White" Icon="Upload" />
                                <TextBlock FontWeight="Bold" Text="Upload Image" />
                            </StackPanel>
                        </Button>

                        <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding AppointmentDetailsImages}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="120"
                                        Margin="0,0,10,10"
                                        Background="#F4F6FB"
                                        BorderBrush="#D8D8D8"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="100" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Image
                                                Grid.Row="0"
                                                Margin="6"
                                                Source="{Binding Thumbnail}"
                                                Stretch="UniformToFill" />

                                            <Button
                                                Grid.Row="1"
                                                Height="28"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveAppointmentDetailsImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <fa:IconBlock Margin="0,0,5,0" FontSize="11" Foreground="#C62828" Icon="TrashAlt" />
                                                    <TextBlock FontSize="11" Foreground="#C62828" Text="Remove" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button
                            Width="130"
                            Height="44"
                            Margin="0,28,0,0"
                            HorizontalAlignment="Right"
                            Background="#073C98"
                            Command="{Binding CloseAppointmentDetailsCommand}"
                            Content="Close"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Operation Details Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsOperationDetailsOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="780"
                MaxHeight="760"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="22">

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="#111111"
                            Text="Operation Details" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="14"
                            Foreground="#777777"
                            Text="Record treatment-stage details while the patient is in treatment."
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#C62828"
                                Text="{Binding OperationErrorMessage}"
                                TextWrapping="Wrap"
                                Visibility="{Binding HasOperationError, Converter={StaticResource BoolToVisibilityConverter}}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Visibility="{Binding RequiresTreatmentStage, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Treatment Step" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <ComboBox
                                        Height="42"
                                        ItemsSource="{Binding TreatmentStageOptions}"
                                        SelectedItem="{Binding FormTreatmentStage, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Select treatment step" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Visibility="{Binding RequiresFollowUpDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Return Date / Next Step" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <DatePicker
                                        SelectedDate="{Binding FormFollowUpDate, Mode=TwoWay}"
                                        Style="{StaticResource AppointmentDatePickerStyle}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,16,0,0" Visibility="{Binding HasToothSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Involved" />

                                <ItemsControl ItemsSource="{Binding ToothOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="16" Rows="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Width="42"
                                                Height="50"
                                                Margin="2"
                                                Padding="0"
                                                Command="{Binding DataContext.ToggleToothSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">

                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#F8FBFF" />
                                                        <Setter Property="BorderBrush" Value="#B9D5D6" />
                                                        <Setter Property="BorderThickness" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#CFF4EF" />
                                                                <Setter Property="BorderBrush" Value="#073C98" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>

                                                <Grid>
                                                    <fa:IconBlock
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="34"
                                                        Foreground="#2E7E82"
                                                        Icon="Tooth" />
                                                    <TextBlock
                                                        Margin="0,5,0,0"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Top"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        Text="{Binding DisplayText}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Visibility="{Binding HasExtractionService, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Medication / Prescription" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding FormPrescription, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Visibility="{Binding HasProphylaxisService, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Prophylaxis Severity" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <ComboBox
                                        Height="42"
                                        ItemsSource="{Binding ProphylaxisSeverityOptions}"
                                        SelectedItem="{Binding FormProphylaxisSeverity, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Select severity" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0" Visibility="{Binding HasRestorationService, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Restoration Surface" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding FormRestorationSurface, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" >
                                <Run Text="Restoration Depth" />
                                <Run Foreground="#E53935" Text=" *" />
                            </TextBlock>
                                    <ComboBox
                                        Height="42"
                                        ItemsSource="{Binding RestorationDepthOptions}"
                                        SelectedItem="{Binding FormRestorationDepth, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Select depth" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Images" />

                                <Button
                                    Width="170"
                                    Height="40"
                                    HorizontalAlignment="Left"
                                    Background="#073C98"
                                    Click="UploadAppointmentDetailsImage_Click"
                                    Foreground="White"
                                    Style="{StaticResource SecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:IconBlock Margin="0,0,8,0" Foreground="White" Icon="Upload" />
                                        <TextBlock FontWeight="Bold" Text="Upload Image" />
                                    </StackPanel>
                                </Button>

                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding AppointmentDetailsImages}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Width="110"
                                                Margin="0,0,10,10"
                                                Background="#F4F6FB"
                                                BorderBrush="#D8D8D8"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="90" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Image
                                                        Grid.Row="0"
                                                        Margin="6"
                                                        Source="{Binding Thumbnail}"
                                                        Stretch="UniformToFill" />

                                                    <Button
                                                        Grid.Row="1"
                                                        Height="26"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding DataContext.RemoveAppointmentDetailsImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Cursor="Hand">
                                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                            <fa:IconBlock Margin="0,0,5,0" FontSize="11" Foreground="#C62828" Icon="TrashAlt" />
                                                            <TextBlock FontSize="11" Foreground="#C62828" Text="Remove" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel
                                Margin="0,24,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">

                                <Button
                                    Width="110"
                                    Height="42"
                                    Margin="0,0,10,0"
                                    Background="#777777"
                                    Command="{Binding CloseOperationDetailsCommand}"
                                    Content="Close"
                                    Foreground="White"
                                    Style="{StaticResource SecondaryButtonStyle}" />

                                <Button
                                    Width="150"
                                    Height="42"
                                    Background="#073C98"
                                    Command="{Binding SaveOperationDetailsCommand}"
                                    Content="Save Details"
                                    Foreground="White"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Complete Treatment Overlay -->
        <Grid
            Background="#99000000"
            Visibility="{Binding IsCompleteTreatmentOverlayOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="620"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="22">

                <StackPanel>
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="Complete Appointment" />

                    <TextBlock
                        Margin="0,6,0,20"
                        FontSize="14"
                        Foreground="#777777"
                        Text="Add treatment notes before completing this appointment. These notes will be saved to the patient’s treatment history."
                        TextWrapping="Wrap" />

                    <TextBlock
                        Margin="0,0,0,10"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#C62828"
                        Text="{Binding CompletionErrorMessage}"
                        TextWrapping="Wrap"
                        Visibility="{Binding HasCompletionError, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <TextBlock
                        Margin="2,0,0,6"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#333333"
                        Text="Treatment Notes" />

                    <TextBox
                        Height="130"
                        Padding="14,10"
                        AcceptsReturn="True"
                        Style="{StaticResource ModernTextAreaStyle}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        Text="{Binding CompletionTreatmentNotes, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel
                        Margin="0,24,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">

                        <Button
                            Width="110"
                            Height="42"
                            Margin="0,0,10,0"
                            Background="#777777"
                            Command="{Binding CloseCompleteTreatmentOverlayCommand}"
                            Content="Back"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />

                        <Button
                            Width="170"
                            Height="42"
                            Background="#00A423"
                            Command="{Binding ConfirmCompleteAppointmentCommand}"
                            Content="Complete"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>       
    </Grid>
</UserControl>
