<UserControl
    x:Class="CruzNeryClinic.Views.AppointmentManagement.AddScheduledAppointmentOverlayView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border
        Width="920"
        MaxHeight="760"
        Padding="34,34,16,34"
        Background="White"
        CornerRadius="26">

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Resources>
                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}"
                       TargetType="{x:Type ScrollBar}" />
            </ScrollViewer.Resources>

            <StackPanel Margin="0,0,18,0">
                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="#111111"
                    Text="{Binding FormTitle}" />

                <TextBlock
                    Margin="0,4,0,22"
                    FontSize="15"
                    Foreground="#777777"
                    Text="Search an existing patient and create a scheduled dental appointment." />

                <TextBlock
                    Margin="0,0,0,14"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="#C62828"
                    Text="{Binding FormErrorMessage}"
                    TextWrapping="Wrap"
                    Visibility="{Binding HasFormError, Converter={StaticResource BoolToVisibilityConverter}}" />

                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Patient Lookup" />

                <StackPanel Margin="0,0,0,18">
                    <TextBlock
                        Style="{StaticResource AppointmentOverlayFieldLabelStyle}"
                        Text="Search Patient ID or Name *" />

                    <Grid>
                        <TextBox
                            Height="46"
                            Style="{StaticResource AppointmentOverlayTextBoxStyle}"
                            Text="{Binding FormPatientSearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <Popup
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                            AllowsTransparency="True"
                            IsOpen="{Binding IsScheduledPatientSearchPopupOpen, Mode=OneWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                            StaysOpen="False">

                            <Border
                                MaxHeight="220"
                                Background="White"
                                BorderBrush="#D8D8D8"
                                BorderThickness="1"
                                CornerRadius="10">

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox
                                        BorderThickness="0"
                                        ItemsSource="{Binding PatientSearchResults}">

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Cursor" Value="Hand" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.SelectPatientCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}">

                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border
                                                                    x:Name="ButtonBorder"
                                                                    Background="{TemplateBinding Background}">
                                                                    <ContentPresenter
                                                                        HorizontalAlignment="Stretch"
                                                                        VerticalAlignment="Center" />
                                                                </Border>

                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF6FF" />
                                                                    </Trigger>

                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="ButtonBorder" Property="Background" Value="#DDEEFF" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>

                                                        <Border
                                                            Padding="12,8"
                                                            Background="Transparent">

                                                            <StackPanel>
                                                                <TextBlock
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#111111"
                                                                    Text="{Binding DisplayText}" />

                                                                <TextBlock
                                                                    Margin="0,2,0,0"
                                                                    FontSize="12"
                                                                    Foreground="#777777"
                                                                    Text="{Binding Category}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <TextBlock
                        Margin="2,6,0,0"
                        FontSize="12"
                        Foreground="#777777"
                        Text="Type at least 2 characters to search existing patients." />
                </StackPanel>

                <Border
                    Margin="0,0,0,18"
                    Padding="14"
                    Background="#FFF8E1"
                    BorderBrush="#F4C542"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasNoPatientSearchResults, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#6B4E00"
                            Text="No matching patient found. Add the patient first before creating an appointment."
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Width="155"
                            Height="34"
                            HorizontalAlignment="Right"
                            Background="#073C98"
                            Command="{Binding ShowAddPatientInstructionCommand}"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}">

                            <TextBlock
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Add Patient" />
                        </Button>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient ID" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientCode, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="First Name" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientFirstName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Last Name" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientLastName, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <Border
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="#FFEBEE"
                    BorderBrush="#E31D1D"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasMedicalAlert, Converter={StaticResource BoolToVisibilityConverter}}">

                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#B71C1C"
                            Text="Medical Alert" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="13"
                            Foreground="#4A1C1C"
                            Text="{Binding MedicalAlertText}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Scheduled Appointment Details" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Type" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="Scheduled" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Category" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientCategory, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Date *" />
                        <DatePicker Height="46" SelectedDate="{Binding FormAppointmentDate, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Time *" />
                        <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding FormAppointmentTimeText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Services / Treatments *" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                Grid.Column="0"
                                Height="42"
                                ItemsSource="{Binding ServiceOptions}"
                                SelectedItem="{Binding SelectedService, Mode=TwoWay}"
                                Style="{StaticResource ExactStyleComboBox}"
                                Tag="Select a service or treatment">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button
                                Grid.Column="2"
                                Width="64"
                                Height="42"
                                Background="#073C98"
                                Command="{Binding AddServiceCommand}"
                                Foreground="White"
                                Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock FontWeight="Bold" Text="Add" />
                            </Button>
                        </Grid>

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedServices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,6,6"
                                        Padding="10,5"
                                        Background="#EAF1FF"
                                        CornerRadius="14">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="#103A8E"
                                                Text="{Binding ServiceName}" />
                                            <Button
                                                Width="16"
                                                Height="16"
                                                Margin="8,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                                <fa:IconBlock FontSize="12" Foreground="#103A8E" Icon="Times" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Dentist *" />
                        <ComboBox
                            Height="42"
                            ItemsSource="{Binding DentistOptions}"
                            SelectedItem="{Binding SelectedDentist, Mode=TwoWay}"
                            Style="{StaticResource ExactStyleComboBox}"
                            Tag="Select a dentist">
                            
                            <ComboBox.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="Select a dentist." />
                                </ToolTip>
                            </ComboBox.ToolTip>

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock 
                                            Text="{Binding DisplayText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox> 
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,18,0,0">
                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Images" />

                    <Button
                        Width="170"
                        Height="40"
                        HorizontalAlignment="Left"
                        Background="#073C98"
                        Click="UploadTeethImage_Click"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,8,0" Foreground="White" Icon="Upload" />
                            <TextBlock FontWeight="Bold" Text="Upload Image" />
                        </StackPanel>
                    </Button>

                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding TeethImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Width="110"
                                    Margin="0,0,10,10"
                                    Background="#F4F6FB"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="90" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Image
                                            Grid.Row="0"
                                            Margin="6"
                                            Source="{Binding Thumbnail}"
                                            Stretch="UniformToFill" />

                                        <Button
                                            Grid.Row="1"
                                            Height="26"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.RemoveTeethImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <fa:IconBlock Margin="0,0,5,0" FontSize="11" Foreground="#C62828" Icon="TrashAlt" />
                                                <TextBlock FontSize="11" Foreground="#C62828" Text="Remove" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Notes / Remarks" />
                    <TextBox
                        Style="{StaticResource AppointmentOverlayTextAreaStyle}"
                        Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Margin="0,28,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="120"
                        Height="44"
                        Margin="0,0,12,0"
                        Background="#777777"
                        Command="{Binding CancelScheduledCommand}"
                        Content="Cancel"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Width="190"
                        Height="44"
                        Background="#073C98"
                        Command="{Binding SaveScheduledCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,8,0" Icon="CalendarPlus" Foreground="White" />
                            <TextBlock FontWeight="Bold" Text="Save Schedule" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>