<UserControl
    x:Class="CruzNeryClinic.Views.AppointmentManagement.AddWalkInAppointmentOverlayView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="AppointmentManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border
            Width="920"
            MaxHeight="760"
            Padding="34,28,16,34"
            Background="White"
            CornerRadius="26">

        <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="0,0,18,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock
                        FontSize="28"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="{Binding FormTitle}" />

                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="15"
                        Foreground="#777777"
                        Text="Search an existing patient and add them to today's walk-in queue." />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    Width="36"
                    Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding CancelWalkInCommand}"
                    Cursor="Hand">
                    <fa:IconBlock
                        FontSize="18"
                        Foreground="#555555"
                        Icon="Times" />
                </Button>
            </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ScrollViewer.Resources>
                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}"
                       TargetType="{x:Type ScrollBar}" />
            </ScrollViewer.Resources>

            <StackPanel Margin="0,0,18,0">
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Patient Lookup" />

                <StackPanel Margin="0,0,0,18">
                    <TextBlock
                        Style="{StaticResource AppointmentOverlayFieldLabelStyle}"
                        Text="Search Patient ID or Name *" />

                    <Grid>
                        <TextBox
                            Height="46"
                            Style="{StaticResource AppointmentOverlayTextBoxStyle}"
                            Text="{Binding FormPatientSearchText, UpdateSourceTrigger=PropertyChanged}" />

                        <Popup
                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                            AllowsTransparency="True"
                            IsOpen="{Binding IsWalkInPatientSearchPopupOpen, Mode=OneWay}"
                            Placement="Bottom"
                            PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                            StaysOpen="False">

                            <Border
                                Style="{StaticResource PatientLookupPopupBorderStyle}">

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ListBox
                                        ItemContainerStyle="{StaticResource PatientLookupListBoxItemStyle}"
                                        ItemsSource="{Binding PatientSearchResults}"
                                        Style="{StaticResource PatientLookupListBoxStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Button
                                                        Command="{Binding DataContext.SelectPatientCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource PatientLookupItemButtonStyle}">

                                                        <Border
                                                            Padding="12,8"
                                                            Background="Transparent">

                                                            <StackPanel>
                                                                <TextBlock
                                                                    FontSize="14"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#111111"
                                                                    Text="{Binding DisplayText}" />

                                                                <TextBlock
                                                                    Margin="0,2,0,0"
                                                                    FontSize="12"
                                                                    Foreground="#777777"
                                                                    Text="{Binding Category}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <TextBlock
                        Margin="2,6,0,0"
                        FontSize="12"
                        Foreground="#777777"
                        Text="Type at least 2 characters to search existing patients." />
                </StackPanel>

                <Border
                    Margin="0,0,0,18"
                    Padding="14"
                    Background="#FFF8E1"
                    BorderBrush="#F4C542"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasNoPatientSearchResults, Converter={StaticResource BoolToVisibilityConverter}}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="170" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#6B4E00"
                            Text="No matching patient found. Add the patient first before creating an appointment."
                            TextWrapping="Wrap" />

                        <Button
                            Grid.Column="1"
                            Width="155"
                            Height="34"
                            HorizontalAlignment="Right"
                            Background="#073C98"
                            Command="{Binding ShowAddPatientInstructionCommand}"
                            Foreground="White"
                            Style="{StaticResource SecondaryButtonStyle}">

                            <TextBlock
                                FontSize="12"
                                FontWeight="Bold"
                                Text="Add Patient" />
                        </Button>
                    </Grid>
                </Border>  

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Patient ID" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientCode, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="First Name" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientFirstName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Last Name" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientLastName, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
                
                <Border
                    Margin="0,18,0,0"
                    Padding="14"
                    Background="#FFEBEE"
                    BorderBrush="#E31D1D"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding HasMedicalAlert, Converter={StaticResource BoolToVisibilityConverter}}">

                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#B71C1C"
                            Text="Medical Alert" />

                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="13"
                            Foreground="#4A1C1C"
                            Text="{Binding MedicalAlertText}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock
                    Margin="0,28,0,12"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="Walk-in Visit Details" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Appointment Type" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="Walk-In Visit" />
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Category" />
                        <TextBox Style="{StaticResource AppointmentReadOnlyTextBoxStyle}" Text="{Binding FormPatientCategory, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Date" />
                        <DatePicker
                            IsEnabled="False"
                            SelectedDate="{Binding FormAppointmentDate}"
                            Style="{StaticResource AppointmentDatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Arrival Time *" />
                        <Border
                            Style="{StaticResource AppointmentTimePickerContainerStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    Grid.Column="0"
                                    MaxLength="2"
                                    Style="{StaticResource AppointmentTimeSegmentTextBoxStyle}"
                                    Text="{Binding WalkInArrivalHourText, UpdateSourceTrigger=PropertyChanged}" />

                                <Border
                                    Grid.Column="1"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1,0,1,0">
                                    <TextBox
                                        MaxLength="2"
                                        Style="{StaticResource AppointmentTimeSegmentTextBoxStyle}"
                                        Text="{Binding WalkInArrivalMinuteText, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>

                                <ComboBox
                                    Grid.Column="2"
                                    ItemsSource="{Binding TimePeriodOptions}"
                                    SelectedItem="{Binding WalkInArrivalPeriod, Mode=TwoWay}"
                                    Style="{StaticResource AppointmentTimePeriodComboBoxStyle}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Services / Treatments *" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                Grid.Column="0"
                                Height="42"
                                ItemsSource="{Binding ServiceOptions}"
                                SelectedItem="{Binding SelectedService, Mode=TwoWay}"
                                Style="{StaticResource ExactStyleComboBox}"
                                Tag="Select a service or treatment">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button
                                Grid.Column="2"
                                Width="64"
                                Height="42"
                                Background="#073C98"
                                Command="{Binding AddServiceCommand}"
                                Foreground="White"
                                Style="{StaticResource SecondaryButtonStyle}">
                                <TextBlock FontWeight="Bold" Text="Add" />
                            </Button>
                        </Grid>

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding SelectedServices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,6,6"
                                        Padding="10,5"
                                        Background="#EAF1FF"
                                        CornerRadius="14">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="#103A8E"
                                                Text="{Binding ServiceName}" />
                                            <Button
                                                Width="16"
                                                Height="16"
                                                Margin="8,0,0,0"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Command="{Binding DataContext.RemoveServiceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                                <fa:IconBlock FontSize="12" Foreground="#103A8E" Icon="Times" />
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2">
                        <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Dentist *" />
                        <ComboBox
                            Height="42"
                            ItemsSource="{Binding DentistOptions}"
                            SelectedItem="{Binding SelectedDentist, Mode=TwoWay}"
                            Style="{StaticResource ExactStyleComboBox}"
                            Tag="Select a dentist">
                            
                            <ComboBox.ToolTip>
                                <ToolTip>
                                    <TextBlock Text="Select a dentist." />
                                </ToolTip>
                            </ComboBox.ToolTip>

                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4">
                                        <TextBlock 
                                            Text="{Binding DisplayText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox> 
                    </StackPanel>
                </Grid>

                <StackPanel
                    Margin="0,18,0,0"
                    Visibility="Collapsed">

                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Treatment Details" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Visibility="{Binding RequiresTreatmentStage, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Treatment Step *" />
                            <ComboBox
                                Height="42"
                                ItemsSource="{Binding TreatmentStageOptions}"
                                SelectedItem="{Binding FormTreatmentStage, Mode=TwoWay}"
                                Style="{StaticResource ExactStyleComboBox}"
                                Tag="Select treatment step" />
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Visibility="{Binding RequiresFollowUpDate, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Return Date / Next Step *" />
                            <DatePicker
                                SelectedDate="{Binding FormFollowUpDate, Mode=TwoWay}"
                                Style="{StaticResource AppointmentDatePickerStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Visibility="{Binding HasToothSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Involved" />

                            <ItemsControl ItemsSource="{Binding ToothOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="16" Rows="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Width="42"
                                            Height="50"
                                            Margin="2"
                                            Padding="0"
                                            Command="{Binding DataContext.ToggleToothSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Cursor="Hand">

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#F8FBFF" />
                                                    <Setter Property="BorderBrush" Value="#B9D5D6" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#CFF4EF" />
                                                            <Setter Property="BorderBrush" Value="#073C98" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>

                                            <Grid>
                                                <fa:IconBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="34"
                                                    Foreground="#2E7E82"
                                                    Icon="Tooth" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Top"
                                                    Margin="0,5,0,0"
                                                    FontSize="13"
                                                    FontWeight="Bold"
                                                    Foreground="White"
                                                    Text="{Binding DisplayText}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0" Visibility="{Binding HasExtractionService, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Medication / Prescription *" />
                            <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding FormPrescription, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="2" Visibility="{Binding HasProphylaxisService, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Prophylaxis Severity *" />
                            <ComboBox
                                Height="42"
                                ItemsSource="{Binding ProphylaxisSeverityOptions}"
                                SelectedItem="{Binding FormProphylaxisSeverity, Mode=TwoWay}"
                                Style="{StaticResource ExactStyleComboBox}"
                                Tag="Select severity" />
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3" Visibility="{Binding HasRestorationService, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Surface *" />
                                    <TextBox Style="{StaticResource AppointmentOverlayTextBoxStyle}" Text="{Binding FormRestorationSurface, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Depth *" />
                                    <ComboBox
                                        Height="42"
                                        ItemsSource="{Binding RestorationDepthOptions}"
                                        SelectedItem="{Binding FormRestorationDepth, Mode=TwoWay}"
                                        Style="{StaticResource ExactStyleComboBox}"
                                        Tag="Select depth" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,18,0,0" Visibility="Collapsed">
                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Teeth Images" />

                    <Button
                        Width="170"
                        Height="40"
                        HorizontalAlignment="Left"
                        Background="#073C98"
                        Click="UploadTeethImage_Click"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,8,0" Foreground="White" Icon="Upload" />
                            <TextBlock FontWeight="Bold" Text="Upload Image" />
                        </StackPanel>
                    </Button>

                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding TeethImages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Width="110"
                                    Margin="0,0,10,10"
                                    Background="#F4F6FB"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="90" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Image
                                            Grid.Row="0"
                                            Margin="6"
                                            Source="{Binding Thumbnail}"
                                            Stretch="UniformToFill" />

                                        <Button
                                            Grid.Row="1"
                                            Height="26"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.RemoveTeethImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <fa:IconBlock Margin="0,0,5,0" FontSize="11" Foreground="#C62828" Icon="TrashAlt" />
                                                <TextBlock FontSize="11" Foreground="#C62828" Text="Remove" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Margin="0,14,0,0">
                    <TextBlock Style="{StaticResource AppointmentOverlayFieldLabelStyle}" Text="Notes / Remarks" />
                    <TextBox
                        Style="{StaticResource AppointmentOverlayTextAreaStyle}"
                        Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <StackPanel
                    Margin="0,28,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="120"
                        Height="44"
                        Margin="0,0,12,0"
                        Background="#777777"
                        Command="{Binding CancelWalkInCommand}"
                        Content="Cancel"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />

                    <Button
                        Width="160"
                        Height="44"
                        Background="#073C98"
                        Command="{Binding SaveWalkInCommand}"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}">

                        <StackPanel Orientation="Horizontal">
                            <fa:IconBlock Margin="0,0,8,0" Icon="PlusCircle" Foreground="White" />
                            <TextBlock FontWeight="Bold" Text="Add to Queue" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        </DockPanel>
        </Border>

        <Grid
            Width="920"
            MaxHeight="760"
            Background="#66000000"
            Visibility="{Binding IsAppointmentFormPromptOpen, Converter={StaticResource BoolToVisibilityConverter}}">

            <Border
                Width="420"
                Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                CornerRadius="12">

                <StackPanel>
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#111111"
                        Text="Appointment Form" />

                    <TextBlock
                        Margin="0,12,0,22"
                        FontSize="14"
                        Foreground="#444444"
                        Text="{Binding AppointmentFormPromptMessage}"
                        TextWrapping="Wrap" />

                    <Button
                        Width="110"
                        Height="40"
                        HorizontalAlignment="Right"
                        Background="#073C98"
                        Command="{Binding CloseAppointmentFormPromptCommand}"
                        Content="OK"
                        Foreground="White"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
