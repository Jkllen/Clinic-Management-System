<UserControl
    x:Class="CruzNeryClinic.Views.UserManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:userManagement="clr-namespace:CruzNeryClinic.Views.UserManagement"
    d:DesignHeight="900"
    d:DesignWidth="1600"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UserManagement/UserManagementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource ScreenBackgroundBrush}">
        <!--  Main content  -->
        <Grid Margin="24,28,24,18">

            <Grid.RowDefinitions>
                <RowDefinition Height="78" />
                <RowDefinition Height="150" />
                <RowDefinition Height="88" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel Grid.Row="0">
                <TextBlock
                    FontSize="30"
                    FontWeight="Bold"
                    Foreground="Black"
                    Text="User Management" />

                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="20"
                    Foreground="#7A7A7A"
                    Text="View, Add &amp; Update User" />
            </StackPanel>

            <!--  Summary cards  -->
            <Grid Grid.Row="1" Margin="20,0,20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Total Users  -->
                <Border
                    Grid.Column="0"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="34"
                                Foreground="White"
                                Icon="Users" />
                        </Border>

                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" Text="Total Users" />
                            <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding TotalUsers}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Active Accounts  -->
                <Border
                    Grid.Column="2"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Icon="Server" />
                        </Border>

                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" Text="Active Accounts" />
                            <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding ActiveAccounts}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Administrators  -->
                <Border
                    Grid.Column="4"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Icon="UserShield" />
                        </Border>

                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" Text="Administrators" />
                            <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding AdministratorCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Staff  -->
                <Border
                    Grid.Column="6"
                    Padding="18"
                    Style="{StaticResource DashboardCardStyle}">

                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">

                        <Border
                            Width="60"
                            Height="60"
                            Background="#2F98D0"
                            CornerRadius="14">

                            <fa:IconBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Foreground="White"
                                Icon="UserFriends" />
                        </Border>

                        <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="17" Text="Staff" />
                            <TextBlock Style="{StaticResource SummaryNumberStyle}" Text="{Binding StaffCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Search, filter, sort, add user  -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <!--  Column 0: Search textbox  -->
                    <ColumnDefinition Width="230" />
                    <!--  Column 1: Space between Search and Filter  -->
                    <ColumnDefinition Width="28" />
                    <!--  Column 2: Filter dropdown/button  -->
                    <ColumnDefinition Width="190" />
                    <!--  Column 3: Space between Filter and Sort  -->
                    <ColumnDefinition Width="10" />
                    <!--  Column 4: Sort By dropdown/button  -->
                    <ColumnDefinition Width="220" />
                    <!--  Column 5: Flexible empty space pushing Add button to the right  -->
                    <ColumnDefinition Width="*" />
                    <!--  Column 6: Add New User button  -->
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <!--  Search User  -->
                <Grid
                    Grid.Column="0"
                    Height="52"
                    VerticalAlignment="Center">

                    <TextBox Style="{StaticResource SearchTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock
                        Margin="51,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="#8A8A8A"
                        IsHitTestVisible="False"
                        Text="Search User">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <fa:IconBlock
                        Margin="18,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="20"
                        Foreground="Black"
                        Icon="Search" />
                </Grid>

                <!--  Filter dropdown  -->
                <ComboBox
                    Grid.Column="2"
                    Width="Auto"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding FilterOptions}"
                    SelectedItem="{Binding SelectedFilterOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Filter" />

                <!--  Sort dropdown  -->
                <ComboBox
                    Grid.Column="4"
                    Height="52"
                    FontSize="16"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                    Style="{StaticResource ToolbarComboBoxStyle}"
                    Tag="Sort By" />

                <!--  Add New User button  -->
                <Button
                    Grid.Column="6"
                    Height="45"
                    VerticalAlignment="Center"
                    Background="#073C98"
                    Command="{Binding AddNewUserCommand}"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Style="{StaticResource SecondaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="White"
                            Icon="UserPlus" />

                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Add New User" />
                    </StackPanel>
                </Button>
            </Grid>

            <!--  Table panel and Help Button Area  -->
            <Grid Grid.Row="3" Margin="0,0,0,18">

                <Grid.RowDefinitions>
                    <!--  Table Area  -->
                    <RowDefinition Height="*" />
                    <!--  Help Button Area  -->
                    <RowDefinition Height="76" />
                </Grid.RowDefinitions>

                <!--  Main table container  -->
                <Border
                    Grid.Row="0"
                    Margin="0,0,0,0"
                    Padding="20"
                    Style="{StaticResource LargePanelStyle}">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Error message  -->
                        <TextBlock
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            FontSize="15"
                            FontWeight="SemiBold"
                            Foreground="#C62828"
                            Text="{Binding ErrorMessage}"
                            TextWrapping="Wrap"
                            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!--  Users table  -->
                        <DataGrid
                            Grid.Row="1"
                            CanUserResizeRows="False"
                            CellStyle="{StaticResource DashboardDataGridCellStyle}"
                            ColumnHeaderStyle="{StaticResource DashboardDataGridColumnHeaderStyle}"
                            ItemsSource="{Binding Users}"
                            MinRowHeight="42"
                            RowHeight="46"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                            Style="{StaticResource DashboardDataGridStyle}">

                            <DataGrid.Resources>
                                <Style BasedOn="{StaticResource BlueDataGridScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </DataGrid.Resources>

                            <DataGrid.Columns>

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Binding="{Binding UserCode}"
                                    Header="User ID" />

                                <DataGridTextColumn
                                    Width="1.3*"
                                    MinWidth="150"
                                    Binding="{Binding LastName}"
                                    Header="Last Name" />

                                <DataGridTextColumn
                                    Width="1.3*"
                                    MinWidth="150"
                                    Binding="{Binding FirstName}"
                                    Header="First Name" />

                                <DataGridTextColumn
                                    Width="1.5*"
                                    MinWidth="170"
                                    Binding="{Binding ContactNumber}"
                                    Header="Contact Number" />

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="120"
                                    Binding="{Binding Role}"
                                    Header="Role" />

                                <DataGridTextColumn
                                    Width="1*"
                                    MinWidth="110"
                                    Binding="{Binding AccountStatus}"
                                    Header="Status" />

                                <DataGridTemplateColumn
                                    Width="1.6*"
                                    MinWidth="210"
                                    Header="Actions">

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                                <!--  Active user actions: Update + Archive  -->
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}">

                                                    <!--  Update button  -->
                                                    <Button
                                                        Width="75"
                                                        Height="32"
                                                        Margin="0,0,8,0"
                                                        Background="#22C84A"
                                                        Command="{Binding DataContext.UpdateUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallActionButtonStyle}">

                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconBlock
                                                                Margin="0,0,5,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="White"
                                                                Icon="Edit" />

                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="Update" />
                                                        </StackPanel>
                                                    </Button>

                                                    <!--  Archive button  -->
                                                    <Button
                                                        Width="75"
                                                        Height="32"
                                                        Background="#E31D1D"
                                                        Command="{Binding DataContext.ArchiveUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SmallActionButtonStyle}">

                                                        <StackPanel Orientation="Horizontal">
                                                            <fa:IconBlock
                                                                Margin="0,0,5,0"
                                                                VerticalAlignment="Center"
                                                                FontSize="13"
                                                                Foreground="White"
                                                                Icon="Archive" />

                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="11"
                                                                FontWeight="Bold"
                                                                Foreground="White"
                                                                Text="Archive" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                                <!--  Archived user action: Restore only  -->
                                                <Button
                                                    Width="79"
                                                    Height="32"
                                                    Background="#E98A1A"
                                                    Command="{Binding DataContext.RestoreUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource SmallActionButtonStyle}"
                                                    Visibility="{Binding IsArchived, Converter={StaticResource BoolToVisibilityConverter}}">

                                                    <StackPanel Orientation="Horizontal">
                                                        <fa:IconBlock
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="15"
                                                            Foreground="White"
                                                            Icon="RedoAlt" />

                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Foreground="White"
                                                            Text="Restore" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!--  Help button  -->
                <Button
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Panel.ZIndex="10"
                    Style="{StaticResource HelpButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock
                            VerticalAlignment="Center"
                            FontSize="36"
                            Foreground="White"
                            Icon="QuestionCircle" />

                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="HELP" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
        <userManagement:AddUserOverlayView 
            Panel.ZIndex="50" 
            Visibility = "{Binding IsAddUserOverlayOpen, 
                          Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</UserControl>
