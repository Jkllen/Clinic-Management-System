<Window x:Class="Clinic_Management_System.MainWindow"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clinic Management System"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="LightBlue"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <!-- Placeholder TextBox Style -->
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                            <TextBlock x:Name="Placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="Gray"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Opacity="0.5"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer white rounded container -->
    <Border CornerRadius="16" Background="White" Margin="12" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                <StackPanel>
                    <Image Source="Assets/ClinicLogo.png" Height="84" Width="84" HorizontalAlignment="Center" Margin="0,6"/>
                    <TextBlock Text="Cruz-Nery Dental Clinic" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,24"/>
                    <Button Content="Dashboard" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Appointment" Style="{StaticResource SelectedNavButton}" Margin="0,8,0,0"/>
                    <Button Content="Inventory" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Patient" Style="{StaticResource NavButtonStyle}"/>
                    <Button Content="Payment" Style="{StaticResource NavButtonStyle}"/>
                    <StackPanel Margin="0,30,0,0">
                        <Button Content="Log out" Style="{StaticResource NavButtonStyle}"/>
                        <Button Content="Help" Style="{StaticResource NavButtonStyle}"/>
                    </StackPanel>
                    <TextBlock Text="© 2025" Foreground="White" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>

            <!-- MAIN AREA -->
            <Grid x:Name="AppointmentGrid" Grid.Column="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Text="Appointment"
                           FontSize="34"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Grid.Row="0"/>

                <!-- SEARCH + FILTERS + ADD BUTTON -->
                <StackPanel Grid.Row="1" Margin="0,120,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- SEARCH BAR -->
                        <Border CornerRadius="10" Background="#E8F0F2" Padding="8" Grid.Column="0" Margin="0,0,10,5">
                            <DockPanel>
                                <TextBlock Text="🔍" VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchBox"
                                         Width="260"
                                         Height="30"
                                         Style="{StaticResource PlaceholderTextBox}"
                                         Tag="Search Here..."
                                         TextChanged="SearchBox_TextChanged"/>
                            </DockPanel>
                        </Border>

                        <!-- FILTERS -->
                        <Button Content="Filter" Width="70" Height="30" Margin="0,0,10,0"
                                Grid.Column="1" Click="Filter_Click"/>
                        <Button Content="Sort by" Width="70" Height="30" Margin="0,0,10,0"
                                Grid.Column="2" Click="SortBy_Click"/>
                        <!-- ADD APPOINTMENT -->
                        <Button Content="Appointment" Width="140" Height="40"
                                Grid.Column="3"
                                Background="#7E6DE7" Foreground="White"
                                Click="AddAppointment_Click"/>
                    </Grid>
                </StackPanel>

                <!-- DataGrid Panel -->
                <Border Grid.Row="2" Background="#DFF7F6"
                        CornerRadius="14" Padding="14" Margin="0,20,0,0">
                    <Grid>
                        <DataGrid x:Name="AppointmentDataGrid"
                            AutoGenerateColumns="False"
                            GridLinesVisibility="None"
                            HeadersVisibility="Column"
                            Background="Transparent"
                            BorderThickness="0"
                            IsReadOnly="False" 
                            CanUserAddRows="False"
                            CanUserDeleteRows="False">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Patient ID" Binding="{Binding PatientID}" Width="120"/>
                            <DataGridTextColumn Header="Patient Name" Binding="{Binding PatientName}" Width="*"/>
                            <DataGridTextColumn Header="Treatment" Binding="{Binding Treatment}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="110"/>

                            <DataGridTemplateColumn Header="Status" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content">
                                            <ComboBoxItem Content="Pending"/>
                                            <ComboBoxItem Content="Completed"/>
                                            <ComboBoxItem Content="Cancelled"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>


                        </DataGrid.Columns>
                    </DataGrid>

                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
