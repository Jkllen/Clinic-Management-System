<Window x:Class="Clinic_Management_System.Appointment_Functions.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Appointments"
        Height="300" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Filter Appointments" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>
        <TextBlock Text="Type" FontSize="12" FontWeight="Regular" Margin="0,0,0,5" HorizontalAlignment="Left"/>
        <ComboBox x:Name="cmbType" Margin="0,0,0,10">
            <ComboBoxItem Content="Any" IsSelected="True"/>
            <ComboBoxItem Content="Walk-in"/>
            <ComboBoxItem Content="Scheduled"/>
        </ComboBox>
        <TextBlock Text="Status" FontSize="12" FontWeight="Regular" Margin="0,0,0,5" HorizontalAlignment="Left"/>
        <ComboBox x:Name="cmbStatus" Margin="0,0,0,20">
            <ComboBoxItem Content="Any" IsSelected="True"/>
            <ComboBoxItem Content="Pending"/>
            <ComboBoxItem Content="Cancelled"/>
            <ComboBoxItem Content="Ongoing"/>
            <ComboBoxItem Content="Completed"/>
        </ComboBox>
        <Button Content="Apply Filter" Height="42" Background="#2E4A78" Foreground="White" Click="ApplyFilter_Click"/>
    </StackPanel>
</Window>
